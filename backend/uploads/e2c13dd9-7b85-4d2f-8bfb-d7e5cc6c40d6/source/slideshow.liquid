						},
						{
							"value": "full",
							"label": "Full Screen"
						}
					]
				},
				{
					"type": "html",
					"id": "caption",
					"label": "Caption"
				},
				{
					"type": "html",
					"id": "heading",
					"default": "<p>Heading</p>",
					"label": "t:sections.all.heading.label"
				},
				{
					"type": "html",
					"id": "subtitle",
					"label": "Subtitle"
				},
				{
					"type": "html",
					"id": "additional_information",
					"default": "Some additional information",
					"label": "t:sections.all.text.label"
				},
				{
					"type": "checkbox",
					"id": "show_review_rating",
					"label": "Show Review Rating",
