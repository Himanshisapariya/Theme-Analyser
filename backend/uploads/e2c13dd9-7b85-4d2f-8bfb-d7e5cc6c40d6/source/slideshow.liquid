				},
				{
					"type": "range",
					"id": "review_count",
					"label": "Review Count",
					"min": 1,
					"max": 5,
					"step": 1,
					"default": 5,
					"unit": "px",
					"visible_if": "{{ block.settings.show_review_rating == true }}"
				},
				{
					"type": "select",
					"id": "text_content_alignment",
					"default": "top-left",
					"label": "Text Content Alignment",
					"options": [
						{ "value": "top-left", "label": "Top Left" },
						{ "value": "top-center", "label": "Top Center" },
						{ "value": "top-right", "label": "Top Right" },
						{ "value": "center-left", "label": "Center Left" },
						{ "value": "center", "label": "Center" },
						{ "value": "center-right", "label": "Center Right" },
						{ "value": "bottom-left", "label": "Bottom Left" },
						{ "value": "bottom-center", "label": "Bottom Center" },
						{ "value": "bottom-right", "label": "Bottom Right" }
					]
				},
				{
					"type": "select",
					"id": "text_alignment",
					"default": "left",
					"label": "t:sections.all.text.text__alignment.header.content",
					"options": [
						{
							"value": "left",
							"label": "t:sections.all.text.text__alignment.horizontal.options__1.label"
						},
						{
							"value": "center",
							"label": "t:sections.all.text.text__alignment.horizontal.options__2.label"
						},
						{
							"value": "right",
							"label": "t:sections.all.text.text__alignment.horizontal.options__3.label"
						}
					]
				},
				{
					"type": "range",
					"id": "max_width",
					"label": "Content Max Width (px)",
					"min": 200,
					"max": 1600,
					"step": 25,
					"default": 1175
				},
				{
					"type": "header",
					"content": "t:sections.all.button.header_button.content"
				},
				{
					"type": "text",
					"id": "button_label1",
					"default": "Label",
					"label": "t:sections.all.button.button_text.label"
				},
				{
					"type": "url",
					"id": "button_link1",
					"label": "t:sections.all.button.button_link.label"
				},
