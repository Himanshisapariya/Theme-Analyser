{%- style -%}
    .collection-grid-section.section-{{ section.id }} {
      padding-top: {{ section.settings.top_padding_desktop }}px;
      padding-bottom: {{ section.settings.bottom_padding_desktop }}px;
    }
  
    .sale-ctm-banner {
      background-color: {{ section.settings.color_code }}
    }
  
    @media screen and (max-width: 990px) {
      .collection-grid-section.section-{{ section.id }} {
        padding-top: {{ section.settings.top_padding_mobile }}px;
        padding-bottom: {{ section.settings.bottom_padding_mobile }}px;
      }
    }
  
    .collection-grid-section.section-{{ section.id }} {
      margin-top: {{ section.settings.top_margin_desktop}}px;
      margin-bottom: {{ section.settings.bottom_margin_desktop }}px;
    }
  
    @media screen and (max-width: 990px) {
      .collection-grid-section.section-{{ section.id }} {
        margin-top: {{ section.settings.top_margin_mobile }}px;
        margin-bottom: {{ section.settings.bottom_margin_mobile }}px;
      }
    }
  
    .collection-tabs {
      display: flex;
      justify-content: center;
      margin-bottom: 25px;
      gap: 20px;
    }
  
    .collection-tab {
      font-size: 18px;
      font-weight: 600;
      cursor: pointer;
      text-transform: uppercase;
      color: #777;
      transition: color 0.3s ease, border-color 0.3s ease;
      border-bottom: 2px solid transparent;
      padding-bottom: 4px;
    }
  
    .collection-tab.active {
      color: #000;
      border-color: #000;
    }
  
  {%- endstyle -%}
  
  <section
    class="collection-grid-section section-{{ section.id }} {% if section.settings.enable_full_width == false %} fullscreen-container{% endif %}  {{ section.settings.section_extra_class }}"
    style="{% if section.settings.background_color != blank %}background-color: {{ section.settings.background_color }};{% endif %}"
  >
    <div class="text-btn-container fullscreen-container">
      <div class="grid-title">
        {% if section.settings.heading != blank %}
          <h2 class="collection-grid-heading alignmnet-{{ section.settings.text_alignment }}">{{ section.settings.heading }}</h2>
        {% endif %}
      </div>
      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="button button--rebuy collection-grid-btn">
          {{- section.settings.button_label -}}
        </a>
      {% endif %}
      
    {%- assign tab_labels = section.blocks | map: 'settings' | map: 'tab_category' | uniq -%}
    {%- if tab_labels.size > 1 -%}
      <div class="collection-tabs">
        {% for tab in tab_labels %}
          {% if tab != blank %}
            <p class="collection-tab {% if forloop.first %}active{% endif %}" data-tab="{{ tab | handleize }}">{{ tab }}</p>
          {% endif %}
        {% endfor %}
      </div>
    {%- endif -%}
      
    </div>
  
  
    {% for tab in tab_labels %}
      <div
        class="collection-grid swiper-collection-container swiper-container-{{ section.id }} tab-group tab-{{ tab | handleize }} {% unless forloop.first %}hidden{% endunless %}"
        data-desktop-slides="{{ section.settings.desktop_slide | default: 4 }}" data-small-desktop-slides="{{ section.settings.small_desktop_slide | default: 3 }}" data-mobile-slides="{{ section.settings.mobile_slide | default: 4 }}"
      >
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            {% if block.settings.tab_category == tab %}
              {% assign collection = collections[block.settings.collection] %}
              <div class="swiper-slide collection-item-wrapper {% if section.settings.text-placement == 'above_product' %} ctm-image-above-title {% endif %}" {{ block.shopify_attributes }}>
                <div class="collection-item">
                  <a href="{% if collection.url != blank %}{{ collection.url }}{% else %}{{ block.settings.link }}{% endif %}" class="card-link">
                    <div class="image-card-inner_img">
                      {% if block.settings.custom_image %}
                        <img
                          src="{{ block.settings.custom_image | image_url: width: 4096 }}"
                          alt="{{ block.settings.title | escape }}"
                          class="collection-image"
                          height="auto"
                          width="auto"
                        >
                      {% elsif collection.image %}
                        <img
                          src="{{ collection.image | image_url: width: 4096 }}"
                          alt="{{ collection.title | escape }}"
                          class="collection-image"
                          height="auto"
                          width="auto"
                        >
                      {% endif %}
                    </div>
                    <div class="collection-content">
                      {% if block.settings.title == blank and block.settings.enable_title %}
                        {% if collection.title != blank %}
                        <h3 class="collection-title">{{ collection.title }}</h3>
                        {% endif %}
                      {% else %}
                        {% if block.settings.title != blank %}
                        <h3 class="collection-title">{{ block.settings.title }}</h3>
                        {% endif %}
                      {% endif %}
                      {% if block.settings.subtext != blank %}
                        <div class="collection-subtext">
                          <p class="collection-subtext">{{ block.settings.subtext }}</p>
                        </div>
                      {% endif %}
                      <div class="collection-desc-btn">
                        {% if block.settings.description != blank %}
                          <div class="collection-description-main">
                            {{ block.settings.description }}
                          </div>
                        {% endif %}
                        <div class="collection-button-main">
                          {% if block.settings.button_label != blank %}
                            <div class="button collection-button">
                              {{- block.settings.button_label -}}
                            </div>
                          {% endif %}
                        </div>
                      </div>
                    </div>
                  </a>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endfor %}
  </section>
  
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      initializeCollectionSliders();
  
      const tabs = document.querySelectorAll('.collection-tab');
      const tabGroups = document.querySelectorAll('.tab-group');
  
      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          tabs.forEach(t => t.classList.remove('active'));
          tab.classList.add('active');
  
          const selected = tab.dataset.tab;
          tabGroups.forEach(group => {
            if (group.classList.contains(`tab-${selected}`)) {
              group.classList.remove('hidden');
              group.style.display = 'block';
            } else {
              group.classList.add('hidden');
              group.style.display = 'none';
            }
          });
        });
      });
    });
  
    if (typeof Shopify !== 'undefined') {
      document.addEventListener('shopify:section:load', function (event) {
        initializeCollectionSliders(event.target);
      });
    }
  
    function initializeCollectionSliders(container = document) {
      const sliders = container.querySelectorAll('.swiper-collection-container:not(.swiper-initialized)');
      sliders.forEach((sliderContainer) => {
        const desktopSlides = parseFloat(sliderContainer.dataset.desktopSlides) || 4;
        const smallDesktopSlides = parseFloat(sliderContainer.dataset.smallDesktopSlides) || 3;
        const mobileSlides = parseFloat(sliderContainer.dataset.mobileSlides) || 1;
  
        const swiper = new Swiper(sliderContainer, {
          slidesPerView: mobileSlides,
          spaceBetween: 2,
          centeredSlides: false,
          loop: false,
          slideClass: 'swiper-slide',
          wrapperClass: 'swiper-wrapper',
          breakpoints: {
            425: { slidesPerView: mobileSlides, spaceBetween: 4 },
            575: { slidesPerView: 1.6, spaceBetween: 4 },
            768: { slidesPerView: 2.1, spaceBetween: 4 },
            1024: { slidesPerView: 2.6, spaceBetween: 4 },
            1200: { slidesPerView: smallDesktopSlides, spaceBetween: 4 },
            1600: { slidesPerView: desktopSlides, spaceBetween: 4 },
          },
          on: {
            init() { this.update(); },
            resize() { this.update(); },
          },
        });
  
        const resizeObserver = new ResizeObserver(() => swiper.update());
        resizeObserver.observe(sliderContainer);
        sliderContainer.classList.add('swiper-initialized');
      });
    }
  </script>
  
  {% schema %}
  {
    "name": "Homepage Collection Grid",
    "settings": [
      {
        "type": "text",
        "label": "Section Extra Class",
        "id": "section_extra_class"
      },
      {
        "type": "checkbox",
        "id": "enable_full_width",
        "label": "Enable Full Width",
        "default": false
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading"
      },
      {
        "type": "text_alignment",
        "label": "Text Alignment",
        "id": "text_alignment",
        "default": "left"
      },
      {
        "type": "select",
        "id": "text-placement",
        "label": "Text Placement",
        "options": [
          { "value": "above_product", "label": "Above Product" },
          { "value": "below_product", "label": "Below Product" }
        ],
        "default": "below_product"
      },
      {
        "type": "color",
        "id": "background_color",
        "label": "Background Color",
        "default": "#f7f7f7"
      },
      {
        "type": "text",
        "id": "button_label",
        "label": "Button Label"
      },
      {
        "type": "url",
        "id": "button_link",
        "label": "Button Link"
      },
      {
        "type": "select",
        "id": "button_style",
        "options": [
          { "value": "primary", "label": "Primary" },
          { "value": "secondary", "label": "Secondary" },
          { "value": "tertiary", "label": "Tertiary" },
          { "value": "link", "label": "As Link" }
        ],
        "default": "primary",
        "label": "Button Style"
      },
      {
        "type": "text",
        "label": "Underline Color",
        "id": "underline_color",
        "default": "#000000"
      },
      {
        "type": "range",
        "label": "Small Desktop Slide per view (1200px - 1600px)",
        "id": "small_desktop_slide",
        "default": 3,
        "min": 2,
        "max": 5,
        "step": 0.1
      },
      {
        "type": "range",
        "label": "Desktop Slide per view (1600px+)",
        "id": "desktop_slide",
        "default": 4,
        "min": 3,
        "max": 6,
        "step": 0.1
      },
      {
        "type": "range",
        "label": "Mobile Slide per view",
        "id": "mobile_slide",
        "default": 1,
        "min": 1,
        "max": 4,
        "step": 0.1
      },
      { "type": "header", "content": "Section Spacing" },
      { "type": "range", "label": "Top Padding Desktop", "id": "top_padding_desktop", "default": 0, "min": 0, "max": 100, "step": 5, "unit": "px" },
      { "type": "range", "label": "Bottom Padding Desktop", "id": "bottom_padding_desktop", "default": 0, "min": 0, "max": 100, "step": 5, "unit": "px" },
      { "type": "range", "label": "Top Padding Mobile", "id": "top_padding_mobile", "default": 0, "min": 0, "max": 100, "step": 5, "unit": "px" },
      { "type": "range", "label": "Bottom Padding Mobile", "id": "bottom_padding_mobile", "default": 0, "min": 0, "max": 100, "step": 5, "unit": "px" },
      { "type": "range", "label": "Top Margin Desktop", "id": "top_margin_desktop", "default": 0, "min": 0, "max": 100, "step": 5, "unit": "px" },
      { "type": "range", "label": "Bottom Margin Desktop", "id": "bottom_margin_desktop", "default": 0, "min": 0, "max": 100, "step": 5, "unit": "px" },
      { "type": "range", "label": "Top Margin Mobile", "id": "top_margin_mobile", "default": 0, "min": 0, "max": 100, "step": 5, "unit": "px" },
      { "type": "range", "label": "Bottom Margin Mobile", "id": "bottom_margin_mobile", "default": 0, "min": 0, "max": 100, "step": 5, "unit": "px" }
    ],
    "blocks": [
      {
        "type": "collection_item",
        "name": "Collection Item",
        "settings": [
          { "type": "collection", "id": "collection", "label": "Select Collection" },
          { "type": "url", "id": "link", "label": "Link" },
          { "type": "image_picker", "id": "custom_image", "label": "Custom Image (optional)" },
          { "type": "text", "id": "title", "label": "Title" },
          { "type": "checkbox", "id": "enable_title", "label": "Display Collection Title", "default": false },
          { "type": "html", "id": "subtext", "label": "Subtext" },
          { "type": "html", "id": "description", "label": "Description" },
          { "type": "text", "id": "button_label", "label": "Button Label", "default": "Shop Now" },
          {
            "type": "select",
            "id": "tab_category",
            "label": "Tab Category",
            "options": [
              { "value": "Men's", "label": "Men's" },
              { "value": "Women's", "label": "Women's" }
            ],
            "default": "Men's"
          }
          
        ]
      }
    ],
    "presets": [
      {
        "name": "Homepage Collection Grid",
        "category": "Custom",
        "blocks": []
      }
    ]
  }
  {% endschema %}
  