    "multicolumn_4cU969": {
      "type": "multicolumn",
      "blocks": {
        "column_UEB9VE": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/mugshot_0000s_0007_Generative_Fill_8.jpg",
            "heading": "Jennifer Sey Founder and CEO",
            "text": "Jennifer believes in hard work, telling the truth and standing by your principles. Even when – especially when? – its hard. Otherwise, they’re platitudes not principles.\nShe was the 1986 U.S. Women's Gymnastics National Champion and a 7x National Team member.<br><br>\nIn 2020, she was the only C-suite executive to speak out against covid lockdowns and school closures. That didn’t go super well for her. But she dusted herself off and now, she is the founder and CEO of XX-XY Athletics – the only athletic brand to stand up for women’s sports and female athletes.",
            "button_label": "More About Jen",
            "button_link": "shopify://pages/our-founder"
          }
        },
        "column_XEXy96": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/mugshot_0000s_0026_Generative_Fill_29.jpg",
            "heading": "Brett",
            "text": "Brett Craig is an award-winning ad man who once created Super Bowl commercials for brands such as Taco Bell and Pepsi. Now he’s the creative genius behind all the viral ads from XX-XY Athletics. He can’t think of a more worthy cause than working for a company that stands up for his daughters’ right to participate in athletics on a level playing field.",
            "button_label": "",
            "button_link": ""
          }
        },
        "column_WrQ8dX": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/mugshot_0000s_0021_Generative_Fill_24.jpg",
            "heading": "Josh",
            "text": "Josh is a retired pro athlete and sports industry vet. Occasionally accused of being deeply curious and analytical, his longest standing personal research project on “Truth” began in May 2006 with the birth of the first of four daughters. Despite many opportunities to give up on the experiment, he has never lied to his kids (and they are all doing just fine). The truth always fits.",
            "button_label": "",
            "button_link": ""
          }
        },
        "column_ABLqEq": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/mugshot_0000s_0014_Generative_Fill_18.jpg",
            "heading": "Krista",
            "text": "Without Krista there are no amazing XX-XY Athletics clothing items to buy. She is proud and excited to be creating in an environment that TRULY values free speech and open debate. And guess what, it makes her work stronger. Because when you’re not afraid of offending someone all the time, your brain works better.",
            "button_label": "",
            "button_link": ""
          }
        },
        "column_aenAWP": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/maggie.jpg",
            "heading": "Maggie",
            "text": "Maggie is a recent graduate of SCAD (Savannah College of Art and Design), where she earned her BFA in Graphic Design. She has a strong passion for truth, which is how our team discovered her. She was canceled at SCAD for creating an editorial that told and photographed the story of detransitioner Chloe Cole. Much of her artwork focuses on social, political, and cultural issues, making XX-XY Athletics the perfect match for Maggie!",
            "button_label": "",
            "button_link": ""
          }
        },
        "column_yBj6iQ": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/cindy.jpg",
            "heading": "Cindy",
            "text": "Cindy is our numbers guru. For Cindy, numbers are more than just data—they are real truths that tell the story of a business. With a knack for scaling startups, Cindy ensures every dollar is put to work in ways that align with our mission of standing up for women’s sports.",
            "button_label": "",
            "button_link": ""
          }
        },
        "column_w3MWE8": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/Screenshot_2025-02-26_at_10.03.09_AM.png",
            "heading": "Brooke",
            "text": "Brooke is the whiz behind the XX-XY Athletics website, making sure it’s more than just a place to shop—it’s a statement. Before jumping into the world of women’s sports and unapologetic truth, she was making moves in the beauty industry. But when the opportunity came to be part of something bigger, she traded lipstick for logos and never looked back.",
            "button_label": "",
            "button_link": ""
          }
        },
        "column_UQ7XKa": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/Sarah.jpg",
            "heading": "Sarah",
            "text": "Sarah leads our PR and communications, bringing energy and a sharp focus to crafting communication campaigns and building partnerships for the first brand to take a stand for women’s sports. Sarah played Division I lacrosse at a time when speed and aggression were enough – but knows the secret that all women athletes hold close: they have yet to realize their full power.",
            "button_label": "",
            "button_link": ""
          }
        },
        "column_dCdBBy": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/DSC09585.jpg",
            "heading": "Milagros",
            "text": "Milagros brings over 25 years of textile expertise, proudly representing Peru and having worked with top American high-end brands. At XX-XY Athletics, she drives innovation with a focus on excellence, integrity, and care. Affectionately known as the team’s “mom,” Milagros fosters a culture of authenticity, collaboration, and faith-driven leadership. Rooted in her traditional Catholic upbringing and love for dogs, she brings warmth and purpose to her work. Passionate about women’s sports, she is committed to protecting and supporting female athletes at every step.",
            "button_label": "",
            "button_link": ""
          }
        }
