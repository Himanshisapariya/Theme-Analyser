<style>
.review-ctm-wrapper {
    display: flex;
    justify-content: space-evenly;
    flex-wrap: wrap; 
    gap: 20px; 
    padding: 20px; 
}

.review-ctm {
    max-width: 47%; 
    background-color: #e8e8e8;
    padding: 23px;
    box-sizing: border-box; 
}

.review-ctm img {
    margin: auto;
    max-width: 100%; 
    display: flex;
    height: 70px;
}

.review-ctm-text {
    margin-bottom: 20px;
    font-weight: 600;
    font-size: 19px;
    text-align: center;
    letter-spacing: -0.005em;
    line-height: 1.714;
}
.review-ctm-text p{
    margin: 0;
}
.review-ctm-text > h3 {
    text-align: center;
    font-weight: 600;
    font-size: 20px;
}

.review-ctm-name {
    text-align: center;
    color: #99a8a9;
    font-size: 20px;
}

@media (max-width: 768px) {
    .review-ctm-wrapper {
        justify-content: center; 
    }

    .review-ctm {
        max-width: 90%; 
        width: 100%; 
    }

    .review-ctm-text {
        font-size: 16px;
    }

    .review-ctm-text > h3 {
        font-size: 20px;
    }
}

@media (max-width: 480px) {
    .review-ctm-text {
        font-size: 14px;
    }

    .review-ctm-text > h3 {
        font-size: 18px;
    }
}
</style>

<div class="review-ctm-wrapper">
    {% for block in section.blocks %}
    <div class="review-ctm">
        {% if block.settings.image %}
        <img src="{{ block.settings.image | image_url }}" class="review-ctm-img" alt="">
        {% endif %}
        {% if block.settings.text %}
        <div class="review-ctm-text">{{ block.settings.text }}
        </div>
        {% endif %}
        {% if block.settings.name %}
        <div class="review-ctm-name">
           {{ block.settings.name }}
        </div>
        {% endif %}
    </div>
    {% endfor %}
</div>


{% schema %}
    {
      "name": "reviews CTM",
      "settings": [
        
      ],
      "blocks": [
        {
          "type": "review",
          "name": "Review",
          "settings": [
            {
              "type": "image_picker",
              "label": "Image",
              "id": "image"
            },
            {
            "type": "html",
            "label": "Text",
            "id": "text"
            },
            {
            "type": "text",
            "label": "Name",
            "id": "name"
            }
          ]
        }
      ],
      "presets": [
        {
          "name": "Review CTM Section"
        }
      ]
    }
    {% endschema %}

