{% doc %}
  @prompt
    can you create a spacer i can use for both mobile and desktop and i can change how big/small it is and the color?
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-spacer-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.desktop_height }}px;
    background-color: {{ block.settings.background_color }};
    display: block;
  }

  @media screen and (max-width: 749px) {
    .ai-spacer-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_height }}px;
    }
  }
{% endstyle %}

<div
  class="ai-spacer-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
></div>

{% schema %}
{
  "name": "Spacer",
  "settings": [
    {
      "type": "header",
      "content": "Desktop"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "min": 10,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Height",
      "default": 50
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "range",
      "id": "mobile_height",
      "min": 10,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Height",
      "default": 30
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "transparent"
    }
  ],
  "presets": [
    {
      "name": "Spacer"
    }
  ],
  "tag": null
}
{% endschema %}