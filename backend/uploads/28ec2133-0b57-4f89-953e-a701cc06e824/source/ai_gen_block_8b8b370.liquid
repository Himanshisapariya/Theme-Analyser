{% doc %}
  @prompt
    I want an area to insert a h1 and h2 ha3 and h4 of just text, no button or anything. I need it to go above something
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-headings-{{ ai_gen_id }} {
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    text-align: {{ block.settings.text_alignment }};
    color: {{ block.settings.text_color }};
    background-color: {{ block.settings.background_color }};
  }

  .ai-text-headings-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-text-headings-h1-{{ ai_gen_id }} {
    font-size: {{ block.settings.h1_size }}px;
    font-weight: {{ block.settings.h1_weight }};
    line-height: {{ block.settings.h1_line_height }};
    margin: 0 0 {{ block.settings.h1_margin_bottom }}px;
    color: {{ block.settings.h1_color }};
  }

  .ai-text-headings-h2-{{ ai_gen_id }} {
    font-size: {{ block.settings.h2_size }}px;
    font-weight: {{ block.settings.h2_weight }};
    line-height: {{ block.settings.h2_line_height }};
    margin: 0 0 {{ block.settings.h2_margin_bottom }}px;
    color: {{ block.settings.h2_color }};
  }

  .ai-text-headings-h3-{{ ai_gen_id }} {
    font-size: {{ block.settings.h3_size }}px;
    font-weight: {{ block.settings.h3_weight }};
    line-height: {{ block.settings.h3_line_height }};
    margin: 0 0 {{ block.settings.h3_margin_bottom }}px;
    color: {{ block.settings.h3_color }};
  }

  .ai-text-headings-h4-{{ ai_gen_id }} {
    font-size: {{ block.settings.h4_size }}px;
    font-weight: {{ block.settings.h4_weight }};
    line-height: {{ block.settings.h4_line_height }};
    margin: 0 0 {{ block.settings.h4_margin_bottom }}px;
    color: {{ block.settings.h4_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-text-headings-h1-{{ ai_gen_id }} {
      font-size: {{ block.settings.h1_size | times: 0.8 }}px;
    }
    
    .ai-text-headings-h2-{{ ai_gen_id }} {
      font-size: {{ block.settings.h2_size | times: 0.8 }}px;
    }
    
    .ai-text-headings-h3-{{ ai_gen_id }} {
      font-size: {{ block.settings.h3_size | times: 0.8 }}px;
    }
    
    .ai-text-headings-h4-{{ ai_gen_id }} {
      font-size: {{ block.settings.h4_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-text-headings-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-headings-container-{{ ai_gen_id }}">
    {% if block.settings.h1_text != blank %}
      <h1 class="ai-text-headings-h1-{{ ai_gen_id }}">{{ block.settings.h1_text }}</h1>
    {% endif %}
    
    {% if block.settings.h2_text != blank %}
      <h2 class="ai-text-headings-h2-{{ ai_gen_id }}">{{ block.settings.h2_text }}</h2>
    {% endif %}
    
    {% if block.settings.h3_text != blank %}
      <h3 class="ai-text-headings-h3-{{ ai_gen_id }}">{{ block.settings.h3_text }}</h3>
    {% endif %}
    
    {% if block.settings.h4_text != blank %}
      <h4 class="ai-text-headings-h4-{{ ai_gen_id }}">{{ block.settings.h4_text }}</h4>
    {% endif %}
  </div>
</div>

