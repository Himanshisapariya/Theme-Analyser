{
  "name": "pooof",
  "version": "1.0.0",
  "description": "[![Build status](https://github.com/shopify/dawn/actions/workflows/ci.yml/badge.svg?branch=main)](https://github.com/Shopify/dawn/actions/workflows/ci.yml?query=branch%3Amain) [![PRs Welcome](https://img.shields.io/badge/PRs-welcome-brightgreen.svg?color=informational)](/.github/CONTRIBUTING.md)",
  "main": "index.js",
  "scripts": {
    "build": "npx @tailwindcss/cli -i css/application.css -o assets/application.css.liquid -w -m",
    "format": "prettier --write snippets/ templates/ sections/ layout/ config/ assets/",
    "lint": "eslint . --ext .js",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": "eslint --fix",
    "*.{js,jsx,ts,tsx,css,md,liquid}": "prettier --write"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crea8ivedev/pooof.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/crea8ivedev/pooof/issues"
  },
  "homepage": "https://github.com/crea8ivedev/pooof#readme",
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@shopify/prettier-plugin-liquid": "^1.9.2",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "prettier": "^3.5.3"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.1.3",
    "tailwindcss": "^4.1.3"
  }
}