{% doc %}
  @prompt
    can you just give me a blank white section i can change the size and color of on mobile and desktop
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-blank-section-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    width: 100%;
    padding-top: {{ block.settings.padding_top_desktop }}px;
    padding-bottom: {{ block.settings.padding_bottom_desktop }}px;
    padding-left: {{ block.settings.padding_left_desktop }}px;
    padding-right: {{ block.settings.padding_right_desktop }}px;
    min-height: {{ block.settings.min_height_desktop }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-blank-section-{{ ai_gen_id }} {
      background-color: {{ block.settings.background_color_mobile }};
      padding-top: {{ block.settings.padding_top_mobile }}px;
      padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
      padding-left: {{ block.settings.padding_left_mobile }}px;
      padding-right: {{ block.settings.padding_right_mobile }}px;
      min-height: {{ block.settings.min_height_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-blank-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
</div>

{% schema %}
{
  "name": "Blank section",
  "settings": [
    {
      "type": "header",
      "content": "Desktop settings"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "min_height_desktop",
      "min": 0,
      "max": 800,
      "step": 10,
      "unit": "px",
      "label": "Minimum height",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_left_desktop",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Left padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right_desktop",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Right padding",
      "default": 20
    },
    {
      "type": "header",
      "content": "Mobile settings"
    },
    {
      "type": "color",
      "id": "background_color_mobile",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "min_height_mobile",
      "min": 0,
      "max": 600,
