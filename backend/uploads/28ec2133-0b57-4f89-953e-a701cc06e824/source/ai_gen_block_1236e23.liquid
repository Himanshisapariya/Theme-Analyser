{% doc %}
  @prompt
    can you give me a section for me to write legal in super small copy at the bottom, sorry even smaller for some reason the font isnt adjusting, but like 7 font for mobile and desktop
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-legal-text-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-legal-text-content-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    font-size: {{ block.settings.font_size }}px !important;
    line-height: {{ block.settings.line_height }};
    color: {{ block.settings.text_color }};
    font-family: {{ block.settings.font_family.family }}, {{ block.settings.font_family.fallback_families }};
    font-weight: {{ block.settings.font_family.weight }};
  }

  .ai-legal-text-content-{{ ai_gen_id }} * {
    font-size: {{ block.settings.font_size }}px !important;
    line-height: {{ block.settings.line_height }} !important;
  }

  .ai-legal-text-content-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: {{ block.settings.link_style }};
    font-size: {{ block.settings.font_size }}px !important;
  }

  .ai-legal-text-content-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
    text-decoration: underline;
  }

  .ai-legal-text-content-{{ ai_gen_id }} p {
    margin: 0 0 {{ block.settings.paragraph_spacing }}px;
    font-size: {{ block.settings.font_size }}px !important;
  }

  .ai-legal-text-content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-legal-text-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_padding_top }}px {{ block.settings.mobile_padding_horizontal }}px {{ block.settings.mobile_padding_bottom }}px;
    }

    .ai-legal-text-content-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_font_size }}px !important;
    }

    .ai-legal-text-content-{{ ai_gen_id }} *,
    .ai-legal-text-content-{{ ai_gen_id }} p,
    .ai-legal-text-content-{{ ai_gen_id }} a {
      font-size: {{ block.settings.mobile_font_size }}px !important;
    }
  }
{% endstyle %}

<div class="ai-legal-text-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-legal-text-content-{{ ai_gen_id }}">
    {% if block.settings.legal_text != blank %}
      {{ block.settings.legal_text }}
    {% else %}
      <p>© {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved. | <a href="/pages/privacy-policy">Privacy Policy</a> | <a href="/pages/terms-of-service">Terms of Service</a></p>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Legal text",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "legal_text",
      "label": "Legal text",
      "default": "<p>© 2024 Your Store Name. All rights reserved. | <a href=\"/pages/privacy-policy\">Privacy Policy</a> | <a href=\"/pages/terms-of-service\">Terms of Service</a></p>"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "font_family",
      "label": "Font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 6,
      "max": 16,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 7
    },
    {
      "type": "range",
      "id": "mobile_font_size",
      "min": 6,
      "max": 14,
      "step": 1,
      "unit": "px",
      "label": "Mobile font size",
      "default": 7
    },
    {
      "type": "range",
      "id": "line_height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "label": "Line height",
      "default": 1.3
    },
    {
      "type": "range",
      "id": "paragraph_spacing",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Paragraph spacing",
      "default": 6
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 600,
      "max": 1400,
      "step": 50,
      "unit": "px",
      "label": "Maximum width",
      "default": 1200
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Mobile top padding",
      "default": 16
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Mobile bottom padding",
      "default": 16
    },
    {
      "type": "range",
      "id": "mobile_padding_horizontal",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Mobile horizontal padding",
      "default": 16
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f3f3f3"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link hover color",
      "default": "#334fb4"
    },
    {
      "type": "select",
      "id": "link_style",
      "label": "Link style",
      "options": [
        {
          "value": "none",
          "label": "No underline"
        },
        {
          "value": "underline",
          "label": "Underlined"
        }
      ],
      "default": "none"
    }
  ],
  "presets": [
    {
      "name": "Legal text"
    }
  ]
}
{% endschema %}