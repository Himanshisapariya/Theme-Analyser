<div class="athlete-image-with-text-section {{ section.settings.extra_class }}">
  <div class="athlete-image-with-text-container {% if section.settings.image_position == 'right' %}image-right{% else %}image-left{% endif %}">
    
    <div class="athlete-image-block">
      {% if section.settings.image != blank %}
        {% assign img = section.settings.image %}
        <div class="athlete-slide-inner">
          <img src="{{ img | image_url: width: 1200 }}"
               alt="{{ img.alt | escape }}"
               class="athlete-image"
               loading="lazy">
        </div>
      {% else %}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </div>
    
    <div class="athlete-text-block">
      {% if section.settings.heading != blank %}
        <h1 class="athlete-heading">{{ section.settings.heading }}</h1>
      {% endif %}
      
      {% if section.settings.text != blank %}
        <div class="athlete-text">{{ section.settings.text }}</div>
      {% endif %}
      
      {% if section.settings.button_label != blank and section.settings.button_link != blank %}
        <a href="{{ section.settings.button_link }}" class="athlete-button">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>
    
  </div>
</div>

<style>


#shopify-section-{{ section.id }} .athlete-image-with-text-section {
  margin-top: {{ section.settings.desktop_margin_top }}px;
  margin-bottom: {{ section.settings.desktop_margin_bottom }}px;
}

#shopify-section-{{ section.id }} .athlete-image-block {
  flex: 0 0 {{ section.settings.image_width }}%;
  width: {{ section.settings.image_width }}%;
  aspect-ratio: {{ section.settings.image_aspect_ratio }};
}

@media screen and (max-width: 768px) {
  #shopify-section-{{ section.id }} .athlete-image-with-text-section {
    margin-top: {{ section.settings.mobile_margin_top }}px;
    margin-bottom: {{ section.settings.mobile_margin_bottom }}px;
  }

  #shopify-section-{{ section.id }} .athlete-image-block {
    aspect-ratio: {{ section.settings.mobile_image_aspect_ratio }};
  }
}


.athlete-image-with-text-section {
  padding: 25px 0;
}

.athlete-image-with-text-container {
  display: flex;
  align-items: center;
  gap: 60px;
  margin: 0 auto;
  max-width: 1400px;
  padding: 0 40px;
}

.athlete-image-with-text-container.image-left {
  flex-direction: row;
}

.athlete-image-with-text-container.image-right {
  flex-direction: row-reverse;
}

.athlete-image-block {
  position: relative;
  overflow: hidden;
  border-radius: 12px;
}

.athlete-slide-inner {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.athlete-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center center;
  border-radius: 12px;
  will-change: transform;
}

.athlete-text-block {
  flex: 1 1 0;
  min-width: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 28px;
}

.athlete-heading {
  font-weight: 500;
  margin: 0;
  padding: 0;
}

.athlete-text {
  display: flex;
  flex-direction: column;
  gap: 15px;
}

.athlete-text h6,
.athlete-text p,
.athlete-text span {
  font-weight: 400;
  margin: 0;
  padding: 0;
}

.athlete-button {
  display: inline-block;
  margin-top: 8px;
  text-decoration: underline;
  text-underline-offset: 3px;
}


@media screen and (min-width: 1861px) {
  .athlete-heading { font-size: 44px; }
  .athlete-text h6 { font-size: 18px; }
}

@media screen and (min-width: 1024px) and (max-width: 1860px) {
  .athlete-heading { font-size: 28px; }
  .athlete-text h6 { font-size: 16px; }
}

@media screen and (max-width: 1023px) {
  .athlete-heading { font-size: 30px; }
  .athlete-text h6 { font-size: 18px; }
  .athlete-text h6 br {
    display: none;
  }
}


@media screen and (max-width: 768px) {
  .athlete-image-with-text-section {
    padding: 0;
  }

  .athlete-image-with-text-container {
    flex-direction: column !important;
    gap: 40px;
    width: 100%;
    max-width: 100%;
    padding: 0;
    margin-top: 40px;
    margin-bottom: 25px;
  }

  .athlete-image-block {
    flex: 1 1 100%;
    width: 100% !important;
    max-width: 100%;
    border-radius: 0;
  }

  .athlete-image {
    border-radius: 0;
  }

  .athlete-text-block {
    flex: 1 1 100%;
    width: 100%;
    max-width: 100%;
    gap: 30px;
    padding: 0 20px;
  }
}


@media screen and (min-width: 769px) and (max-width: 1023px) {
  .athlete-image-with-text-container {
    gap: 40px;
    max-width: 100%;
    padding: 0 30px;
  }

  .athlete-text-block {
    padding: 0;
  }
}


@media screen and (min-width: 1024px) and (max-width: 1199px) {
  .athlete-image-block {
    aspect-ratio: 0.85 / 1;
  }
}


@media screen and (min-width: 1200px) and (max-width: 1680px) {
  .athlete-image-with-text-container {
    max-width: 1200px;
  }
}
</style>

{% schema %}
{
  "name": "Athlete Image With Text",
  "class": "athlete-image-with-text",
  "settings": [
    {
      "type": "text",
      "id": "extra_class",
      "label": "Extra Class"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "Image Width (Desktop)",
      "min": 20,
      "max": 70,
      "step": 1,
      "unit": "%",
      "default": 50,
      "info": "Percentage of the section width the image occupies on desktop."
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Image Height — Desktop (Aspect Ratio)",
      "options": [
        { "value": "1 / 1",    "label": "Square (1:1)" },
        { "value": "0.75 / 1", "label": "Portrait — Tall (3:4)" },
        { "value": "0.85 / 1", "label": "Portrait — Standard (0.85:1)" },
        { "value": "0.90 / 1", "label": "Portrait — Wide (0.9:1)" },
        { "value": "16 / 9",   "label": "Landscape — Wide (16:9)" },
        { "value": "4 / 3",    "label": "Landscape — Standard (4:3)" },
        { "value": "3 / 2",    "label": "Landscape — Classic (3:2)" }
      ],
      "default": "0.90 / 1",
      "info": "Controls the height of the image on desktop."
    },
    {
      "type": "select",
      "id": "mobile_image_aspect_ratio",
      "label": "Image Height — Mobile (Aspect Ratio)",
      "options": [
        { "value": "1 / 1",    "label": "Square (1:1)" },
        { "value": "0.75 / 1", "label": "Portrait — Tall (3:4)" },
        { "value": "0.85 / 1", "label": "Portrait — Standard (0.85:1)" },
        { "value": "0.90 / 1", "label": "Portrait — Wide (0.9:1)" },
        { "value": "16 / 9",   "label": "Landscape — Wide (16:9)" },
        { "value": "4 / 3",    "label": "Landscape — Standard (4:3)" },
        { "value": "3 / 2",    "label": "Landscape — Classic (3:2)" }
      ],
      "default": "0.90 / 1",
      "info": "Controls the height of the image on mobile. Overrides the desktop setting."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Athlete Spotlight"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Discover inspiring stories from our athletes who push boundaries and break barriers. Their journey embodies the spirit of excellence and determination.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Desktop Spacing"
    },
    {
      "type": "range",
      "id": "desktop_margin_top",
      "label": "Margin Top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "desktop_margin_bottom",
      "label": "Margin Bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "mobile_margin_top",
      "label": "Margin Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "mobile_margin_bottom",
      "label": "Margin Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Athlete Image With Text",
      "category": "Image"
    }
  ]
}
{% endschema %}
