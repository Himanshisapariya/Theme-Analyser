var timeoutId;

var slideImage = function(step) {
    if (step === undefined) step = 1;
    clearTimeout(timeoutId);

    var $messages = $('.announcement-bar__message');
    var visibleMessage = $messages.filter(function() {
        return $(this).css('opacity') == 1;
    });
    var indx = visibleMessage.index('.announcement-bar__message');
    
    if (step != 0) {
        visibleMessage
        .attr('tabindex', -1)
        .find('a')
        .attr('tabindex', -1);

      visibleMessage.animate({ opacity: 0 }, 500, function() {
        $(this).css('display', 'none').attr('aria-hidden', 'true');
      });
    }

    indx = indx + step;
    if (indx >= $messages.length) {
        indx = 0;
    } else if (indx < 0) {
        indx = $messages.length - 1;
    }

    if (step != 0) {
         const message = $messages.eq(indx)
          .css({ display: 'inline-block', opacity: 0 })
          .attr({ tabindex: 0, 'aria-hidden': 'false' })
          .find('a')
          .attr('tabindex', 0)
          .end();

        message.animate({ opacity: 1 }, 500);
    }

    if (step !== 0) {
        timeoutId = setTimeout(slideImage, 4000);
    }
};

slideImage(0);

timeoutId = setTimeout(slideImage, 500);

$('#pause').click(function() {
    clearTimeout(timeoutId);
    $(this).hide();
    $('#play').show();
});

$('#play').click(function() {
    slideImage(0);
    $(this).hide();
    $('#pause').show();
});

