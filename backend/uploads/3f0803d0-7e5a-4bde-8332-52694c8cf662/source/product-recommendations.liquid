<script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>

{% style %}
    {% render 'spaced-section' %}
    {% render 'spaced-section-inner' %}
{% endstyle %}


{%- assign excluded_rec_ids = '8841839280259,8494143963267,8603453948035' | split: ',' -%}

{% if product %}

{% assign color_trigger = settings.trigger_swatch | handle | strip %}

{% assign default_color = '' %}
{% for option in product.options_with_values %}
  {% assign opt_handle = option.name | handle | strip %}
  {% if opt_handle == color_trigger %}
    {% assign default_color = option.selected_value %}
    {% break %}
  {% endif %}
{% endfor %}

<div class="product-recommendations section-{{ section.id }}-padding"
     data-rec-section
     data-default-color="{{ default_color | escape }}"
     data-product-id="{{ product.id }}"
     data-color-trigger="{{ color_trigger }}"
     data-shopify-recommendations-url="/recommendations/products?section_id={{ section.id }}&product_id={{ product.id }}&limit=8&intent=related">
    <div class="product-recommendations__item product-recommendations__item fullscreen-container gts">
        <div class="product-recommendations__header--container recommendations-header">

            <h2 class="product-recommendations__heading h4 title--section"
                data-color-heading
                data-heading-prefix="{{ section.settings.color_heading_prefix | default: 'More in' }}"
                data-default-heading="{{ section.settings.heading | strip_html | strip | escape }}">
                {% if default_color != blank %}
                    {{ section.settings.color_heading_prefix | default: 'More in' }} {{ default_color }}
                {% else %}
                    {{ section.settings.heading | replace: '<p>', '<p class="h4">' }}
                {% endif %}
            </h2>

            {% if section.settings.enable_swiper %}
            <div class="tabbing-arrows header-arrows">
                <div class="swiper-button-prev peev-tabbing-btn swiper-prev-{{ section.id }}">
                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="18" viewBox="0 0 10 18">
                    <path d="M9 17L1 9L9 1" stroke="currentColor" stroke-width="1.5" fill="none"/>
                </svg>
                </div>
                <div class="swiper-button-next next-tabbing-btn swiper-next-{{ section.id }}">
                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="18" viewBox="0 0 10 18">
                    <path d="M1 1L9 9L1 17" stroke="currentColor" stroke-width="1.5" fill="none"/>
                </svg>
                </div>
            </div>
            {% endif %}
        </div>

        <div class="swiper-container swiper product-recommendations">
            <ul class="swiper-wrapper product-recommendations_list ctm-fabric" role="list">
            </ul>
        </div>


        {%- assign product_color_option = nil -%}
        {%- for option in product.options_with_values -%}
          {%- assign opt_h = option.name | handle | strip -%}
          {%- if opt_h == color_trigger -%}
            {%- assign product_color_option = option -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}

        {%- assign color_map_lines = settings.shop_this_color_map | newline_to_br | split: '<br />' -%}

        {%- if recommendations.performed? -%}
          <ul class="rec-slides-pool" data-color-pool="shopify-recs" aria-hidden="true">
            {%- for rec_product in recommendations.products -%}
              {%- assign rec_pid_str = rec_product.id | append: '' -%}
              {%- unless rec_product.id == product.id or excluded_rec_ids contains rec_pid_str -%}
                <li class="swiper-slide collection-product-card product-recommendations__product quickview{%- if settings.quickview_hover -%}--hover{%- endif -%}"
                    data-rec-slide>
                  {%- render 'product-card', product_card_product: rec_product, section_id: section.id -%}
                </li>
              {%- endunless -%}
            {%- endfor -%}
          </ul>
        {%- elsif product_color_option != nil -%}
          {%- for color_value in product_color_option.values -%}
            {%- assign color_lower = color_value | downcase | strip -%}
            {%- assign color_pool_key = color_value | handleize -%}

            {%- comment -%} Look up mapped collection handle from shop_this_color_map {%- endcomment -%}
            {%- assign mapped_handle = nil -%}
            {%- for map_line in color_map_lines -%}
              {%- assign map_line_clean = map_line | strip -%}
              {%- unless map_line_clean == blank -%}
                {%- assign map_parts = map_line_clean | split: ':' -%}
                {%- if map_parts.size >= 2 -%}
                  {%- assign map_color = map_parts[0] | strip | downcase -%}
                  {%- if map_color == color_lower -%}
                    {%- assign map_path = map_parts[1] | strip -%}
                    {%- assign mapped_handle = map_path | split: '/collections/' | last | strip -%}
                    {%- break -%}
                  {%- endif -%}
                {%- endif -%}
              {%- endunless -%}
            {%- endfor -%}

            {%- assign color_handle = mapped_handle | default: color_pool_key -%}
            {%- assign color_collection = collections[color_handle] -%}
            <ul class="rec-slides-pool" data-color-pool="{{ color_pool_key }}" aria-hidden="true">
              {%- if color_collection != blank -%}
                {%- assign rendered_ids = ',' -%}
                {%- for rec_product in color_collection.products limit: 50 -%}
                  {%- assign pid = rec_product.id | append: ',' -%}
                  {%- assign rec_pid_str = rec_product.id | append: '' -%}
                  {%- unless rec_product.id == product.id or rendered_ids contains pid or excluded_rec_ids contains rec_pid_str -%}
                    <li class="swiper-slide collection-product-card product-recommendations__product quickview{%- if settings.quickview_hover -%}--hover{%- endif -%}"
                        data-rec-slide>
                      {%- render 'product-card', product_card_product: rec_product, section_id: section.id -%}
                    </li>
                    {%- assign rendered_ids = rendered_ids | append: rec_product.id | append: ',' -%}
                  {%- endunless -%}
                {%- endfor -%}
              {%- endif -%}
            </ul>
          {%- endfor -%}
        {%- endif -%}
    </div>
</div>

{% else %}

{% assign page_collection = collections[section.settings.page_collection] %}
{% if page_collection != blank and page_collection.products_count > 0 %}
<div class="product-recommendations section-{{ section.id }}-padding gts" data-page-recommendations>
    <div class="product-recommendations__item product-recommendations__item fullscreen-container gts">
        <div class="product-recommendations__header--container recommendations-header">
            <h2 class="product-recommendations__heading h4 title--section">
                {% if section.settings.page_heading != blank %}
                    {{ section.settings.page_heading | replace: '<p>', '<p class="h4">' }}
                {% else %}
                    {{ section.settings.heading | replace: '<p>', '<p class="h4">' }}
                {% endif %}
            </h2>

            {% if section.settings.enable_swiper %}
            <div class="tabbing-arrows header-arrows">
                <div class="swiper-button-prev peev-tabbing-btn swiper-prev-{{ section.id }}">
                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="18" viewBox="0 0 10 18">
                    <path d="M9 17L1 9L9 1" stroke="currentColor" stroke-width="1.5" fill="none"/>
                </svg>
                </div>
                <div class="swiper-button-next next-tabbing-btn swiper-next-{{ section.id }}">
                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="18" viewBox="0 0 10 18">
                    <path d="M1 1L9 9L1 17" stroke="currentColor" stroke-width="1.5" fill="none"/>
                </svg>
                </div>
            </div>
            {% endif %}
        </div>

        <div class="swiper-container swiper product-recommendations">
            <ul class="swiper-wrapper product-recommendations_list ctm-fabric" role="list">
                {% for page_product in page_collection.products limit: section.settings.products_limit %}
                  {%- assign page_pid_str = page_product.id | append: '' -%}
                  {%- unless excluded_rec_ids contains page_pid_str -%}
                <li class="swiper-slide collection-product-card product-recommendations__product quickview{% if settings.quickview_hover %}--hover{% endif %}">
                    {% render 'product-card',
                        product_card_product: page_product,
                        section_id: section.id
                    %}
                </li>
                  {%- endunless -%}
                {% endfor %}
            </ul>
        </div>
    </div>
</div>
{% endif %}

{% endif %}

{% javascript %}
var _mainColorCache = null;

function initRecommendationSwiper(swiperEl) {
  if (!swiperEl || typeof Swiper === 'undefined') return;
  var section = swiperEl.closest('[data-rec-section], [data-page-recommendations]');
  if (!section) return;
  var nextBtn = section.querySelector('.next-tabbing-btn');
  var prevBtn = section.querySelector('.peev-tabbing-btn');
  if (swiperEl.swiper) swiperEl.swiper.destroy(true, true);
  new Swiper(swiperEl, {
    loop: false,
    spaceBetween: 10,
    navigation: { nextEl: nextBtn, prevEl: prevBtn },
    breakpoints: {
      0: { slidesPerView: 1.3 },
      375: { slidesPerView: 2.3 },
      990: { slidesPerView: 3.3 },
      1280: { slidesPerView: 5.5 },
    },
  });
}

function clearShopifyRecSlides(section) {
  section.querySelectorAll('[data-shopify-rec-slide]').forEach(function(s) { s.remove(); });
}

function fetchShopifyRecommendations(wrapper, swiperEl, section) {
  var url = section.dataset.shopifyRecommendationsUrl;
  if (!url) { section.style.display = 'none'; return; }
  fetch(url)
    .then(function(r) { return r.text(); })
    .then(function(html) {
      var doc = new DOMParser().parseFromString(html, 'text/html');
      var slides = doc.querySelectorAll('[data-rec-slide]');
      if (!slides.length) { section.style.display = 'none'; return; }
      slides.forEach(function(slide) {
        slide.dataset.shopifyRecSlide = '1';
        wrapper.appendChild(slide);
      });
      updateRecommendationHeading(null);
      initRecommendationSwiper(swiperEl);
      if (_mainColorCache) syncRecommendationSwatches(_mainColorCache);
    })
    .catch(function() { section.style.display = 'none'; });
}

function showColorCollection(color) {
  var section = document.querySelector('[data-rec-section]');
  if (!section || !color) return;
  var colorHandle = color.toLowerCase().trim().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  var swiperEl = section.querySelector('.product-recommendations');
  if (!swiperEl) return;
  var wrapper = swiperEl.querySelector('.swiper-wrapper');
  if (!wrapper) return;

  if (swiperEl.swiper) swiperEl.swiper.destroy(true, true);
  clearShopifyRecSlides(section);

  // Return slides currently in wrapper back to their source color pools
  Array.from(wrapper.querySelectorAll('[data-rec-slide]')).forEach(function(slide) {
    var srcPool = slide.dataset.poolHandle
      ? section.querySelector('[data-color-pool="' + slide.dataset.poolHandle + '"]')
      : null;
    if (srcPool) srcPool.appendChild(slide);
    else slide.remove();
  });

  var pool = section.querySelector('[data-color-pool="' + colorHandle + '"]');
  var slides = pool ? Array.from(pool.querySelectorAll('[data-rec-slide]')) : [];

  if (slides.length) {
    slides.forEach(function(slide) {
      slide.dataset.poolHandle = colorHandle;
      wrapper.appendChild(slide);
    });
    updateRecommendationHeading(color);
    initRecommendationSwiper(swiperEl);
    syncRecommendationSwatches(color);
    section.style.display = '';
  } else {
    fetchShopifyRecommendations(wrapper, swiperEl, section);
  }
}

function syncRecommendationSwatches(colorValue) {
  if (!colorValue) return;
  var colorLower = colorValue.toLowerCase().trim();
  document.querySelectorAll('[data-rec-section] .js-color-swatches-wrapper').forEach(function(wrap) {
    var inputs = Array.from(wrap.querySelectorAll('.js-color-swatches input.color-swatch-input'));
    var match = inputs.find(function(i) {
      return (i.dataset.variantValue || i.value || '').toLowerCase().trim() === colorLower;
    }) || inputs.find(function(i) {
      return (i.dataset.variantValue || i.value || '').toLowerCase().trim().startsWith(colorLower);
    });
    if (match && !match.checked) {
      match.checked = true;
      if (typeof updateSwatchSelection === 'function') updateSwatchSelection(match, wrap);
    }
  });
}

function syncCrossSellSwatches(colorValue, doUpdate) {
  var checkedMain = document.querySelector('.main-product-page .color-swatch-input:checked');
  var color = colorValue || (checkedMain ? (checkedMain.dataset.variantValue || checkedMain.value) : null);
  if (!color) return;
  var colorLower = color.toLowerCase().trim();
  document.querySelectorAll('[data-cross-sell-list] .js-color-swatches-wrapper, .cross_swiper .js-color-swatches-wrapper').forEach(function(wrap) {
    var inputs = wrap.querySelectorAll('.js-color-swatches input.color-swatch-input');
    var match = Array.from(inputs).find(function(i) {
      return (i.dataset.variantValue || i.value || '').toLowerCase().trim() === colorLower;
    });
    if (match && !match.checked) {
      match.checked = true;
      if (doUpdate && typeof updateSwatchSelection === 'function') updateSwatchSelection(match, wrap);
    }
  });
}

function initMobileCrossSellSwiper() {
  if (typeof Swiper === 'undefined') return;
  var el = document.querySelector('.cross_swiper.swiper');
  if (!el || el.swiper) return;
  window.crossSwiper = new Swiper(el, {
    slidesPerView: 'auto',
    spaceBetween: 16,
    scrollbar: { el: '.swiper-scrollbar', draggable: true },
  });
}

function updateRecommendationHeading(color) {
  var section = document.querySelector('[data-rec-section]');
  if (!section) return;
  var h2 = section.querySelector('[data-color-heading]');
  if (!h2) return;
  if (color) {
    h2.textContent = (h2.dataset.headingPrefix || 'More in') + ' ' + color;
  } else {
    h2.textContent = h2.dataset.defaultHeading || (h2.dataset.headingPrefix || 'You May Also Like');
  }
}

document.addEventListener('DOMContentLoaded', function() {
  // Page context
  var pageSwiperEl = document.querySelector('[data-page-recommendations] .product-recommendations');
  if (pageSwiperEl) { initRecommendationSwiper(pageSwiperEl); return; }

  var sec = document.querySelector('[data-rec-section]');
  if (!sec) return;

  _mainColorCache = sec.dataset.defaultColor || '';
  if (!_mainColorCache) {
    var el = document.querySelector('.main-product-page .color-swatch-input:checked');
    if (el) _mainColorCache = el.dataset.variantValue || el.value;
  }

  if (_mainColorCache) {
    showColorCollection(_mainColorCache);
  } else {
    var swiperEl = sec.querySelector('.product-recommendations');
    var wrapper = swiperEl ? swiperEl.querySelector('.swiper-wrapper') : null;
    if (swiperEl && wrapper) fetchShopifyRecommendations(wrapper, swiperEl, sec);
  }

  var mainProduct = document.querySelector('.main-product-page');
  if (mainProduct) {
    mainProduct.addEventListener('change', function(e) {
      if (e.target.matches('.color-swatch-input') && e.target.checked) {
        _mainColorCache = e.target.dataset.variantValue || e.target.value;
        showColorCollection(_mainColorCache);
        syncRecommendationSwatches(_mainColorCache);
        syncCrossSellSwatches(_mainColorCache, true);
      }
    });
  }
});

window.addEventListener('load', function() {
  if (typeof checkSwatches === 'function') checkSwatches();
  if (typeof initSwatchSwipers === 'function') initSwatchSwipers();
  syncCrossSellSwatches(null, false);
  initMobileCrossSellSwiper();
  if (_mainColorCache) syncRecommendationSwatches(_mainColorCache);
});
{% endjavascript %}

<style>
    .rec-slides-pool {
      display: none !important;
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .swiper-button-prev.peev-tabbing-btn,
    .swiper-button-next.next-tabbing-btn{
            top: 38%;
    }
    .recommendations-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}

.recommendations-header .header-arrows {
  display: flex;
  gap: 12px;
}

.recommendations-header .swiper-button-prev,
.recommendations-header .swiper-button-next {
  position: static; /* IMPORTANT */
  margin: 0;
  transform: none;
}

.section-{{ section.id }}-padding {
    margin-top: {{ section.settings.margin_top }};
    margin-bottom: {{ section.settings.margin_bottom }};
}

@media(min-width:769px) {
  .section-{{ section.id }}-padding {
      padding: 0 80px !important;
  }
}

    </style>
{% schema %}
{
    "name": "t:sections.product-recommendations.name",
    "tag": "section",
    "class": "spaced-section section-product-recommendations",
    "settings": [
        {
            "type": "richtext",
            "id": "heading",
            "default": "<p>You May Also Like</p>",
            "label": "t:sections.product-recommendations.settings.heading.label"
        },
        {
            "type": "text",
            "id": "color_heading_prefix",
            "label": "Color-based heading prefix",
            "default": "More in",
            "info": "Heading becomes '[prefix] [Color]' based on selected swatch. E.g. 'More in Red'."
        },
        {
            "type": "text",
            "id": "link",
            "default": "Shop All",
            "label": "t:sections.product-recommendations.settings.link.label"
        },
        {
            "type": "url",
            "id": "button_link",
            "label": "t:sections.product-carousel.settings.button_link.label"
        },
        {
            "type": "checkbox",
            "id": "enable_swiper",
            "label": "Enable Swiper for Product Recommendations",
            "default": false
        },
        {
            "type": "header",
            "content": "t:sections.product-recommendations.settings.header__2.content"
        },
        {
            "type": "select",
            "id": "image_ratio",
            "options": [
                {
                    "value": "landscape",
                    "label": "t:sections.product-recommendations.settings.image_ratio.options__1.label"
                },
                {
                    "value": "portrait",
                    "label": "t:sections.product-recommendations.settings.image_ratio.options__2.label"
                },
                {
                    "value": "square",
                    "label": "t:sections.product-recommendations.settings.image_ratio.options__3.label"
                }
            ],
            "default": "portrait",
            "label": "t:sections.product-recommendations.settings.image_ratio.label"
        },
        {
            "type": "select",
            "id": "image_fit",
            "label": "t:sections.featured-products.settings.image_fit.label",
            "options": [
                {
                    "value": "contain",
                    "label": "t:sections.featured-products.settings.image_fit.options__1.label"
                },
                {
                    "value": "cover",
                    "label": "t:sections.featured-products.settings.image_fit.options__2.label"
                }
            ],
            "default": "cover"
        },
        {
            "type": "checkbox",
            "id": "show_secondary_image",
            "default": false,
            "label": "t:sections.product-recommendations.settings.show_secondary_image.label"
        },
        {
            "type": "checkbox",
            "id": "show_vendor",
            "default": false,
            "label": "t:sections.product-recommendations.settings.show_vendor.label"
        },
        {
            "type": "checkbox",
            "id": "show_desc",
            "default": false,
            "label": "t:sections.product-recommendations.settings.show_desc.label"
        },
        {
      "type": "checkbox",
      "id": "show_sku",
      "default": false,
      "label": "t:sections.all.product_card.show_sku.label"
    },
        {
            "type": "checkbox",
            "id": "quickview_show",
            "default": false,
            "label": "t:sections.all.product_card.quickview_show.label"
        },
        {
            "type": "checkbox",
            "id": "show_link",
            "default": true,
            "label": "t:sections.all.product_card.show_link.label"
        },
        {
            "type": "header",
            "content": "t:sections.all.section-margin.header.content"
        },
        {
            "type": "range",
            "id": "margin_top",
            "min": 0,
            "max": 200,
            "step": 10,
            "default": 100,
            "unit": "px",
            "label": "t:sections.all.section-margin.margin_top.label"
        },
        {
            "type": "range",
            "id": "margin_bottom",
            "min": 0,
            "max": 200,
            "step": 10,
            "default": 100,
            "unit": "px",
            "label": "t:sections.all.section-margin.margin_bottom.label"
        },
        {   
            
            "type": "header",
            "content": "Page Settings"
        },
        {
            "type": "text",
            "id": "page_heading",
            "label": "Heading (pages)",
            "default": "Featured Products"
        },
        {
            "type": "collection",
            "id": "page_collection",
            "label": "Collection (pages)"
        },
        {
            "type": "range",
            "id": "products_limit",
            "min": 5,
            "max": 50,
            "step": 5,
            "default": 10,
            "label": "t:sections.product-recommendations.settings.products_limit.label"
        }
    ],
    "presets": [
        {
            "name": "Product Recommendations"
        }
    ]
}
{% endschema %}
