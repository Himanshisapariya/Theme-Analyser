<style>
 .template-collection h1 {
    font-weight: {{ section.settings.heading_font_weight }} !important;
    font-size: {{ section.settings.heading_font_size_mobile }}px;
}

.ctm-collection-description p {
  font-family: 'Poppins';
  margin: 0;
  font-size: {{ section.settings.description_font_size_mobile }}px;
  line-height: {{ section.settings.description_line_height }};
}

.ctm-gender-filter-btn.active {
  color: #000;
  border-bottom: 2px solid black;
}

@media (max-width: 575px) {
  .ctm-gender-filter-btn {
    font-size: 14px !important;
  }
  .ctm-gender-filter-buttons {
    gap: 10px;
  }
  .template-collection .card-information__wrapper .card__title .card_product_title{
    font-size: {{ section.settings.product_title_font_mobile }}px !important;
  }
}

.collection-product-card {
	transition: opacity 0.3s ease;
}

.collection-product-card.hidden {
	display: none;
}
@media only screen and (min-width: 750px) {
	.template-collection h1 {
		font-size: {{ section.settings.heading_font_size_desktop }}px;
	}
	.ctm-collection-description p {
		font-family: 'Poppins';
		margin: 0;
  		font-size: {{ section.settings.description_font_size_desktop }}px;
	}
}

@media(min-width: 576px){
.template-collection .card-information__wrapper .card__title .card_product_title{
	font-size: {{ section.settings.product_title_font_desktop }}px !important;
}
}

@media only screen and (min-width: 768px) and (max-width: 1650px) {
	.template-collection h1 {
		font-size: calc({{ section.settings.heading_font_size_desktop }}px - 16px);
	}
	.ctm-collection-description p {
		font-size: calc({{ section.settings.description_font_size_desktop }}px - 2px);
	}
	.template-collection .card-information .card-information__wrapper .card__title h2.card_product_title,
	.card-title_info .price.mini-price .price-item{
	font-size: 12px !important;
}
}

</style>

{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-loading-overlay.css' | asset_url | stylesheet_tag }}
{%- if settings.pagination_type == 'load_more'
	or settings.pagination_type == 'infinite_scroll'
-%}
	<script src="{{ 'load-more.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
	<script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>
	<script src="{{ 'facets-menu.js' | asset_url }}" defer="defer"></script>
	{{ 'component-facets.css' | asset_url | stylesheet_tag }}
{%- endif -%}

<link
	rel="preload"
	href="{{ 'component-card.css' | asset_url }}"
	as="style"
	onload="this.onload=null;this.rel='stylesheet'"
>
<link
	rel="preload"
	href="{{ 'component-card-extended.css' | asset_url }}"
	as="style"
	onload="this.onload=null;this.rel='stylesheet'"
>
<link
	rel="preload"
	href="{{ 'component-price.css' | asset_url }}"
	as="style"
	onload="this.onload=null;this.rel='stylesheet'"
>
<link
	rel="preload"
	href="{{ 'component-badge.css' | asset_url }}"
	as="style"
	onload="this.onload=null;this.rel='stylesheet'"
>
<link
	rel="preload"
	href="{{ 'component-rte.css' | asset_url }}"
	as="style"
	onload="this.onload=null;this.rel='stylesheet'"
>

<noscript>{{ 'component-card.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-price.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-badge.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-rte.css' | asset_url | stylesheet_tag }}</noscript>

<div class="ctm-collection-filter-wrapper">
	{% render 'breadcrumbs' %}
	<div class="fullscreen-container fullscreen-container-with-pt0 ctm-collection-heading-above">
		<div class="ctm-collection-heading">
			<h1 class="title--page">
						{{ collection.title }}
			<span>({{ collection.products.count }})</span>
			</h1>
		</div>
	</div>
	</div>
<div class="fullscreen-container fullscreen-container-with-pt0 filter-one-div-start">
	{% if collection.description %}
		<div class="ctm-collection-description">
			{{ collection.description }}
		</div>
	{% endif %}
	<div class="title-join-filters {{ section.settings.collection_product_title_invisible }}">
		{%- if collection.all_products_count > 0 -%}
			{%- if section.settings.enable_filtering
				or section.settings.enable_sorting
			-%}
				<div class="facets facets__main">
					{% render 'facets',
						results: collection,
						enable_filtering: section.settings.enable_filtering,
						enable_sorting: section.settings.enable_sorting,
						image_filter_ratio: section.settings.image_filter_ratio,
						image_filter_fit: section.settings.image_filter_fit,
						image_filter_columns: section.settings.image_filter_columns
					%}
				</div>
			{%- endif -%}
		{%- endif -%}
		</div>
	{% if collection.handle == 'sale' %}
		<p class="finalsale_text-ctm">All final-sale items are non-returnable and non-exchangeable once purchased.</p>
	{% endif %}
</div>
 
{% render 'collection-tab-ctm' %}


<div id="ProductGridContainer">
	{%- paginate collection.products by section.settings.products_per_page -%}
		{%- if collection.products.size == 0 -%}
			<div
				class="collection collection-product collection--empty fullscreen-container"
				id="product-grid"
				data-id="{{ section.id }}"
			>
				<div class="loading-overlay">
					<div class="loading-overlay__spinner">
						<svg
							aria-hidden="true"
							focusable="false"
							role="presentation"
							class="spinner"
							viewBox="0 0 66 66"
							xmlns="http://www.w3.org/2000/svg"
						>
							<circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
						</svg>
					</div>
				</div>

				<div class="title-wrapper center title-wrapper-empty">
					<h2 class="title title--primary">
						{% if collection.all_products_count == 0 %}
							{{ 'sections.collection_template.empty' | t -}}
							<br>
							{{
								'sections.collection_template.use_fewer_filters_html'
								| t: link: routes.collections_url, class: 'underlined-link link'
							}}
						{% else %}
							{{ 'sections.collection_template.empty_results' | t -}}
							<br>
							{{
								'sections.collection_template.results_use_fewer_filters_html'
								| t: link: collection.url, class: 'underlined-link link'
							}}
						{% endif %}
					</h2>
				</div>
			</div>
		{%- else -%}
			<div class="collection collection-product fullscreen-container">
				<div class="loading-overlay">
					<div class="loading-overlay__spinner">
						<svg
							aria-hidden="true"
							focusable="false"
							role="presentation"
							class="spinner"
							viewBox="0 0 66 66"
							xmlns="http://www.w3.org/2000/svg"
						>
							<circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
						</svg>
					</div>
				</div>
				{% liquid
					assign card_index = 0

					if section.settings.show_large_card == true
						if paginate.current_page == 1 or settings.pagination_type == 'pagination'
							assign card_index = 7
						endif

						if paginate.page_size == 7 or paginate.page_size == 11 or paginate.page_size == 15 or paginate.page_size == 19
							if settings.pagination_type == 'load_more' or settings.pagination_type == 'infinite_scroll'
								assign card_index = 7
							endif
						endif
					endif
				%}

				<ul
					id="product-grid"
					data-id="{{ section.id }}" 
					class="collection-product-list collection-product-list--{{ section.settings.columns_mobile }}-mobile load-more-grid"
				>
				{% if section.settings.product_lists %}
					{% assign product_list_collection = section.settings.product_lists %}
				{% else %}
					{% assign product_list_collection = collection.products %}
				{% endif %}
					{%- for product in product_list_collection -%}
						<li
                            class="
                                collection-product-card quickview{%- if settings.quickview_hover -%}--hover{% endif %}
                                {%- if paginate.page_size > 6 -%}
                                {%- if card_index != 0 and forloop.index == card_index -%}
                                    collection-product-card--extended collection-product-card--{{- section.settings.image_ratio -}}
                                {%- endif -%}
                                {%- endif -%}
                            "
                            data-product-tags="{{ product.tags | join: ',' | escape }}"
                            >
							{% render 'product-card',
								product_card_product: product,
								media_size: section.settings.image_ratio,
								media_fit: section.settings.image_fit,
								show_secondary_image: section.settings.show_secondary_image,
								show_vendor: section.settings.show_vendor,
								show_desc: section.settings.show_desc,
								show_sku: section.settings.show_sku,
								quickview_show: section.settings.quickview_show,
								section_id: section.id
							%}
						</li>
					{%- endfor -%}
					{% render 'infocard_collection',
						infocard_heading_font_desktop: section.settings.infocard_heading_font_desktop,
						infocard_heading_font_mobile: section.settings.infocard_heading_font_mobile,
						infocard_subheading_font_desktop: section.settings.infocard_subheading_font_desktop,
						infocard_subheading_font_mobile: section.settings.infocard_subheading_font_mobile, 
						infocard_subheading_margin_top: section.settings.infocard_subheading_margin_top,
						infocard_subheading_margin_bottom: section.settings.infocard_subheading_margin_bottom,
						infocard_subheading_color: section.settings.infocard_subheading_color
					%}
				</ul>

				{%- if paginate.pages > 1 -%}
					{%- if settings.pagination_type == 'load_more' -%}
						{% render 'load-more',
							next_url: paginate.next.url,
							count_pages: paginate.pages,
							current_page: paginate.current_page
						%}
						<div class="no-js">
							{% render 'pagination', paginate: paginate %}
						</div>
					{%- elsif settings.pagination_type == 'infinite_scroll' -%}
						{% render 'infinite-scroll',
							next_url: paginate.next.url,
							count_pages: paginate.pages,
							current_page: paginate.current_page
						%}
						<div class="no-js">
							{% render 'pagination', paginate: paginate %}
						</div>
					{% else %}
						{% render 'pagination', paginate: paginate %}
					{%- endif -%}
				{%- endif -%}
			</div>
		{%- endif -%}
	{%- endpaginate -%}
</div>

{% schema %}
{
	"name": "t:sections.main-collection-product-grid.name",
	"tag": "section",
	"class": "collection-grid-section",
	"settings": [
		{
			"type": "checkbox",
			"label": "Show Gender Filter",
			"id": "show_gender_filter"
        },
		{
			"type": "text",
			"id": "collection_product_title_invisible",
			"label": "To make title hide",
		},
		{
			"type": "product_list",
			"id": "product_lists",
			"label": "Select the products",
		},
		{
			"type": "range",
			"id": "products_per_page",
			"min": 4,
			"max": 22,
			"step": 1,
			"default": 10,
			"label": "t:sections.main-collection-product-grid.settings.products_per_page.label"
		},
		{
			"type": "select",
			"id": "columns_mobile",
			"default": "1",
			"label": "t:sections.main-collection-product-grid.settings.columns_mobile.label",
			"options": [
				{
					"value": "1",
					"label": "t:sections.main-collection-product-grid.settings.columns_mobile.options__1.label"
				},
				{
					"value": "2",
					"label": "t:sections.main-collection-product-grid.settings.columns_mobile.options__2.label"
				}
			]
		},
		{
			"type": "header",
			"content": "t:sections.main-collection-product-grid.settings.header__3.content"
		},
		{
			"type": "select",
			"id": "image_ratio",
			"options": [
				{
					"value": "landscape",
					"label": "t:sections.main-collection-product-grid.settings.image_ratio.options__1.label"
				},
				{
					"value": "portrait",
					"label": "t:sections.main-collection-product-grid.settings.image_ratio.options__2.label"
				},
				{
					"value": "square",
					"label": "t:sections.main-collection-product-grid.settings.image_ratio.options__3.label"
				}
			],
			"default": "portrait",
			"label": "t:sections.main-collection-product-grid.settings.image_ratio.label"
		},
		{
			"type": "select",
			"id": "image_fit",
			"label": "t:sections.featured-products.settings.image_fit.label",
			"options": [
				{
					"value": "contain",
					"label": "t:sections.featured-products.settings.image_fit.options__1.label"
				},
				{
					"value": "cover",
					"label": "t:sections.featured-products.settings.image_fit.options__2.label"
				}
			],
			"default": "cover"
		},
		{
			"type": "checkbox",
			"id": "show_secondary_image",
			"default": false,
			"label": "t:sections.main-collection-product-grid.settings.show_secondary_image.label"
		},
		{
			"type": "checkbox",
			"id": "show_vendor",
			"default": false,
			"label": "t:sections.main-collection-product-grid.settings.show_vendor.label"
		},
		{
			"type": "checkbox",
			"id": "show_desc",
			"default": false,
			"label": "t:sections.main-collection-product-grid.settings.show_desc.label",
			"info": "t:sections.main-collection-product-grid.settings.show_desc.info"
		},
		{
			"type": "checkbox",
			"id": "show_sku",
			"default": false,
			"label": "t:sections.all.product_card.show_sku.label"
		},
		{
			"type": "checkbox",
			"id": "quickview_show",
			"default": true,
			"label": "t:sections.all.product_card.quickview_show.label"
		},

		{
			"type": "header",
			"content": "t:sections.main-collection-product-grid.settings.header__1.content"
		},
		{
			"type": "checkbox",
			"id": "enable_filtering",
			"default": true,
			"label": "t:sections.main-collection-product-grid.settings.enable_filtering.label",
			"info": "t:sections.main-collection-product-grid.settings.enable_filtering.info"
		},
		{
			"type": "checkbox",
			"id": "enable_sorting",
			"default": true,
			"label": "t:sections.main-collection-product-grid.settings.enable_sorting.label"
		},
		{
			"type": "header",
			"content": "Image Settings"
		},
    {
      "type": "select",
      "id": "image_filter_ratio",
