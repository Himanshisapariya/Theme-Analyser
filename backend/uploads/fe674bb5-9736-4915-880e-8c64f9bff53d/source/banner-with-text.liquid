    },
    {
  "type": "range",
  "id": "heading_font_size_tablet",
  "label": "Heading Size (Tablet)",
  "min": 20,
  "max": 100,
  "step": 2,
  "default": 40,
  "unit": "px"
},
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "label": "Heading Size (Mobile)",
      "min": 18,
      "max": 80,
      "step": 2,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "subheading_font_size_desktop",
      "label": "Subheading Size (Desktop)",
      "min": 12,
      "max": 40,
      "step": 1,
      "default": 18,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "subheading_font_size_mobile",
      "label": "Subheading Size (Mobile)",
      "min": 12,
      "max": 30,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "caption_font_size_desktop",
      "label": "Caption Size (Desktop)",
      "min": 10,
      "max": 24,
