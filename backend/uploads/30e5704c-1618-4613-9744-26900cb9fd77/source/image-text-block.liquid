<div class="four-image-blocks">
  <div class="block-grid fullscreen-container">
    {% for block in section.blocks %}
      {% assign overlay_rgba = block.settings.overlay_color | color_to_rgb %}
     <a href="{{ block.settings.link }}" class="block-item" style="background-image: url({{ block.settings.image | image_url: width: 800 }});">
  <div
    class="block-overlay"
    style="
      {% if block.settings.show_overlay %}
        background-color: rgba(0, 0, 0, {{ block.settings.overlay_opacity | divided_by: 100.0 }});
      {% else %}
        background-color: transparent;
      {% endif %}
    "
  >
    <span class="block-title">{{ block.settings.title }}</span>
  </div>
</a>
    {% endfor %}
  </div>
</div>

<style>

.four-image-blocks .block-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 20px;
    margin: 0 auto;
    padding-bottom: 25px;
}
.four-image-blocks .block-overlay {
  width: 100%;
  padding: 12px 0;
  text-align: center;
  position: relative;
  z-index: 1;
  transition: background-color 0.3s ease;
}
  .four-image-blocks .block-item {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    height: 220px;
    text-decoration: none;
    background-size: cover;
    background-position: center;
    position: relative;
    transition: transform 0.3s;
    border-radius: 6px;
    overflow: hidden;
  }


  .four-image-blocks .block-overlay {
    width: 100%;
    padding: 10px 0;
    text-align: center;
    transition: background 0.3s ease;
  }

  .four-image-blocks .block-title {
    color: #fff;
    font-size: 18px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .four-image-blocks .block-item {
      height: 160px;
    }

    .four-image-blocks .block-title {
      font-size: 12px;
    }
  }

  @media (max-width: 480px) {
    .four-image-blocks .block-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Image Blocks",
  "max_blocks": 4,
  "settings": [],
  "blocks": [
    {
      "type": "image_block",
      "name": "Image Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Block Title",
          "default": "Block Title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Block Link"
        },
        {
          "type": "checkbox",
          "id": "show_overlay",
          "label": "Show Image Overlay",
          "default": true
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "min": 0,
          "max": 100,
          "step": 5,
          "unit": "%",
          "label": "Overlay Opacity",
          "default": 30
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image Blocks"
    }
  ]
}
{% endschema %}
