<link
  rel="stylesheet"
  href="{{ 'main-lookbook.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>

<noscript>
  {{- 'main-lookbook.css' | asset_url | stylesheet_tag -}}
</noscript>

{% style %}
  {% render 'spaced-section' %}
  #shopify-section-{{ section.id }} {
    --per-row : {{ section.settings.per_row }}
  }
{% endstyle %}

{% liquid
  if section.settings.per_row == 1
    assign collection_class = 'collection-grid-one'
  else
    assign collection_class = ''
  endif
%}

<div class="collection-list {{ collection_class }} {{ section.settings.spring_news_class }} section-{{ section.id }}">
  <div class="fullscreen-container newsrooms">
    <div class="page-header">
      <div class="page-header__inner">
        <h3 class="main-page-title title--page">
          {{ section.settings.title }}
        </h3>
        {% if section.settings.subheading != blank %}
        <h6>{{ section.settings.subheading }}</h6>
        {% endif %}
      </div>
    </div>
    <div class="section-{{ section.id }}{% if section.settings.enable_slider == true %} lookbook-swiper swiper {% endif %}" role="region" aria-label="carousel">
      {%- comment -%}fix - #556: screen-reader instructions as first child{%- endcomment -%}
      {% if section.settings.enable_slider == true %}<span class="visually-hidden">Image carousel. Use the Previous and Next buttons to navigate between slides.</span>{% endif %}
      {%- comment -%}fix - #558: Nav buttons before slides for logical focus order{%- endcomment -%}
      {% if section.settings.enable_slider == true %}
        <div class="slider-controls-box">
          {% if section.blocks.size > 1 %}
            <div class="tabbing-aerrows">
              <div class="swiper-button-prev peev-tabbing-btn swiper-prev-template--19266566946947__collection_tabbing_mYR76T swiper-button-disabled">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="10"
                  height="18"
                  viewBox="0 0 10 18"
                  fill="none"
                  class="icon icon-caret-left"
                  role="img"
                  aria-labelledby="prev-arrow-title-{{ section.id }}"
                >
                  <title id="prev-arrow-title-{{ section.id }}">Previous slide arrow</title>
                  <path d="M9 17L0.999999 9L9 1" stroke="currentcolor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              </div>
              <div class="swiper-button-next next-tabbing-btn swiper-next-template--19266566946947__collection_tabbing_mYR76T">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="10"
                  height="18"
                  viewBox="0 0 10 18"
                  fill="none"
                  class="icon icon-caret-right"
                  role="img"
                  aria-labelledby="next-arrow-title-{{ section.id }}"
                >
                  <title id="next-arrow-title-{{ section.id }}">Next slide arrow</title>
                  <path d="M1 1L9 9L1 17" stroke="currentcolor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              </div>
            </div>
          {% endif %}
        </div>
      {% endif %}
      <ul
        class="{% if section.settings.enable_slider == true %} swiper-wrapper {% else %} collection-product-list collections-grid {% endif %} {{ section.settings.extra_class }}"
        role="{% if section.settings.enable_slider == true %}presentation{% else %}list{% endif %}"
      >
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'about_blocks' -%}
              {% liquid
                assign condition = forloop.index | modulo: section.settings.per_row
                if condition == 0
                  assign block_class = 'hide_border'
                else
                  assign block_class = ''
                endif
              %}
              <li
                class="{% if section.settings.enable_slider == true %} swiper-slide{% endif %} collections-grid__card color-background-2 color-border-1 {{ block_class }} {{ collection_class }} {% if section.settings.image_ratio == 'portrait' or section.settings.image_ratio == 'portrait' %} collections-grid__card--portrait {% endif %}"
                {{ block.shopify_attributes }}
              >
                {{ 'component-collection-card.css' | asset_url | stylesheet_tag }}

                {% liquid
                  case section.settings.image_ratio
                    when 'landscape'
                      assign section_size = '56.25%'
                    when 'portrait'
                      assign section_size = '134.54%'
                    when 'square'
                      assign section_size = '100%'
                    else
                      assign section_size = '100%'
                  endcase
                %}

                {% style %}
                  .collection-grid__image-block::before {
                    padding-bottom: {{ section_size }};
                  }
                {% endstyle %}
                <div class="collection-grid__item">
                   <a
                    class="collection-grid__link"
                    {% if block.settings.heading != blank %}
                      href="{{ block.settings.heading_link }}"
                    {% endif %}
                  >
                  <div class="collection-grid__image-wrapper">
                    <div class="collection-grid__image-block">
                      <div class="collection-grid__image-item">
                        {% if block.settings.block_image != blank %}
                          {% liquid
                            if block.settings.block_image != blank
                              assign blockImg = block.settings.block_image
                            endif
                            assign image_height = blockImg.width | divided_by: blockImg.aspect_ratio
                            assign image_width = blockImg.width
                            assign sizes = '100vw'
                          %}
                          {% assign image_style = 'object-fit: cover;' %}
                          {{
                            blockImg
                            | image_url: width: 3840
                            | image_tag:
                              loading: 'lazy',
                              width: image_width,
                              height: image_height,
                              alt: block.settings.alt_text,
                              sizes: sizes,
                              widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
                              style: image_style
                          }}
                        {%- else -%}
                          {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                        {% endif %}
                        {%- if block.settings.overlay_enable -%}
                          <span
                            class="collection-card__overlay"
                            style="background-color: rgba(var(--color-overlay), {{ block.settings.overlay_opacity }}%);"
                          >
                          </span>
                        {% endif %}
                      </div>
                    </div>
                  </div>
                  </a>
                  <div class="newsroom-card-title">
                    {% if block.settings.text != blank %}
                      <p class="ctm-lookbook-subheading">{{ block.settings.text }}</p>
                    {% endif %}
                    {%- if block.settings.heading != blank -%}
                      <p
                        class="
                          collection-grid__title {% if section.settings.per_row >= 4 %}h5 collection-grid__small-pad{% endif %}{% if block.settings.color_scheme == 'dark' %} theme-dark
                          {% elsif block.settings.color_scheme == 'light' %} theme-light {% endif %}
                        "
                      >
                        {{ block.settings.heading }}
                      </p>
                    {%- endif -%}
                  </div>
                </div>
              </li>
          {% endcase %}
        {%- endfor -%}
      </ul>
    </div>
    {%- if paginate.pages > 1 -%}
      {% render 'pagination', paginate: paginate %}
    {%- endif -%}
  </div>
</div>

{% if section.settings.enable_slider == true %}
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const sectionId = '{{ section.id }}';
      const desktopSlides = {{ section.settings.desktop_slide | default: 4 }};
      const swiperEl = document.querySelector(`#shopify-section-${sectionId} .lookbook-swiper`);
      
      if (swiperEl) {
        // fix - #557: set aria-hidden + tabindex=-1 on inactive slides
        function updateSlideA11y(swiper) {
          swiper.slides.forEach(function(slide) {
            const visible = slide.classList.contains('swiper-slide-visible');
            slide.setAttribute('aria-hidden', visible ? 'false' : 'true');
            slide.querySelectorAll('a,button,input,select,textarea,[tabindex]').forEach(function(el) {
              if (visible) { el.removeAttribute('tabindex'); }
              else { el.setAttribute('tabindex', '-1'); }
            });
          });
        }

        const swiper = new Swiper(swiperEl, {
          slidesPerView: 1.2,
          spaceBetween: 5,
          watchSlidesProgress: true,
          navigation: {
            nextEl: swiperEl.querySelector('.swiper-button-next'),
            prevEl: swiperEl.querySelector('.swiper-button-prev'),
          },
          breakpoints: {
            500: {
              slidesPerView: 2.2,
              spaceBetween: 10,
            },
            1024: {
              slidesPerView: 3.5,
              spaceBetween: 10,
            },
            1200: {
              slidesPerView: desktopSlides,
              spaceBetween: 10,
            },
          },
          on: {
            init: function() { updateSlideA11y(this); },
            slideChange: function() { updateSlideA11y(this); },
            resize: function() { updateSlideA11y(this); },
          },
        });
      }
    });
  </script>
{% endif %}

{% schema %}
{
  "name": "t:sections.main-lookbook.name",
  "tag": "section",
  "class": "section-lookbook",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "richtext",
      "id": "title",
      "label": "t:sections.all.heading.label",
      "default": "<p>Heading</p>"
    },
    {
      "type": "text",
      "id": "extra_class",
      "label": "Extra Class"
    },
    {
      "type": "checkbox",
      "id": "enable_slider",
      "label": "Enable Slider",
      "default": false
    },
    {
      "type": "range",
      "label": "Desktop Slide per view",
      "id": "desktop_slide",
      "info": "0.5 Steps Used for slide.",
      "default": 4,
      "min": 3,
      "max": 6,
      "step": 0.5
    },
    {
      "type": "html",
      "id": "subheading",
      "label": "Sub Heading"
    },
    {
      "type": "range",
      "id": "per_row",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 2,
      "label": "t:sections.all.column_per_row.label",
      "info": "t:sections.all.column_per_row.info"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "landscape",
          "label": "t:sections.all.image.ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.all.image.ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.all.image.ratio.options__3.label"
        }
      ],
      "default": "square",
      "label": "t:sections.all.image.ratio.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 20,
      "unit": "px",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 20,
      "unit": "px",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    },
    {
      "type": "text",
      "id": "spring_news_class",
      "label": "Spring Newsroom Class"
    }
  ],
  "blocks": [
    {
      "type": "about_blocks",
      "name": "t:sections.main-lookbook.blocks.categories.name",
      "settings": [
        {
          "type": "select",
          "id": "color_scheme",
          "options": [
            {
              "value": "dark",
              "label": "t:sections.split_screen_slideshow.blocks.settings.color_scheme.options__2.label"
            },
            {
              "value": "light",
              "label": "t:sections.split_screen_slideshow.blocks.settings.color_scheme.options__1.label"
            }
          ],
          "default": "light",
          "label": "t:sections.split_screen_slideshow.blocks.settings.color_scheme.label"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "html",
          "id": "heading",
          "default": "<p>Heading</p>",
          "label": "t:sections.all.text.label"
        },
        {
          "type": "url",
          "id": "heading_link",
          "label": "t:sections.main-lookbook.blocks.heading_link.label"
        },
        {
          "type": "image_picker",
          "id": "block_image",
          "label": "t:sections.all.image.label"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt Text",
          "info": "Describe the image for accessibility"
        },
        {
          "type": "header",
          "content": "t:sections.all.overlay.header.content"
        },
        {
          "type": "checkbox",
          "id": "overlay_enable",
          "default": true,
          "label": "t:sections.all.overlay.overlay_enable.label"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "min": 10,
          "max": 90,
          "default": 10,
          "unit": "%",
          "label": "t:sections.all.overlay.overlay_opacity.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.main-lookbook.name",
      "blocks": [
        {
          "type": "about_blocks"
        },
        {
          "type": "about_blocks"
        }
      ]
    }
  ]
}
{% endschema %}