<style>
    #shopify-section-{{ section.id }} {
      padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
      background-color: {{ section.settings.background_color }};
    }

    .ctm-link-item {
      list-style: none;
    }

    .ctm-hover-links-container {
      margin: 0 auto;
      padding: 0 20px;
    }

    .ctm-hover-links-heading {
      font-size: {{ section.settings.heading_font_size }}px;
      margin-bottom: 40px;
      text-align: {{ section.settings.heading_alignment }};
      color: {{ section.settings.heading_color }};
      font-weight: 400;
    }

    .ctm-hover-links-wrapper {
      display: flex;
      gap: 60px;
      align-items: center;
    }

    .ctm-hover-links-content {
      justify-content: flex-start;
      display: flex;
      gap: 60px;
      align-items: {{ section.settings.content_alignment }};
      width: 100%;
      margin: 0 auto;
    }

    .ctm-links-column {
      flex: 0 0 calc(50% - 30px);
      width: calc(50% - 30px);
    }

    .ctm-links-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .ctm-image-column {
      flex: 0 0 calc(50% - 30px);
      {% comment %} width: calc(50% - 30px); {% endcomment %}
      position: relative;
      aspect-ratio: 0.80 / 1;
      overflow: hidden;
      border-radius: {{ section.settings.image_border_radius }}px;
    }

    .ctm-link-item a {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      font-size: {{ section.settings.link_font_size }}px;
      color: {{ section.settings.link_color }};
      text-decoration: none;
      position: relative;
      transition: color 0.3s ease;
      font-weight: 700;
      padding: 5px 0;
      line-height: 1.2;
    }

    .ctm-link-arrow {
      display: none;
      width: 0;
      opacity: 0;
      transition: all 0.3s ease;
      transform: translateX(-10px);
    }

    .ctm-link-item a:hover .ctm-link-arrow,
    .ctm-link-item a.active .ctm-link-arrow {
      width: 20px;
      opacity: 1;
      transform: translateX(0);
    }

    .ctm-link-arrow svg {
      width: 20px;
      height: 20px;
      stroke: {{ section.settings.arrow_color }};
      stroke-width: 4;
    }

    .ctm-link-item a::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: -20px;
      width: 0;
      height: 3px;
      background-color: {{ section.settings.underline_color }};
      transition: width 250ms ease;
    }

    .ctm-link-item a:hover::after,
    .ctm-link-item a.active::after {
      width: calc(100% + 18px);
    }

    .ctm-image-slide-wrapper {
      position: relative;
      width: 100%;
      height: 100%;
      max-width: {{ section.settings.image_width }}px;
    }

    .ctm-image-slide {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      opacity: 0;
      visibility: hidden;
      transition: opacity {{ section.settings.animation_speed }}ms cubic-bezier(0.19, 1, 0.22, 1);
    }

    .ctm-image-slide.active {
      opacity: 1;
      visibility: visible;
      z-index: 1;
    }

    .ctm-image-slide img {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: {{ section.settings.image_fit }};
      object-position: {{ section.settings.image_position }};
      border-radius: {{ section.settings.image_border_radius }}px;
      will-change: transform;
    }

    .ctm-hover-link-button {
      margin-top:80px;
    }

    /* Swiper-style slide animation wrapper */
    .ctm-image-slide.slide-from-right .ctm-slide-inner,
    .ctm-image-slide.slide-from-left .ctm-slide-inner {
      position: absolute;
      width: 100%;
      height: 100%;
    }

    .ctm-slide-inner {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
    }

    .ctm-slide-inner img {
      width: 100%;
      height: 100%;
      object-fit: {{ section.settings.image_fit }};
      object-position: {{ section.settings.image_position }};
      border-radius: {{ section.settings.image_border_radius }}px;
    }

    /* Swiper-style slide animation */
    .ctm-image-slide.slide-from-right .ctm-slide-inner {
      animation: ctmSlideFromRight {{ section.settings.animation_speed }}ms cubic-bezier(0.19, 1, 0.22, 1) forwards;
    }

    .ctm-image-slide.slide-from-left .ctm-slide-inner {
      animation: ctmSlideFromLeft {{ section.settings.animation_speed }}ms cubic-bezier(0.19, 1, 0.22, 1) forwards;
    }

    @keyframes ctmSlideFromRight {
      from {
        transform: translateX(200px);
      }
      to {
        transform: translateX(0);
      }
    }

    @keyframes ctmSlideFromLeft {
      from {
        transform: translateX(-200px);
      }
      to {
        transform: translateX(0);
      }
    }

    {% if section.settings.animation_style == 'zoom' %}
      .ctm-image-slide.active .ctm-slide-inner {
        animation: ctmZoomIn {{ section.settings.animation_speed }}ms cubic-bezier(0.19, 1, 0.22, 1) forwards;
      }

      @keyframes ctmZoomIn {
        from {
          transform: scale(1.3);
        }
        to {
          transform: scale(1);
        }
      }
    {% endif %}

    {% if section.settings.animation_style == 'fade' %}
      .ctm-image-slide.active .ctm-slide-inner {
        animation: ctmFadeScale {{ section.settings.animation_speed }}ms cubic-bezier(0.19, 1, 0.22, 1) forwards;
      }

      @keyframes ctmFadeScale {
        from {
          transform: scale(0.9);
          opacity: 0;
        }
        to {
          transform: scale(1);
          opacity: 1;
        }
      }
    {% endif %}

    @media (max-width: 768px) {
      .ctm-hover-links-wrapper {
        flex-direction: column;
        gap: 30px;
      }

      .ctm-hover-links-content {
        align-items: normal;
        gap: 0;
      }

      .ctm-links-column,
      .ctm-image-column {
        flex: 1 1 100%;
        padding-left: 0;
      }

      /* Hide images on mobile */
      .ctm-image-column {
        display: none;
      }

      /* Mobile link styles */
      .ctm-link-item {
        margin-bottom: 0;
        border-bottom: 1px solid rgba(0, 0, 0, 0.1);
      }

      .ctm-link-item:last-child {
        border-bottom: none;
      }

      .ctm-link-item a {
        width: 100%;
        justify-content: space-between;
        padding: 16px 0;
        font-size: {{ section.settings.mobile_link_font_size }}px;
        font-weight: 700;
      }

      /* Always show arrow on mobile */
      .ctm-link-arrow {
        width: 20px;
        opacity: 1;
        transform: translateX(0);
        margin-left: auto;
        display: inline-block;
      }

      /* Remove underline animation on mobile */
      .ctm-link-item a::after {
        display: none;
      }

      .ctm-hover-links-heading {
        font-weight: 400;
        font-size: {{ section.settings.mobile_heading_font_size }}px;
        margin-bottom: 24px;
      }

      .ctm-hover-link-button {
        margin-top:30px;
        text-align: center;
      }
    }

      @media(min-width: 1025px){
      .ctm-hover-links-container {
        margin: 0 auto;
        padding: 0 20px;
        max-width: 74vw;
      }
    }

    @media(min-width: 2000px){
      .ctm-hover-links-container {
        margin: 0 auto;
        padding: 0 20px;
        max-width: 80vw;
      } 
      .ctm-link-item a {
        font-size: calc({{ section.settings.link_font_size }}px + 7px);
      }
      .ctm-image-slide-wrapper {
        max-width: calc({{ section.settings.image_width }}px + 100px);
      }

    }

    @media(min-width: 769px) and (max-width:1024px){
      .ctm-hover-links-container {
        padding: 0 40px !important;
      }
    }

    @media(min-width: 769px) and (max-width:1600px){
      .ctm-link-item a {
        font-size: {{ section.settings.tablet_link_font_size }}px;
      }
      
    }
</style>

<div class="ctm-hover-links-section">
  <div class="ctm-hover-links-container">
    <div class="ctm-hover-links-wrapper">
      <div class="ctm-hover-links-content">
        <div class="ctm-links-column">
          {% if section.settings.heading != blank %}
            <h2 class="ctm-hover-links-heading">{{ section.settings.heading }}</h2>
          {% endif %}
          <ul class="ctm-links-list">
            {% for block in section.blocks %}
              <li class="ctm-link-item" {{ block.shopify_attributes }}>
                <a
                  href="{{ block.settings.link }}"
                  data-index="{{ forloop.index0 }}"
                  class="ctm-hover-link {% if forloop.first %}active{% endif %}"
                >
                  {{ block.settings.link_text }}
                  <span class="ctm-link-arrow" aria-hidden="true">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                      <line x1="4" y1="12" x2="20" y2="12"></line>
                      <polyline points="14 6 20 12 14 18"></polyline>
                    </svg>
                  </span>
                </a>
              </li>
            {% endfor %}
          </ul>
          {% if section.settings.button_text != blank %}
            <div class="ctm-hover-link-button">
              <a class="" href="{{ section.settings.button_link }}">{{ section.settings.button_text }}</a>
            </div>
          {% endif %}
        </div>

        <div class="ctm-image-column" aria-hidden="true">
          <div class="ctm-image-slide-wrapper">
            {% for block in section.blocks %}
              {% if block.settings.image != blank %}
                <div
                  class="ctm-image-slide {% if forloop.first %}active{% endif %}"
                  data-index="{{ forloop.index0 }}"
                >
                  <div class="ctm-slide-inner">
                    <img
                      src="{{ block.settings.image | img_url: '1200x' }}"
                      alt=""
                      loading="lazy"
                    >
                  </div>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    const links = document.querySelectorAll('.ctm-hover-link');
    const slides = document.querySelectorAll('.ctm-image-slide');
    const autoChange = {{ section.settings.auto_change }};
    const autoChangeSpeed = {{ section.settings.auto_change_speed }};
    const slideDirection = '{{ section.settings.slide_direction }}';
    const animationStyle = '{{ section.settings.animation_style }}';

    let currentIndex = 0;
    let autoChangeInterval;
    let isTransitioning = false;
    let isMobile = window.innerWidth <= 768;
    let pendingIndex = null;

    function showSlide(index, direction = 'next') {
      if (index === currentIndex || isMobile) return;

      // If already transitioning, queue the next transition
      if (isTransitioning) {
        pendingIndex = index;
        return;
      }

      isTransitioning = true;

      // Immediately remove all active states from links
      links.forEach((link, i) => {
        link.classList.remove('active');
      });

      // Immediately add active state to current link
      links[index].classList.add('active');

      // Remove all active states and animation classes from slides
      slides.forEach((slide) => {
        slide.classList.remove('active', 'slide-from-right', 'slide-from-left');
      });

      // Determine animation direction
      let animationClass = '';
      if (animationStyle === 'slide') {
        if (direction === 'next') {
          animationClass = slideDirection === 'right' ? 'slide-from-right' : 'slide-from-left';
        } else {
          animationClass = slideDirection === 'right' ? 'slide-from-left' : 'slide-from-right';
        }
      }

      // Small delay to ensure clean state before activating new slide
      requestAnimationFrame(() => {
        slides[index].classList.add('active', animationClass);
      });

      currentIndex = index;

      // Reset transitioning flag after animation completes
      setTimeout(() => {
        isTransitioning = false;

        // If there's a pending transition, execute it
        if (pendingIndex !== null && pendingIndex !== currentIndex) {
          const nextDirection = pendingIndex > currentIndex ? 'next' : 'prev';
          const nextIndex = pendingIndex;
          pendingIndex = null;
          showSlide(nextIndex, nextDirection);
        }
      }, 300); // Shorter timeout for faster response
    }

    // Only add hover/focus events on desktop
    if (!isMobile) {
      links.forEach((link, index) => {
        link.addEventListener('mouseenter', () => {
          const direction = index > currentIndex ? 'next' : 'prev';
          showSlide(index, direction);

          if (autoChange && autoChangeInterval) {
            clearInterval(autoChangeInterval);
          }
        });

        link.addEventListener('mouseleave', () => {
          if (autoChange) {
            startAutoChange();
          }
        });

        link.addEventListener('focus', () => {
          const direction = index > currentIndex ? 'next' : 'prev';
          showSlide(index, direction);

          if (autoChange && autoChangeInterval) {
            clearInterval(autoChangeInterval);
          }
        });

        link.addEventListener('blur', () => {
          if (autoChange) {
            startAutoChange();
          }
        });
      });
    }

    function startAutoChange() {
      if (autoChange && !isMobile) {
        clearInterval(autoChangeInterval);
        autoChangeInterval = setInterval(() => {
          const nextIndex = (currentIndex + 1) % slides.length;
          showSlide(nextIndex, 'next');
        }, autoChangeSpeed);
      }
    }

    // Initialize first slide on desktop only
    if (slides.length > 0 && !isMobile) {
      slides[0].classList.add('active');
      if (animationStyle === 'slide') {
        const initialClass = slideDirection === 'right' ? 'slide-from-right' : 'slide-from-left';
        slides[0].classList.add(initialClass);
      }
    }

    if (autoChange && !isMobile) {
      startAutoChange();
    }

    // Handle resize
    window.addEventListener('resize', () => {
      const wasMobile = isMobile;
      isMobile = window.innerWidth <= 768;

      if (wasMobile !== isMobile) {
        if (isMobile && autoChangeInterval) {
          clearInterval(autoChangeInterval);
        } else if (!isMobile && autoChange) {
          startAutoChange();
        }
      }
    });
  })();
</script>

