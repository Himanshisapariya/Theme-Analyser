      "blocks": {
        "faq_VHwNmg": {
          "type": "faq",
          "settings": {
            "question": "<p>Are your leggings true to size?</p>",
            "answer": "Yes—our leggings are designed to fit true to size. They’re high-rise with a snug, sculpting fit that moves with you. For a little more room, size up. Be sure to check the size chart on each product page for the best fit.",
            "faq_answer": ""
          }
        },
        "faq_YCfCPN": {
          "type": "faq",
          "settings": {
            "question": "<p>What if I’m between sizes?</p>",
            "answer": "If you’re between sizes, it depends on how you like your fit. For a snug, sculpting feel—especially in our high-rise leggings—we recommend sizing down. If you prefer a bit more room to move, go with the larger size. Check the size chart and product details for guidance specific to each style.",
            "faq_answer": ""
          }
        },
        "faq_mB7xGP": {
          "type": "faq",
          "settings": {
            "question": "<p>Do all of the leggings have pockets?</p>",
            "answer": "Not all of our leggings have pockets. Some styles feature convenient, secure pockets designed for your essentials, while others focus on a sleek, streamlined fit. Check the product description for each legging to see if pockets are included.",
            "faq_answer": ""
          }
        },
        "faq_DeitFA": {
          "type": "faq",
          "settings": {
            "question": "<p>What materials are the leggings made from?</p>",
            "answer": "Our leggings are crafted from our exclusive Legit™ fabric—made of 86% polyester and 14% elastane. Think soft, durable, and ready to keep up with every move you make. This high-performance blend feels amazing against your skin, stretches where you need it, and holds its shape so you can squat, run, and chill without missing a beat.",
            "faq_answer": ""
          }
        },
        "faq_RHxYHW": {
          "type": "faq",
          "settings": {
            "question": "<p>Are they all high-waisted?</p>",
            "answer": "Yes. All of our leggings feature a high-rise fit designed to offer support and a flattering, sculpting feel.",
            "faq_answer": ""
          }
        },
        "faq_JmVXYD": {
          "type": "faq",
          "settings": {
            "question": "<p>Are they see-through?</p>",
            "answer": "Nope. Our leggings are made with high-quality, performance fabrics designed to keep you covered—no surprises here. You can squat, stretch, and sprint with confidence. If you’re worried about sheerness, check out the product details or reviews for extra peace of mind.",
            "faq_answer": ""
          }
        },
        "faq_xWaBzD": {
          "type": "faq",
          "settings": {
            "question": "<p>Do they shrink in the wash?</p>",
            "answer": "Our leggings are made with durable fabrics designed to hold their shape wash after wash. To keep them looking and fitting their best, follow the care instructions on the label—usually cold wash and air dry or tumble dry low. Proper care helps prevent any shrinking or stretching.",
            "faq_answer": ""
          }
        }
