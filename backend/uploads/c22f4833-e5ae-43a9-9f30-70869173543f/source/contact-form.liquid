{{ 'section-contact-form.css' | asset_url | stylesheet_tag }}
<script src="{{ 'parallax.js' | asset_url }}" defer="defer"></script>

{% style %}
	{% render 'spaced-section' %}

{% endstyle %}

<div class="contact section-{{ section.id }}-padding">
	<div class="container contact__wrapper">
		<div class="contact__container">
			<div class="contact__box">
				{% if section.settings.heading != blank
					or section.settings.text != blank
				%}
					<div class="contact__text">
						{%- if section.settings.heading != blank -%}
							<h2 class="contact__title">
								{{ section.settings.heading }}
							</h2>
						{%- endif -%}
						{% if section.settings.text != blank %}
							<p class="contact__desc">{{ section.settings.text | escape }}</p>
						{% endif %}
					</div>
				{% endif %}
				{%- form 'contact', id: 'ContactForm' -%}
					{%- if form.posted_successfully? -%}
						<div
							class="form-status form-status-list form__message"
							tabindex="-1"
							autofocus
						>
							{% render 'icon-success' %}
							{{ 'templates.contact.form.post_success' | t }}
						</div>
					{%- elsif form.errors -%} 
					{%- endif -%}
					<div class="field contact-min-w">
						<input type="text"
							rows="10"
							id="ContactForm-sub"
							class="field__input no-radius border-act"
							name="contact[SUBJECT]"
							placeholder="SUBJECT"
							aria-required="true"
							required
										>
							{{- form.body -}}
						<label
							class="form__label field__label"
							for="ContactForm-sub"
							placeholder="SUBJECT"
						></label>
					</div>
					<div class="contact__fields contact-min-w">
						<div class="field field__name">
							<input
								class="field__input no-radius border-act"
								autocomplete="name"
								type="text"
								id="ContactForm-name"
								name="contact[{{ 'templates.contact.form.name' | t }}]"
								value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
								placeholder="{{ 'templates.contact.form.name' | t }}" required
							>
							<label
								class="field__label"
								for="ContactForm-name"
								placeholder="{{ 'templates.contact.form.name' | t }}"
								aria-label="Newsletterform"
							></label>
						</div>
						<div class="field field--with-error">
							<input
								autocomplete="email"
								type="email"
								id="ContactForm-email"
								class="field__input no-radius border-act"
								name="contact[email]"
								spellcheck="false"
								autocapitalize="off"
								value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
								aria-required="true"
								{% if form.errors contains 'email' %}
									aria-invalid="true"
									aria-describedby="ContactForm-email-error"
								{% endif %}
								placeholder="{{ 'templates.contact.form.email' | t }}"
								required 
							>
							<label
								class="field__label"
								for="ContactForm-email"
								placeholder="{{ 'templates.contact.form.email' | t }}"
								aria-label="Newsletterform"
							></label>
							{%- if form.errors contains 'email' -%}
								<small
									class="contact__field-error"
									id="ContactForm-email-error"
								>
									<span class="visually-hidden">
										{{- 'accessibility.error' | t -}}
									</span>
									<span class="form__message">
										{{- form.errors.translated_fields.email | capitalize }}
										{{ form.errors.messages.email -}}
									</span>
								</small>
							{%- endif -%}
						</div>
					</div>
					<div class="contact__fields contact-min-w">
						<div class="field contact-min-w">
							<input
								type="tel"
								id="ContactForm-phone"
								class="field__input no-radius border-act"
								autocomplete="tel"
								name="contact[{{ 'templates.contact.form.phone' | t }}]"
								pattern="[0-9\-]*"
								value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
								placeholder="{{ 'templates.contact.form.phone' | t }}"
							>
							<label
								class="field__label"
								for="ContactForm-phone"
								placeholder="{{ 'templates.contact.form.phone' | t }}"
								aria-label="Newsletterform"
							></label>
						</div>
						<div class="field contact-min-w">
							<input
								type="tel"
								id="ContactForm-order"
								class="field__input no-radius border-act"
								autocomplete="tel"
								name="contact[ORDER NUMBER]"
								pattern="[0-9\-]*"
								value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
								placeholder="ORDER NUMBER"
							>
							<label
								class="field__label"
								for="ContactForm-order"
								placeholder="ORDER NUMBER"
								aria-label="Newsletterform"
							></label>
						</div>
					</div>
					<div class="field field__no-margin contact-min-w">
						<textarea
							rows="10"
							id="ContactForm-body"
							class="text-area field__input no-radius border-act"
							name="contact[MESSAGE]"
							placeholder="MESSAGE"
							aria-required="true"
							required
										>
							{{- form.body -}}
						</textarea>
						<label
							class="form__label field__label"
							for="ContactForm-body"
							placeholder="MESSAGE"
						></label>
					</div>
					<div class="file-upload">
						<label for="file-input" class="file-label">
							<svg version="1.1" role="image" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px" width="7px" height="17px" viewBox="0 0 7 17" xml:space="preserve">
							<path d="M6.649,3.773C6.656,2.919,6.33,2.095,5.74,1.477C5.162,0.849,4.354,0.48,3.5,0.456C3.449,0.45,3.398,0.447,3.347,0.444C1.727,0.368,0.352,1.619,0.275,3.24l0.087,10.838c0,0.006,0,0.013,0,0.019c-0.018,1.342,1.056,2.444,2.398,2.461c0.58,0.018,1.143-0.196,1.564-0.595L4.321,15.96c0.031-0.03,0.061-0.059,0.091-0.088c0.406-0.468,0.628-1.068,0.624-1.688l-0.08-8.634C4.965,5.49,4.971,5.43,4.974,5.37c0.039-0.866-0.631-1.599-1.497-1.638c-0.433-0.03-0.856,0.14-1.148,0.461C2.068,4.525,1.934,4.939,1.95,5.361l0.061,6.504c0,0.002,0,0.004,0,0.006c0.005,0.226,0.192,0.406,0.419,0.401c0.229-0.004,0.412-0.192,0.41-0.422l-0.061-6.5C2.766,5.13,2.828,4.911,2.953,4.73c0.038-0.043,0.153-0.176,0.504-0.172c0.621,0.009,0.673,0.686,0.667,0.989l0.079,8.634c0.006,0.413-0.138,0.814-0.405,1.13c-0.265,0.282-0.64,0.433-1.026,0.415c-0.004,0-0.009,0-0.013,0c-0.889-0.023-1.591-0.763-1.567-1.652L1.098,3.232C1.1,3.196,1.104,3.161,1.108,3.126c0.144-1.164,1.204-1.992,2.368-1.848C4.108,1.3,4.704,1.576,5.128,2.045C5.576,2.509,5.824,3.13,5.82,3.776l0.076,8.214c0,0.001,0,0.003,0,0.004c0.004,0.227,0.192,0.407,0.419,0.403c0.229-0.004,0.412-0.192,0.41-0.422L6.649,3.773z"></path>
						  </svg>	
						ADD ATTACHMENT
						</label>
						<input type="file" id="file-input" class="file-input" hidden>
					</div>
					<div class="contact__bottom">
						<button type="submit" class="{{ section.settings.button_style }}">
							<span>
								SUBMIT
							</span>
						</button>

						<div class="contact__add-text tdu">
							{{ section.settings.additional_text }}
						</div>
					</div>
				{%- endform -%}
			</div>
		</div>
	</div>
</div>
<script>
const fileInput = document.getElementById("file-input");
const fileName = document.querySelector(".file-name");

fileInput.addEventListener("change", function () {
  fileName.textContent = fileInput.files.length > 0
    ? fileInput.files[0].name
    : "No file chosen";
});
</script>
{% schema %}
{
	"name": "t:sections.contact-form.name",
	"tag": "section",
	"class": "spaced-section contact-section",
	"enabled_on": {
		"templates": ["*"]
	},
	"settings": [
		{
			"type": "richtext",
			"id": "heading",
			"default": "<p>Contact form</p>",
			"label": "t:sections.contact-form.settings.heading.label"
		},
		{
			"type": "textarea",
			"id": "text",
			"default": "Some text for your contact form. You can use multiple lines of text.",
			"label": "t:sections.contact-form.settings.text.label"
		},
		{
			"type": "richtext",
			"id": "additional_text",
			"default": "<p>Additional text for contact form.</p>",
			"label": "t:sections.contact-form.settings.additional_text.label"
		},
		{
			"type": "header",
			"content": "t:sections.all.section-margin.header.content"
		},
		{
			"type": "range",
			"id": "margin_top",
			"min": 0,
			"max": 200,
			"step": 10,
			"default": 0,
			"unit": "px",
			"label": "t:sections.all.section-margin.margin_top.label"
		},
		{
			"type": "range",
			"id": "margin_bottom",
			"min": 0,
			"max": 200,
			"step": 10,
			"default": 0,
			"unit": "px",
			"label": "t:sections.all.section-margin.margin_bottom.label"
		},
		{
    "type": "select",
    "id": "button_style",
    "options": [
      {
        "value": "button--ctm_global_button",
        "label": "Global Button"
      },
      {
        "value": "button--ctm_wb_global_button",
        "label": "Global Button (White Background)"
      },
      {
        "value": "ctm-custom-button",
        "label": "Custom Button"
      },
      {
        "value": "ctm-custom-outline-button",
        "label": "Outline Button"
      },
      {
        "value": "button button--primary",
        "label": "t:sections.all.button.button_style.options__1.label"
      },
      {
        "value": "button button--secondary",
        "label": "t:sections.all.button.button_style.options__2.label"
      },
      {
        "value": "button button--tertiary",
        "label": "t:sections.all.button.button_style.options__3.label"
      }
    ],
    "default": "button button--primary",
    "label": "t:sections.all.button.button_style.label"
  }
	],
	"presets": [
		{
			"name": "t:sections.contact-form.presets.name"
		}
	]
}
{% endschema %}
