<section
  class="fabric-sections {{ section.settings.extra_class }}"
  style="{% if section.settings.background_color != blank %}background-color: {{ section.settings.background_color }};{% endif %}"
>
  <div class="fullscreen-container {{ section.settings.extra_class_for_container }}">
    <div class="fabric-text-content">
      <div class="fabric-title-btn">
      {% if section.settings.title != blank %}
        <h1 class="fabric-title h3">{{ section.settings.title }}</h1>
      {% endif %}
      {% if section.settings.button_text and section.settings.button_link %}
        <h5 class="link-btn">
          <a href="{{ section.settings.button_link }}" class="btn button--rebuy btn-primary">
            {{- section.settings.button_text -}}
          </a>
        </h5>
      {% endif %}
      </div>
      {% if section.settings.subtitle != blank %}
        <p class="fabric-subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}
    </div>
    <div class="fabric-grid">
      {% for block in section.blocks %}
        <div class="fabric-card">
          <div class="fabric-image">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.heading }}" class="fabric-image">
            {% endif %}
          </div>
          <div class="fabric-content-main">
            <div class="fabric-content">
              <h3 class="fabric-heading">{{ block.settings.heading }}</h3>
              <p class="fabric-description">{{ block.settings.description }}</p>
            </div>
            <div class="button-febric">
              {% if block.settings.button_text and block.settings.button_link %}
                <a
                  href="{{ block.settings.button_link }}"
                  class="{{ section.settings.button_style }} new-button-text"
                >
                  {{- block.settings.button_text -}}
                </a>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    
    
  </div>
</section>

<style>
  .fabric-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 30px;
  }

  .fabric-subtitle {
    font-size: 20px;
    margin-bottom: 40px;
    margin-top: 0;
  }

  .ctm-fabric-start .fabric-image img {
    flex: 0 0 100%;
    object-fit: cover;
    width: 100%;
    height: 500px;
  }

  .ctm-fabric-start .fabric-content {
    display: flex;
    flex-direction: column;
    flex: unset;
  }

  .fabric-sections.ctm-fabric-start {
    padding-bottom: 50px;
  }

  .fabric-card {
    text-align: left;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
  }

  .fabric-image {
    width: 100%;
  }

  .fabric-heading {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 10px;
  }

  .fabric-description {
    font-size: 14px;
    margin-bottom: 15px;
    color: #333;
  }

  .fabric-button {
    color: #000;
    font-size: 14px !important;
    text-decoration: none;
    border-radius: 0 !important;
    transition: background 0.3s ease;
    width: 100%;
  }
  
  
  .fabric-slider {
    display: none;
    margin-top: 30px;
  }

  .fabric-slider .fabric-card {
    box-sizing: border-box;
    height: auto;
    justify-content: space-between;
  }

  .swiper-pagination {
    position: relative;
    margin-top: 20px;
  }

  .swiper-button-prev,
  .swiper-button-next {
    color: #000;
  }

  @media (max-width: 1512px) {
    .ctm-fabric-start .fabric-image img {
      height: 360px;
    }
  }

  @media (max-width: 1200px) {
    .fabric-grid-desktop {
      display: none;
    }

    .fabric-slider-mobile {
      display: block;
    }

    .ctm-fabric-start .fabric-image img {
      height: 340px;
    }
  }

  @media (max-width: 990px) {
    .fabric-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 575px) {
    .fabric-grid {
      grid-template-columns: repeat(1, 1fr);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const fabricSlider = document.querySelector('.fabric-slider-mobile');
    if (fabricSlider) {
      new Swiper('.fabric-slider-mobile', {
        slidesPerView: 1.2,
        spaceBetween: 5,
        pagination: {
          el: '.swiper-pagination',
          clickable: true,
        },
        navigation: {
          nextEl: '.swiper-button-next',
          prevEl: '.swiper-button-prev',
        },
        breakpoints: {
          576: {
            slidesPerView: 2.5,
            spaceBetween: 10,
          },
          990: {
            slidesPerView: 3.2,
          },
        },
      });
    }
  });
</script>

{% schema %}
{
  "name": "Fabric Card Section",
  "settings": [
    {
      "type": "text",
      "id": "extra_class",
      "label": "Extra Class"
    },
    {
      "type": "text",
      "id": "extra_class_for_container",
      "label": "Container Extra Class"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title"
    },
    {
      "type": "html",
      "id": "subtitle",
      "label": "Section Subtitle"
    },
    {
      "type": "text",
      "label": "Button Text",
      "id": "button_text"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f7f7f7"
    },
    {
      "type": "select",
      "id": "button_style",
      "options": [
        {
          "value": "button--ctm_global_button",
          "label": "Global Button"
        },
        {
          "value": "button--ctm_wb_global_button",
          "label": "Global Button (White Background)"
        },
        {
          "value": "ctm-custom-button",
          "label": "Custom Button"
        },
        {
          "value": "ctm-custom-outline-button",
          "label": "Outline Button"
        },
        {
        "value": "fabric-button button button--secondary",
        "label": "Fabric Button"
        },
        {
          "value": "button button--primary",
          "label": "t:sections.all.button.button_style.options__1.label"
        },
        {
          "value": "button button--secondary",
          "label": "t:sections.all.button.button_style.options__2.label"
        },
        {
          "value": "button button--tertiary",
          "label": "t:sections.all.button.button_style.options__3.label"
        }
      ],
      "default": "button button--primary",
      "label": "t:sections.all.button.button_style.label"
    }
  ],
  "blocks": [
    {
      "type": "fabric_block",
      "name": "Fabric Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Fabric Image"
        },
        {
          "type": "html",
          "id": "heading",
          "label": "Fabric Name"
        },
        {
          "type": "html",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Fabric Card Section",
      "category": "Custom"
    }
  ]
}
{% endschema %}
