                },
                {
                    "value": "portrait",
                    "label": "t:sections.product-recommendations.settings.image_ratio.options__2.label"
                },
                {
                    "value": "square",
                    "label": "t:sections.product-recommendations.settings.image_ratio.options__3.label"
                }
