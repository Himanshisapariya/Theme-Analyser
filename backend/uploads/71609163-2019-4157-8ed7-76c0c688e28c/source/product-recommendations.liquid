{% style %}
    {% render 'spaced-section' %}
    {% render 'spaced-section-inner' %}
{% endstyle %}

{% assign is_mix_match = false %}
{% for collection in product.collections %}
  {% if collection.handle == 'mix-match-for-20-off' %}
    {% assign is_mix_match = true %}
    {% break %}
  {% endif %}
{% endfor %}

<product-recommendations-also-like
    class="product-recommendations section-{{ section.id }}-padding"
    data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}"
>
    <div class="product-recommendations__item product-recommendations__item fullscreen-container">
		<div class="product-recommendations__header--container recommendations-header">
			{% assign fleece_ids = collections['fearless-fleece'].products | map: 'id' %}
				<h2 class="product-recommendations__heading h2 title--section">
                    {% if product.metafields.custom.recommendations_heading != blank %}
                    {{ product.metafields.custom.recommendations_heading }}
                    {% elsif is_mix_match %}
					Mix & Match: 3 Graphic Tees or Hats for 20% Off
					{% elsif product.handle == 'team-women-running-club-membership' %}
					More in Women's Running
					{% elsif fleece_ids contains product.id %}
					More in Fleece
					{% elsif product.metafields.custom.recommendations_collection.value != blank %}
					More in This Fabric
					{% else %}
					{{ section.settings.heading }}
					{% endif %}
				</h2>

			{% if section.settings.enable_swiper %}
			<div class="tabbing-arrows header-arrows">
				<div class="swiper-button-prev peev-tabbing-btn swiper-prev-{{ section.id }}">
				<svg xmlns="http://www.w3.org/2000/svg" width="10" height="18" viewBox="0 0 10 18">
					<path d="M9 17L1 9L9 1" stroke="currentColor" stroke-width="1.5" fill="none"/>
				</svg>
				</div>
				<div class="swiper-button-next next-tabbing-btn swiper-next-{{ section.id }}">
				<svg xmlns="http://www.w3.org/2000/svg" width="10" height="18" viewBox="0 0 10 18">
					<path d="M1 1L9 9L1 17" stroke="currentColor" stroke-width="1.5" fill="none"/>
				</svg>
				</div>
			</div>
			{% endif %}

		</div>

        {% if is_mix_match %}
        {% assign mix_match_collection = collections['mix-match-for-20-off'] %}

        {% if mix_match_collection != blank and mix_match_collection.products_count > 0 %}
            <div class="swiper-container swiper product-recommendations">
            <ul class="swiper-wrapper product-recommendations_list ctm-fabric" role="list">
                {% for mix_product in mix_match_collection.products limit: section.settings.products_limit %}
                <li class="swiper-slide collection-product-card product-recommendations__product quickview{% if settings.quickview_hover %}--hover{% endif %}">
                    {% render 'product-card',
                    product_card_product: mix_product,
                    section_id: section.id
                    %}
                </li>
                {% endfor %}
            </ul>

            </div>
        {% endif %}

        {% elsif product.metafields.custom.recommendations_collection.value != blank %}
        <div class="swiper-container swiper product-recommendations">
            <ul class="swiper-wrapper product-recommendations_list ctm-fabric" role="list">
            {% for coll in product.metafields.custom.recommendations_collection.value %}
                {% for compare_product in coll.products limit: section.settings.products_limit %}
                {% unless compare_product.id == 8603453948035 or compare_product.id == 8494143963267 %}
                    <li class="swiper-slide collection-product-card product-recommendations__product quickview{% if settings.quickview_hover %}--hover{% endif %}">
                    {% render 'product-card',
                        product_card_product: compare_product,
                        section_id: section.id
                    %}
                    </li>
                {% endunless %}
                {% endfor %}
            {% endfor %}
            </ul>
        </div>

        {% elsif recommendations.performed and recommendations.products_count > 0 %}
        <div class="swiper-container swiper product-recommendations">
            <ul class="swiper-wrapper product-recommendations_list ctm-fabric" role="list">
            {% for recommendation in recommendations.products limit: section.settings.products_limit %}
                {% unless recommendation.id == 8603453948035 or recommendation.id == 8494143963267 %}
                <li class="swiper-slide collection-product-card product-recommendations__product quickview{% if settings.quickview_hover %}--hover{% endif %}">
                    {% render 'product-card',
                    product_card_product: recommendation,
                    section_id: section.id
                    %}
                </li>
                {% endunless %}
            {% endfor %}
            </ul>


        </div>
        {% endif %}
    </div>
</product-recommendations-also-like>

{% javascript %}
function initRecommendationSwiper(swiperEl) {
  if (!swiperEl || typeof Swiper === 'undefined') return;

  const section = swiperEl.closest('product-recommendations-also-like');
  if (!section) return;

  const nextBtn = section.querySelector('.next-tabbing-btn');
  const prevBtn = section.querySelector('.peev-tabbing-btn');

  // Prevent double init
  if (swiperEl.swiper) {
    swiperEl.swiper.destroy(true, true);
  }

  new Swiper(swiperEl, {
    loop: false,
    spaceBetween: 10,
    navigation: {
      nextEl: nextBtn,
      prevEl: prevBtn,
    },
    breakpoints: {
      0: {
        slidesPerView: 1.3,
      },
      375: {
        slidesPerView: 2.3,
      },
      990: {
        slidesPerView: 3.3,
      },
      1280: {
        slidesPerView: 5.5,
      },
    },
  });
}

function initInitialRecommendationSwiper() {
  const swiperEl = document.querySelector(
    'product-recommendations-also-like .product-recommendations'
  );
  if (swiperEl) {
    initRecommendationSwiper(swiperEl);
  }
}

window.addEventListener('load', () => {
  initInitialRecommendationSwiper();
});

customElements.define(
  'product-recommendations-also-like',
  ProductRecommendations
);
{% endjavascript %}

<style>
    .swiper-button-prev.peev-tabbing-btn,
    .swiper-button-next.next-tabbing-btn{
            top: 38%;
    }
	.recommendations-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}

.recommendations-header .header-arrows {
  display: flex;
  gap: 12px;
}

.recommendations-header .swiper-button-prev,
.recommendations-header .swiper-button-next {
  position: static; 
  margin: 0;
  transform: none;
}
    </style>
{% schema %}
{
    "name": "t:sections.product-recommendations.name",
    "tag": "section",
    "class": "spaced-section section-product-recommendations",
    "settings": [
        {
            "type": "paragraph",
            "content": "t:sections.product-recommendations.settings.paragraph__1.content"
        },
        {
            "type": "richtext",
            "id": "heading",
            "default": "<p>You May Also Like</p>",
            "label": "t:sections.product-recommendations.settings.heading.label"
        },
        {
            "type": "text",
            "id": "link",
            "default": "Shop All",
            "label": "t:sections.product-recommendations.settings.link.label"
        },
        {
