<div class="fabric-collection-section {{ section.settings.extra_class }}">
    <div class="fabric-container fullscreen-container {{ section.settings.extra_class_for_container }}">
        <div class="fabric-text-btn">
            {% if section.settings.heading != blank %}
            <div class="fabric-text">
                <h2>{{ section.settings.heading }}</h2>
            </div>
            {% endif %}

            {% if section.settings.button_text != blank %}
            <div class="fabric-button">
                <h5>
                    <a href="{{ section.settings.button_url }}" class="btn button--rebuy btn-primary">
                        {{ section.settings.button_text }}
                    </a>
                </h5>
            </div>
            {% endif %}
        </div>

        <div class="fabric-collection-products">
            <div class="fabric-container swiper fabric-product-swiper">
                <div class="fabric-product-grid swiper-wrapper">
                    {% for product in section.settings.select_products %}
                    <div class="fabric-product-item swiper-slide">
                        <div class="product-card">
                            <div class="product-card__image">
                                <a href="{{ product.url }}">
                                    <img src="{{ product.featured_image | img_url: '800x' }}"
                                        alt="{{ product.title | escape }}">
                                </a>
                            </div>
                            <div class="product-card__info">
                                <h5 class="product-card__title">
                                    <a href="{{ product.url }}">{{ product.title }}</a>
                                </h5>

                            </div>
                            <div class="product-card_btn">
                                {%- form 'product',
                                product,
                                id: product_form_id,
                                class: 'form',
                                novalidate: 'novalidate',
                                data-type: 'add-to-cart-form'
                                -%}
                                <input type="hidden" name="id"
                                    value="{{ product.selected_or_first_available_variant.id }}" {% if
                                    product.selected_or_first_available_variant.available==false %} disabled {% endif
                                    %}>
                                <div class="product-form__buttons">
                                    <div class="product-form__quantity__add__buttons fabric-card-main">

                                        <button id="ProductSubmitButton-{{ section.id }}" type="submit" name="add"
                                            class="button--ctm_wb_global_button"
                                            {% if product.selected_or_first_available_variant.available==false %}
                                            disabled {% endif %}>
                                            <span>
                                                {%- if product.selected_or_first_available_variant.available -%}
                                                SHOP NOW
                                                {%- else -%}
                                                {{ 'products.product.sold_out' | t }}
                                                {%- endif -%}
                                            </span>
                                            {% comment %} {%- render 'icon-loading' -%} {% endcomment %}
                                        </button>
                                    </div>
                                    <div class="product-form__checkout">
                                        {%- if block.settings.show_dynamic_checkout -%}
                                        {{ form | payment_button }}
                                        {%- endif -%}
                                    </div>
                                </div>
                                {%- endform -%}
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                </div>
                <div class="swiper-scrollbar"></div>
            </div>
        </div>

    </div>
</div>

  <style>
    
    .fabric-collection-section {
        margin-top: {{ section.settings.margin_top | times: 0.50 | round: 0 }}px;
        margin-bottom: {{ section.settings.margin_bottom | times: 0.50 | round: 0 }}px;
    }
    @media (min-width: 992px) {
        .fabric-collection-section {
            margin-top: {{ section.settings.margin_top }}px;
            margin-bottom: {{ section.settings.margin_bottom }}px;
        }
    }
  </style>

<script>
  new Swiper(".fabric-product-swiper", {
    loop: false,
    spaceBetween: 10,
    scrollbar: {
      el: '.swiper-scrollbar',
      draggable: true,
    },
    breakpoints: {
      0: {
        slidesPerView: 1.3,
        {% comment %} spaceBetween: 20, {% endcomment %}
      },
      375: {
        slidesPerView: 1.3,
        {% comment %} spaceBetween: 25, {% endcomment %}
      },
      576: {
        slidesPerView: 1.7,
        {% comment %} spaceBetween: 25, {% endcomment %}
      },
      640: {
        slidesPerView: 2.3,
        {% comment %} spaceBetween: 25, {% endcomment %}
      },
      990: {
        slidesPerView: 2.3,
        spaceBetween: 20,
        {% comment %} spaceBetween: 12, {% endcomment %}
      },
      1400: {
        slidesPerView: 4,
        spaceBetween: 90,
        {% comment %} spaceBetween: 32, {% endcomment %}
      },
      1700: {
        slidesPerView: 3,
        spaceBetween: 90,
        {% comment %} spaceBetween: 32, {% endcomment %}
      }
    },
  });
</script>

{% schema %}

{
  "name": "Fabric Collection Section",
  "settings": [
    {
      "type": "text",
      "label": "Extra Class",
      "id": "extra_class"
    },
    {
      "type": "text",
      "id": "extra_class_for_container",
      "label": "Container Extra Class"
    },
    {
      "type": "text",
      "label": "Heading",
      "id": "heading"
    },
    {
      "type": "text",
      "label": "Button Text",
      "id": "button_text"
    },
    {
      "type": "url",
      "label": "Button URL",
      "id": "button_url"
    },
    {
      "type": "product_list",
      "label": "Select Products",
      "id": "select_products"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "margin top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "margin bottom",
      "default": 0
    },
     {
      "type": "select",
      "id": "button_style",
      "options": [
        {
          "value": "button--ctm_global_button",
          "label": "Global Button"
        },
        {
          "value": "button--ctm_wb_global_button",
          "label": "Global Button (White Background)"
        },
        {
          "value": "ctm-custom-button",
          "label": "Custom Button"
        },
        {
          "value": "ctm-custom-outline-button",
          "label": "Outline Button"
        },
        {
        "value": "fabric-button button button--secondary",
        "label": "Fabric Button"
        },
        {
          "value": "button button--primary",
          "label": "t:sections.all.button.button_style.options__1.label"
        },
        {
          "value": "button button--secondary",
          "label": "t:sections.all.button.button_style.options__2.label"
        },
        {
          "value": "button button--tertiary",
          "label": "t:sections.all.button.button_style.options__3.label"
        }
      ],
      "default": "button button--primary",
      "label": "t:sections.all.button.button_style.label"
    }
  ],
  "presets": [
    {
      "name": "Fabric Collection Section"
    }
  ]
}
{% endschema %}