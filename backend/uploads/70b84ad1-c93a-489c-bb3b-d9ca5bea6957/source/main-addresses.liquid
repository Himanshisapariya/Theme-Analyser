{{ 'customer.css' | asset_url | stylesheet_tag }}
{{ 'customer.js' | asset_url | script_tag }}

<div class="customer account template-addresses" data-customer-addresses>
    <div class="container">
        <div class="account-header">
            <div class="account-header-content">
                <h1 class="account-title">Addresses</h1>
                <a href="{{ routes.account_url }}" class="back-to-account-link">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M19 12H5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M12 19l-7-7 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span>BACK TO ACCOUNT</span>
                </a>
            </div>
        </div>

        <div class="account-grid">
            <!-- Left Column - Address Management -->
            <div class="account-details-column">
                <!-- Add New Address Card -->
                <div class="account-card">
                    <div class="account-card-header">
                        <h2 class="h6">Add New Address</h2>
                        <button
                            type="button"
                            class="add-address-btn"
                            aria-expanded="false"
                            aria-controls="AddAddress"
                            onclick="toggleAddressForm('AddAddress')"
                        >
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                                <path d="M12 8v8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                <path d="M8 12h8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                            </svg>
                        </button>
                    </div>
                    <div class="account-card-content">
                        <div id="AddAddress" class="address-form" style="display: none;">
                                {% form 'customer_address', customer.new_address, aria-labelledBy: 'AddressNewHeading' %}
                                    <div class="form-row">
                                        <div class="form-group half-width">
                                            <label for="AddressFirstNameNew" class="form-label">First Name</label>
                                            <input
                                                type="text"
                                                id="AddressFirstNameNew"
                                                name="address[first_name]"
                                                value="{{ form.first_name }}"
                                                autocomplete="given-name"
                                                class="form-input"
                                                required
                                            >
                                        </div>
                                        <div class="form-group half-width">
                                            <label for="AddressLastNameNew" class="form-label">Last Name</label>
                                            <input
                                                type="text"
                                                id="AddressLastNameNew"
                                                name="address[last_name]"
                                                value="{{ form.last_name }}"
                                                autocomplete="family-name"
                                                class="form-input"
                                                required
                                            >
                                        </div>
                                    </div>
                                    
                                    <div class="form-group">
                                        <label for="AddressCompanyNew" class="form-label">Company</label>
                                        <input
                                            type="text"
                                            id="AddressCompanyNew"
                                            name="address[company]"
                                            value="{{ form.company }}"
                                            autocomplete="organization"
                                            class="form-input"
                                            placeholder="Company (optional)"
                                        >
                                    </div>
                                    
                                    <div class="form-group">
                                        <label for="AddressAddress1New" class="form-label">Address</label>
                                        <input
                                            type="text"
                                            id="AddressAddress1New"
                                            name="address[address1]"
                                            value="{{ form.address1 }}"
                                            autocomplete="address-line1"
                                            class="form-input"
                                            placeholder="Street Address"
                                            required
                                        >
                                    </div>
                                    
                                    <div class="form-group">
                                        <input
                                            type="text"
                                            id="AddressAddress2New"
                                            name="address[address2]"
                                            value="{{ form.address2 }}"
                                            autocomplete="address-line2"
                                            class="form-input"
                                            placeholder="Apartment, suite, etc. (optional)"
                                        >
                                    </div>
                                    
                                    <div class="form-row">
                                        <div class="form-group half-width">
                                            <label for="AddressCityNew" class="form-label">City</label>
                                            <input
                                                type="text"
                                                id="AddressCityNew"
                                                name="address[city]"
                                                value="{{ form.city }}"
                                                autocomplete="address-level2"
                                                class="form-input"
                                                placeholder="City"
                                                required
                                            >
                                        </div>
                                        <div class="form-group half-width">
                                            <label for="AddressZipNew" class="form-label">Postal Code</label>
                                            <input
                                                type="text"
                                                id="AddressZipNew"
                                                name="address[zip]"
                                                value="{{ form.zip }}"
                                                autocapitalize="characters"
                                                autocomplete="postal-code"
                                                class="form-input"
                                                placeholder="Postal Code"
                                                required
                                            >
                                        </div>
                                    </div>
                                    
                                    <div class="form-row">
                                        <div class="form-group half-width">
                                            <label for="AddressCountryNew" class="form-label">Country</label>
                                            <div class="select-wrapper">
                                                <select
                                                    id="AddressCountryNew"
                                                    name="address[country]"
                                                    data-default="{{ form.country }}"
                                                    autocomplete="country"
                                                    class="form-select"
                                                    required
                                                >
                                                    {{ all_country_option_tags }}
                                                </select>
                                                <span class="select-arrow">
                                                    <svg width="12" height="8" viewBox="0 0 12 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                        <path d="M1 1L6 6L11 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                                    </svg>
                                                </span>
                                            </div>
                                        </div>
                                        <div class="form-group half-width" id="AddressProvinceContainerNew" style="display: none;">
                                            <label for="AddressProvinceNew" class="form-label">Province</label>
                                            <div class="select-wrapper">
                                                <select
                                                    id="AddressProvinceNew"
                                                    name="address[province]"
                                                    data-default="{{ form.province }}"
                                                    autocomplete="address-level1"
                                                    class="form-select"
                                                ></select>
                                                <span class="select-arrow">
                                                    <svg width="12" height="8" viewBox="0 0 12 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                        <path d="M1 1L6 6L11 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                                    </svg>
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="form-group">
                                        <label for="AddressPhoneNew" class="form-label">Phone</label>
                                        <input
                                            type="tel"
                                            id="AddressPhoneNew"
                                            name="address[phone]"
                                            value="{{ form.phone }}"
                                            autocomplete="tel"
                                            class="form-input"
                                            placeholder="Phone (optional)"
                                        >
                                    </div>
                                    
                                    <div class="form-group checkbox-group">
                                        <label for="address_default_address_new" class="checkbox-label">
                                            {{ form.set_as_default_checkbox }}
                                            Set as default address
                                        </label>
                                    </div>
                                    
                                    <div class="form-actions">
                                        <button type="submit" class="button--ctm_wb_global_button">
                                            Save Address
                                        </button>
                                        <button type="reset" class="button--ctm_wb_global_button" onclick="toggleAddressForm('AddAddress')">
                                            Cancel
                                        </button>
                                    </div>
                                {% endform %}
                            </div>
                        </div>
                    </div>

                <!-- Existing Addresses -->
                {% paginate customer.addresses by 10 %}
                    {% for address in customer.addresses %}
                        <div class="account-card" data-address>
                            <div class="account-card-header">
                                <h2 class="h6">
                                    {% if address == customer.default_address %}
                                        Default Address
                                    {% else %}
                                        Address {{ forloop.index }}
                                    {% endif %}
                                </h2>
                                <div class="address-actions">
                                    <button
                                        type="button"
                                        class="btn-edit"
                                        aria-label="{{ 'customer.addresses.edit_address' | t }} {{ forloop.index }}"
                                        aria-controls="EditAddress_{{ address.id }}"
                                        aria-expanded="false"
                                        data-address-id="{{ address.id }}"
                                        onclick="toggleAddressForm('EditAddress_{{ address.id }}')"
                                    >
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                            <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                    </button>
                                    <button
                                        type="button"
                                        class="btn-delete"
                                        aria-label="{{ 'customer.addresses.delete' | t }} {{ forloop.index }}"
                                        data-target="{{ address.url }}"
                                        data-confirm-message="{{ 'customer.addresses.delete_confirm' | t }}"
                                    >
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M3 6h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                            <path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                            <path d="M8 6V4a2 2 0 012-2h4a2 2 0 012 2v2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                            <path d="M10 11v6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                            <path d="M14 11v6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                    </button>
                                </div>
                            </div>
                            <div class="account-card-content">
                                <div class="address-display">
                                    <div class="detail-row">
                                        <span class="detail-label">Name:</span>
                                        <span class="detail-value">{{ address.first_name }} {{ address.last_name }}</span>
                                    </div>
                                    {% if address.company %}
                                        <div class="detail-row">
                                            <span class="detail-label">Company:</span>
                                            <span class="detail-value">{{ address.company }}</span>
                                        </div>
                                    {% endif %}
                                    <div class="detail-row">
                                        <span class="detail-label">Address:</span>
                                        <span class="detail-value">
                                            {{ address.address1 }}<br>
                                            {% if address.address2 != "" %}
                                                {{ address.address2 }}<br>
                                            {% endif %}
                                            {{ address.city }}, {{ address.province }} {{ address.zip }}<br>
                                            {{ address.country }}
                                        </span>
                                    </div>
                                    {% if address.phone %}
                                        <div class="detail-row">
                                            <span class="detail-label">Phone:</span>
                                            <span class="detail-value">{{ address.phone }}</span>
                                        </div>
                                    {% endif %}
                                </div>
                                
                                <!-- Edit Form (Hidden by default) -->
                                <div id="EditAddress_{{ address.id }}" class="address-form" style="display: none;">
                                    <h3>Edit Address</h3>
                                    {% form 'customer_address', address %}
                                        <div class="form-row">
                                            <div class="form-group half-width">
                                                <label for="AddressFirstName_{{ form.id }}" class="form-label">First Name</label>
                                                <input
                                                    type="text"
                                                    id="AddressFirstName_{{ form.id }}"
                                                    name="address[first_name]"
                                                    value="{{ form.first_name }}"
                                                    autocomplete="given-name"
                                                    class="form-input"
                                                    placeholder="First Name"
                                                    required
                                                >
                                            </div>
                                            <div class="form-group half-width">
                                                <label for="AddressLastName_{{ form.id }}" class="form-label">Last Name</label>
                                                <input
                                                    type="text"
                                                    id="AddressLastName_{{ form.id }}"
                                                    name="address[last_name]"
                                                    value="{{ form.last_name }}"
                                                    autocomplete="family-name"
                                                    class="form-input"
                                                    placeholder="Last Name"
                                                    required
                                                >
                                            </div>
                                        </div>
                                        
                                        <div class="form-group">
                                            <label for="AddressCompany_{{ form.id }}" class="form-label">Company</label>
                                            <input
                                                type="text"
                                                id="AddressCompany_{{ form.id }}"
                                                name="address[company]"
                                                value="{{ form.company }}"
                                                autocomplete="organization"
                                                class="form-input"
                                                placeholder="Company (optional)"
                                            >
                                        </div>
                                        
                                        <div class="form-group">
                                            <label for="AddressAddress1_{{ form.id }}" class="form-label">Address</label>
                                            <input
                                                type="text"
                                                id="AddressAddress1_{{ form.id }}"
                                                name="address[address1]"
                                                value="{{ form.address1 }}"
                                                autocomplete="address-line1"
                                                class="form-input"
                                                placeholder="Street Address"
                                                required
                                            >
                                        </div>
                                        
                                        <div class="form-group">
                                            <input
                                                type="text"
                                                id="AddressAddress2_{{ form.id }}"
                                                name="address[address2]"
                                                value="{{ form.address2 }}"
                                                autocomplete="address-line2"
                                                class="form-input"
                                                placeholder="Apartment, suite, etc. (optional)"
                                            >
                                        </div>
                                        
                                        <div class="form-row">
                                            <div class="form-group half-width">
                                                <label for="AddressCity_{{ form.id }}" class="form-label">City</label>
                                                <input
                                                    type="text"
                                                    id="AddressCity_{{ form.id }}"
                                                    name="address[city]"
                                                    value="{{ form.city }}"
                                                    autocomplete="address-level2"
                                                    class="form-input"
                                                    placeholder="City"
                                                >
                                            </div>
                                            <div class="form-group half-width">
                                                <label for="AddressZip_{{ form.id }}" class="form-label">Postal Code</label>
                                                <input
                                                    type="text"
                                                    id="AddressZip_{{ form.id }}"
                                                    name="address[zip]"
                                                    value="{{ form.zip }}"
                                                    autocapitalize="characters"
                                                    autocomplete="postal-code"
                                                    class="form-input"
                                                    placeholder="Postal Code"
                                                >
                                            </div>
                                        </div>
                                        
                                        <div class="form-row">
                                            <div class="form-group half-width">
                                                <label for="AddressCountry_{{ form.id }}" class="form-label">Country</label>
                                                <div class="select-wrapper">
                                                    <select
                                                        id="AddressCountry_{{ form.id }}"
                                                        name="address[country]"
                                                        data-address-country-select
                                                        data-default="{{ form.country }}"
                                                        data-form-id="{{ form.id }}"
                                                        autocomplete="country"
                                                        class="form-select"
                                                    >
                                                        {{ all_country_option_tags }}
                                                    </select>
                                                    <span class="select-arrow">
                                                        <svg width="12" height="8" viewBox="0 0 12 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                            <path d="M1 1L6 6L11 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                                        </svg>
                                                    </span>
                                                </div>
                                            </div>
                                            <div class="form-group half-width" id="AddressProvinceContainer_{{ form.id }}" style="display:none;">
                                                <label for="AddressProvince_{{ form.id }}" class="form-label">Province</label>
                                                <div class="select-wrapper">
                                                    <select
                                                        id="AddressProvince_{{ form.id }}"
                                                        name="address[province]"
                                                        data-default="{{ form.province }}"
                                                        autocomplete="address-level1"
                                                        class="form-select"
                                                    ></select>
                                                    <span class="select-arrow">
                                                        <svg width="12" height="8" viewBox="0 0 12 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                            <path d="M1 1L6 6L11 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                                        </svg>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <div class="form-group">
                                            <label for="AddressPhone_{{ form.id }}" class="form-label">Phone</label>
                                            <input
                                                type="tel"
                                                id="AddressPhone_{{ form.id }}"
                                                name="address[phone]"
                                                value="{{ form.phone }}"
                                                autocomplete="tel"
                                                class="form-input"
                                                placeholder="Phone (optional)"
                                            >
                                        </div>
                                        
                                        <div class="form-group checkbox-group">
                                            <label for="address_default_address_{{ form.id }}" class="checkbox-label">
                                                {{ form.set_as_default_checkbox }}
                                                Set as default address
                                            </label>
                                        </div>
                                        
                                        <div class="form-actions">
                                            <button type="submit" class="button--ctm_wb_global_button">
                                                Update Address
                                            </button>
                                            <button type="reset" class="button--ctm_wb_global_button" onclick="toggleAddressForm('EditAddress_{{ address.id }}')">
                                                Cancel
                                            </button>
                                        </div>
                                    {% endform %}
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                {% endpaginate %}
            </div>
        </div>

        <!-- Pagination -->
        {% if paginate.pages > 1 %}
            <div class="pagination-wrapper">
                <nav class="pagination" role="navigation" aria-label="{{ 'general.pagination.label' | t }}">
                    <ul role="list">
                        {% if paginate.previous %}
                            <li>
                                <a href="{{ paginate.previous.url }}" aria-label="{{ 'general.pagination.previous' | t }}">
                                    <svg width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M7 3L3 7l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                </a>
                            </li>
                        {% endif %}

                        {% for part in paginate.parts %}
                            <li>
                                {% if part.is_link %}
                                    <a href="{{ part.url }}" aria-label="{{ 'general.pagination.page' | t: number: part.title }}">
                                        {{ part.title }}
                                    </a>
                                {% else %}
                                    {% if part.title == paginate.current_page %}
                                        <span aria-current="page" aria-label="{{ 'general.pagination.page' | t: number: part.title }}">
                                            {{ part.title }}
                                        </span>
                                    {% else %}
                                        <span>{{ part.title }}</span>
                                    {% endif %}
                                {% endif %}
                            </li>
                        {% endfor %}

                        {% if paginate.next %}
                            <li>
                                <a href="{{ paginate.next.url }}" aria-label="{{ 'general.pagination.next' | t }}">
                                    <svg width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M3 7l4-4 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                </a>
                            </li>
                        {% endif %}
                    </ul>
                </nav>
            </div>
        {% endif %}
    </div>
</div>

<script>
function toggleAddressForm(formId) {
    const form = document.getElementById(formId);
    const allForms = document.querySelectorAll('.address-form');
    const allCards = document.querySelectorAll('.address-card');
    
    // Hide all forms
    allForms.forEach(f => f.style.display = 'none');
    
    // Show/hide the selected form
    if (form.style.display === 'none') {
        form.style.display = 'block';
        
        // Expand the card that contains this form
        const parentCard = form.closest('.address-card');
        if (parentCard) {
            parentCard.classList.add('form-expanded');
        }
    } else {
        form.style.display = 'none';
        
        // Collapse the card
        const parentCard = form.closest('.address-card');
        if (parentCard) {
            parentCard.classList.remove('form-expanded');
        }
    }
}

// Initialize country/province relationship
document.addEventListener('DOMContentLoaded', function() {
    const countrySelects = document.querySelectorAll('[data-address-country-select]');
    
    countrySelects.forEach(select => {
        select.addEventListener('change', function() {
            const formId = this.getAttribute('data-form-id');
            const provinceContainer = document.getElementById('AddressProvinceContainer_' + formId);
            const provinceSelect = document.getElementById('AddressProvince_' + formId);
            
            if (provinceContainer && provinceSelect) {
                // This would typically be handled by Shopify's built-in functionality
                // You may need to implement custom province loading logic here
            }
        });
    });
});
</script>

{% schema %}
{
  "name": "Addresses",
  "settings": [
    {
      "type": "header",
      "content": "Addresses"
    },
    {
      "type": "paragraph",
      "content": "Manage your shipping and billing addresses"
    }
  ]
}
{% endschema %}
