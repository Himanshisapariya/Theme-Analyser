<div id="buildALookDrawer" role="dialog" aria-modal="true" aria-label="Build a Look Drawer">
  <div class="drawer-header">
    <h2>Build a Look</h2>
    <button id="closeBuildALook" aria-label="close">&times;</button>
  </div>

  <div class="drawer-content">
    {% assign products_to_add = product.metafields.custom.build_a_look.value %}
    {% if products_to_add %}
      <form id="add-all-to-cart">
        {% assign product_index = 0 %}

        <ul class="drawer-products" role="list">
          {% for product_ref in products_to_add %}
            {% assign selected_product = all_products[product_ref.handle] %}
            {% if selected_product %}
              <li
                class="drawer-product"
                data-product-id="{{ selected_product.id }}"
                data-product-index="{{ product_index }}"
              >
                <div role="group" aria-label="product" style="display:contents">
                <!-- Product Images Swiper -->
                <!-- fix - #567: Navigation buttons moved before slides for logical focus order -->
                <div
                  class="drawer-product-images swiper"
                  role="region"
                  aria-label="{{ selected_product.title }} carousel"
                >
                <!-- fix - #566: Screen-reader-only instructions added as first child of carousel -->
                  <span class="visually-hidden">Image carousel. Use the Previous and Next buttons to navigate between product images.</span>
                  <div class="tabbing-arrows ctm-bundle-arrows">
                    <button
                      type="button"
                      class="swiper-button-prev peev-tabbing-btn swiper-prev-{{ section.id }}"
                      aria-label="{{ 'accessibility.previous_slide' | t | default: 'Previous slide' }}"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="10"
                        height="18"
                        viewBox="0 0 10 18"
                        fill="none"
                        class="icon icon-caret-left"
                        aria-hidden="true"
                        focusable="false"
                      >
                        <path d="M9 17L1 9L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                      </svg>
                    </button>
                    <button
                      type="button"
                      class="swiper-button-next next-tabbing-btn swiper-next-{{ section.id }}"
                      aria-label="{{ 'accessibility.next_slide' | t | default: 'Next slide' }}"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="10"
                        height="18"
                        viewBox="0 0 10 18"
                        fill="none"
                        class="icon icon-caret-right"
                        aria-hidden="true"
                        focusable="false"
                      >
                        <path d="M1 1L9 9L1 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                      </svg>
                    </button>
                  </div>

                  <div class="swiper-wrapper">
                    {% for image in selected_product.images %}
                      <div class="swiper-slide">
                        <img
                          src="{{ image | img_url: '300x' }}"
                          alt="{{ image.alt }}"
                          data-image-id="{{ image.id }}"
                        >
                      </div>
                    {% endfor %}
                  </div>
                </div>

                <!-- Product Details -->
                <div class="drawer-product-details">
                  <div class="drawer-details">
                    <div class="ctm-product-wrap">
                      <div
                        class="
                          product__title__wrapper
                          {% if selected_product.available == false %} price--sold-out {% endif %}
                          {% if selected_product.compare_at_price > product.price %} price--on-sale {% endif %}
                        "
                      >
                        <h6 class="ctm-bundle-product__title" {{ block.shopify_attributes }}>
                          {{ selected_product.title | escape }}
                        </h6>
                      </div>

                      <!-- Product Price -->
                      <div class="drawer-product-price price" id="price-{{ product_index }}">
                        {{ selected_product.selected_or_first_available_variant.price | money }}
                      </div>
                    </div>

                    {% assign first_variant = selected_product.selected_or_first_available_variant %}

                    <!-- Variant Radios -->
                    <variant-radios
                      id="variant-radios-drawer-{{ product_index }}"
                      class="no-js-hidden {% unless selected_product.has_only_default_variant %}borders ctm-variant-selector{% endunless %}"
                      data-section="drawer-{{ product_index }}"
                      data-url="{{ selected_product.url }}"
                      data-update-url="false"
                    >
                      <div class="variant-name">
                        <p class="ctm-variant-label">Color/Size:</p>
                        <p id="variant-name-{{ forloop.index0 }}" class="ctm-variant-value">
                          - {{ first_variant.title }}
                        </p>
                      </div>

                      {% for option in selected_product.options_with_values %}
                        <fieldset class="js product-form__input product-form__input--radios">
                          <legend class="visually-hidden">{{ option.name }}</legend>
                          <div
                            class="
                              form__label product-form__controls-group
                              {% if forloop.index == 1 %} ctm_color_option
                              {% elsif forloop.index == 2 %} ctm_size_option
                              {% endif %}
                            "
                          >
                            {% for value in option.values %}
                              {% if option.position == 1 %}
                                {% assign variant_available = false %}
                                {% assign variant_status = 'soldout' %}
                                {% for variant in selected_product.variants %}
                                  {% if variant.option1 == value and variant.available %}
                                    {% assign variant_available = true %}
                                    {% assign variant_status = 'available' %}
                                    {% break %}
                                  {% endif %}
                                {% endfor %}
                              {% else %}
                                {% assign variant_available = false %}
                                {% assign variant_status = 'soldout' %}
                                {% for variant in selected_product.variants %}
                                  {% assign match = true %}
                                  {% for i in (1..3) %}
                                    {% assign option_key = 'option' | append: i %}
                                    {% if i == option.position %}
                                      {% unless variant[option_key] == value %}
                                        {% assign match = false %}
                                      {% endunless %}
                                    {% else %}
                                      {% unless variant[option_key] == first_variant[option_key] %}
                                        {% assign match = false %}
                                      {% endunless %}
                                    {% endif %}
                                  {% endfor %}
                                  {% if match and variant.available %}
                                    {% assign variant_available = true %}
                                    {% assign variant_status = 'available' %}
                                    {% break %}
                                  {% endif %}
                                {% endfor %}
                              {% endif %}

                              <input
                                type="radio"
                                id="drawer-{{ product_index }}-{{ option.position }}-{{ forloop.index0 }}"
                                name="options[{{ option.name | escape }}]-{{ product_index }}"
                                value="{{ value | escape }}"
                                form="add-all-to-cart"
                                {% if forloop.index0 == 0 %}
                                  checked
                                {% endif %}
                                {% unless variant_available %}
                                  data-unavailable="true"
                                {% endunless %}
                              >
                              {% liquid
                                assign color_value = value | handle | strip
                                assign color_value_custom = color_value
                                if settings.custom_colors != blank
                                  assign custom_colors_string = settings.custom_colors | strip
                                  assign custom_colors_obj = custom_colors_string | newline_to_br | split: '<br />'
                                  for obj in custom_colors_obj
                                    assign obj_strip = obj | strip
                                    assign obj_key = obj_strip | split: ':' | first
                                    assign obj_value = obj_strip | split: ':' | last
                                    assign obj_color_name = obj_key | handle | strip
                                    if color_value == obj_color_name
                                      assign obj_color_value = obj_value
                                      assign color_value_custom = obj_color_value | strip
                                      break
                                    endif
                                  endfor
                                endif
                              %}

                              <label
                                for="drawer-{{ product_index }}-{{ option.position }}-{{ forloop.index0 }}"
                                class="ctm-bundle-color-swatch color-swatch product-form__option-label {% unless variant_available %}unavailable{% endunless %}"
                                data-available="{{ variant_status }}"
                                {% if option.position == 1 %}
                                  style="--swatch-color: url('{{ color_value_custom }}'); border-radius: {{ settings.swatch_border_radius }}px;"
                                {% endif %}
                                title="{{ value }}"
                              >
                                {% if option.position == 1 %}
                                  {% comment %} Color option with background {% endcomment %}

                                  {% assign color_image = null %}
                                  {% assign color_swatch_fallback = settings.swatch_value_list | map: 'handle' %}
                                  {% assign downcased_value = value | downcase %}
                                  {% for variant in selected_product.variants %}
                                    {% if variant.featured_image and variant.option1 == value %}
                                      {% assign color_image = variant.featured_image %}
                                      {% break %}
                                    {% endif %}
                                  {% endfor %}
                                  <span class="color-option-wrapper">
                                    <span class="visually-hidden">
                                      {{- value -}}
                                      {%- if variant_status == 'soldout' %} - Sold Out{% endif -%}
                                    </span>
                                    {% if color_image %}
                                      {{
                                        color_image
                                        | image_url: width: 50, height: 50, crop: 'center'
                                        | image_tag:
                                          alt: color_image.alt,
                                          class: 'color-swatch-image',
                                          width: 50,
                                          height: 50,
                                          loading: 'lazy'
                                      }}
                                    {% elsif color_swatch_fallback contains downcased_value %}
                                      <span
                                        class="color-swatch"
                                        style="background-color: {{ value | downcase }};"
                                      ></span>
                                    {% else %}
                                      <span class="color-text">{{ value }}</span>
                                    {% endif %}
                                  </span>
                                {% else %}
                                  {% if variant_status == 'soldout' %}
                                    <span class="visually-hidden">{{ value }} - Sold Out</span>
                                  {% endif %}
                                  {{ value }}
                                {% endif %}
                              </label>
                            {% endfor %}
                          </div>
                        </fieldset>
                      {% endfor %}

                      <!-- Hidden input for selected variant ID -->
                      <input
                        type="hidden"
                        class="selected-variant-id"
                        data-product-index="{{ product_index }}"
                        value="{{ first_variant.id }}"
                      >

                      <!-- Product variants JSON for JavaScript -->
                      <script
                        type="application/json"
                        class="product-variants-json"
                        data-product-index="{{ product_index }}"
                      >
                        {{ selected_product.variants | json }}
                      </script>
                    </variant-radios>
                  </div>
                </div>
                </div><!-- /role="group" -->
              </li>

              {% assign product_index = product_index | plus: 1 %}
            {% endif %}
          {% endfor %}
        </ul>

        <!-- Total Price and Add All Button -->
        <div class="drawer-footer byeee">
          <button type="submit" id="add-all-btn" class="button--ctm_wb_global_button ctm-bundle-button">
            <span>Add Set to Cart - </span>
            <span class="total-price" id="drawer-total-price">
              {% assign total_price = 0 %}
              {% for product_ref in products_to_add %}
                {% assign selected_product = all_products[product_ref.handle] %}
                {% if selected_product %}
                  {% assign total_price = total_price
                    | plus: selected_product.selected_or_first_available_variant.price
                  %}
                {% endif %}
              {% endfor %}
              {{ total_price | money }}
            </span>
          </button>
        </div>
      </form>
    {% else %}
      <p>No products selected for this look.</p>
    {% endif %}
  </div>
</div>

