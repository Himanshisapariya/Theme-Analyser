{% javascript %}
  function handleSwiper() {
    const sliderSelector = '.product-recommendations';
    let swiperInstance = null;
    let retryCount = 0;
    const maxRetries = 5;

    function initializeSwiper() {
      const swiperElement = document.querySelector(sliderSelector);

      if (!swiperElement || typeof Swiper === 'undefined') {
        if (retryCount < maxRetries) {
          retryCount++;
          setTimeout(initializeSwiper, 500);
        }
        return;
      }

      try {
        swiperInstance = new Swiper(sliderSelector, {
          loop: false,
          spaceBetween: 10,
          scrollbar: {
            el: '.swiper-scrollbar',
            draggable: true,
          },
          navigation: {
            nextEl: `.next-tabbing-btn`,
            prevEl: `.peev-tabbing-btn`,
          },
          // breakpoints: {
          //   0: {
          //     slidesPerView: 1.3,
          //   },
          //   375: {
          //     slidesPerView: 2.3,
          //   },
          //   990: {
          //     slidesPerView: 3.3,
          //   },
          //   1280: {
          //     slidesPerView: 5,
          //   },
          // },
        });
      } catch (error) {
        if (retryCount < maxRetries) {
          retryCount++;
          setTimeout(initializeSwiper, 1000);
        }
      }
    }

    initializeSwiper();

    if (navigator.userAgent.includes('Safari') && !navigator.userAgent.includes('Chrome')) {
      setTimeout(function () {
        initializeSwiper();
      }, 1500);
    }
  }

  window.addEventListener('load', function () {
    handleSwiper();
  });

  class ProductRecommendations extends HTMLElement {
    constructor() {
      super();

      const handleIntersection = (entries, observer) => {
        if (!entries[0].isIntersecting) return;
        observer.unobserve(this);

        fetch(this.dataset.url)
          .then((response) => response.text())
          .then((text) => {
            const html = document.createElement('div');
            html.innerHTML = text;
            const recommendations = html.querySelector('product-recommendations-also-like');
            if (recommendations && recommendations.innerHTML.trim().length) {
              this.innerHTML = recommendations.innerHTML;
            }
            const selector = this.querySelector('.product-recommendations');

            const swiperInstance = new Swiper(selector, {
              loop: false,
              spaceBetween: 10,
              scrollbar: {
                el: '.swiper-scrollbar',
                draggable: true,
              },
              navigation: {
                nextEl: `.next-tabbing-btn`,
                prevEl: `.peev-tabbing-btn`,
              },
              breakpoints: {
                0: {
                  slidesPerView: 1.3,
                },
                375: {
                  slidesPerView: 2.3,
                },
                990: {
                  slidesPerView: 3.3,
                },
                1280: {
                  slidesPerView: 5,
                },
              },
            });
          })
          .catch((e) => {
            console.error(e);
          });
      };

      new IntersectionObserver(handleIntersection.bind(this), {
        rootMargin: '0px 0px 200px 0px',
      }).observe(this);
    }
  }

  customElements.define('product-recommendations-also-like', ProductRecommendations);
{% endjavascript %}
