<svg
	xmlns="http://www.w3.org/2000/svg"
	width="10"
	height="18"
	viewBox="0 0 10 18"
	fill="none"
	class="icon icon-caret-right"
	{% if aria_label %}
		role="img"
		aria-labelledby="IconTitle-{{ id | default: 'caret-right' }}"
	{% else %}
		aria-hidden="true"
		focusable="false"
	{% endif %}
>
	{% if aria_label %}
		<title id="IconTitle-{{ id | default: 'caret-right' }}">{{ aria_label }}</title>
	{% endif %}
	<path d="M1 1L9 9L1 17" stroke="currentcolor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
</svg>
