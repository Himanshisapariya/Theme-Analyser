{% if product.metafields.custom.fabric_details %}
  {% assign fabric = product.metafields.custom.fabric_details.value %}

  <section class="fabric-section-main-start">
    <section class="fabric-section fullscreen-container">
      <div class="fabric-section-inside">
        <div class="fabric-content">
          <div class="fabric-content-title">
            <h2>{{ fabric.title }}</h2>
          </div>
          <div class="fabric-content-text">
            {{ fabric.content_details }}
          </div>
          <div class="fabric-details">
            <ul>
              {% for detail in fabric.content_details %}
                <li>{{ detail }}</li>
              {% endfor %}
            </ul>
          </div>
          <div class="fabric-content-link-above">
            {% if fabric.enable_url == true %}
              <a href="{{ fabric.btn_url }}" class="fabric-popup-redirect">{{ fabric.btn_text }}</a>
            {%  else %}
              <a href="#" class="fabric-popup-trigger" data-popup-id="fabric-popup">Learn More About XX-XY Fabrics</a>
            {% endif %}
          </div>
        </div>
        <div class="fabric-image desktop-image test ">
          {{
            fabric.image
            | image_url: width: 4096
            | image_tag:
              loading: 'lazy',
              alt: '',
              width: media.preview_image.width,
              height: image_height,
              sizes: '100vw',
              widths: '550, 750, 1100, 1445, 1680, 2048, 2890, 4096'
          }}
          {{
            fabric.image2
            | image_url: width: 4096
            | image_tag:
              loading: 'lazy',
              alt: '',
              width: media.preview_image.width,
              height: image_height,
              sizes: '100vw',
              widths: '550, 750, 1100, 1445, 1680, 2048, 2890, 4096'
          }}
        </div>
         {%  if fabric.mobile_image != blank %}
        <div class="fabric-mobile-image">
          {{
            fabric.mobile_image
            | image_url: width: 4096
            | image_tag:
              loading: 'lazy',
              alt: '',
              width: media.preview_image.width,
              height: image_height,
              sizes: '100vw',
              widths: '550, 750, 1100, 1445, 1680, 2048, 2890, 4096'
          }}
        </div>
      {% endif %}
      </div>
    </section>
  </section>

  <!-- Popup -->
  <div id="fabric-popup" class="fabric-popup">
    <div class="popup-content">
      <span class="close-popup">&times;</span>
      <div class="fabric-popup-main-popup">
        <h3>{{ fabric.popup_title }}</h3>
      </div>
      {{ fabric.info }}
    </div>
  </div>
  {% comment %}
    <style>
      .fabric-section { display: flex; align-items: center; justify-content: space-between; padding: 40px; }
      .fabric-content { max-width: 50%; }
      .fabric-image img { width: 100%; max-width: 300px; border-radius: 10px; }
      .fabric-popup { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.6); justify-content: center; align-items: center; }
      .popup-content { background: white; padding: 20px; max-width: 500px; border-radius: 10px; }
      .close-popup { cursor: pointer; font-size: 24px; position: absolute; top: 10px; right: 20px; }
    </style>
  {% endcomment %}

  <script>
    document.querySelector('.fabric-popup-trigger').addEventListener('click', function (event) {
      event.preventDefault();
      document.getElementById('fabric-popup').style.display = 'flex';
    });

    document.querySelector('.close-popup').addEventListener('click', function () {
      document.getElementById('fabric-popup').style.display = 'none';
    });

    document.addEventListener('DOMContentLoaded', function () {
      document.querySelector('.fabric-popup-trigger').addEventListener('click', function () {
        document.body.classList.add('overflow-hidden');
      });

      document.querySelector('.fabric-popup .close-popup').addEventListener('click', function () {
        document.body.classList.remove('overflow-hidden');
      });
    });

    document.addEventListener('DOMContentLoaded', function () {
      const trigger = document.querySelector('.fabric-popup-trigger');
      const closeBtn = document.querySelector('.fabric-popup .close-popup');
      const elements = document.querySelectorAll('.shopify-section-header, .section-announcement');

      trigger.addEventListener('click', function () {
        elements.forEach((el) => el.classList.add('change-z-for-fabric-popup'));
      });

      closeBtn.addEventListener('click', function () {
        elements.forEach((el) => el.classList.remove('change-z-for-fabric-popup'));
      });
    });
  </script>
{% endif %}