{{ 'customer.css' | asset_url | stylesheet_tag }}
<script src="{{ 'input.js' | asset_url }}" defer="defer"></script>


<style>

.tooltip-content {
	margin-top: 20px;
}

.order-tracking .tooltip-content {
  position: relative;
  display: inline-block;
}

.order-tracking .tooltip {
  display: none;
  background-color: #f9f9f9;
  border: 1px solid #ccc;
  padding: 5px;
  position: absolute!important;
  z-index: 1;
  width: 250px;
  top: 15px;
  left: 20px;
  font-size: 12px;
  line-height: 16px;
}

.order-tracking .tooltip-content:hover .tooltip {
  display: block;
}

.section-logo {
	height: auto !important;
	width: 200px !important;
}
</style>

<div
	class="login_section color-{{ section.settings.color_scheme_customer }} header-color-{{ section.settings.header_color_scheme }}"
>

	 <div class="customer login fullscreen-container">
		<div class="login__form order-return__field">
			<div class="page-header">
				<div class="page-header__inner">
					<h2 class="title--page" id="login" tabindex="-1">
						Have your order number? Enter your details below.
					</h2>
				</div>
			</div>
		<div class="login__fields">
			
			<form id="returnForm">

			<div class="section-logo">
				{% if section.settings.logo %}
				<img src="{{ section.settings.logo | image_url }}" alt="Icon" height="auto" width="200px">
				{% endif %}
			</div>

		  <div class="tooltip-content">
			<div class="info-icon" id="infoIcon">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24px" height="24px">    <path d="M 12 2 C 6.4889971 2 2 6.4889971 2 12 C 2 17.511003 6.4889971 22 12 22 C 17.511003 22 22 17.511003 22 12 C 22 6.4889971 17.511003 2 12 2 z M 12 4 C 16.430123 4 20 7.5698774 20 12 C 20 16.430123 16.430123 20 12 20 C 7.5698774 20 4 16.430123 4 12 C 4 7.5698774 7.5698774 4 12 4 z M 11 7 L 11 9 L 13 9 L 13 7 L 11 7 z M 11 11 L 11 17 L 13 17 L 13 11 L 11 11 z"/></svg>
			</div>
			<div class="tooltip" id="tooltip">You can find your order number on your packing slip or in your order confirmation email.</div>
		  </div>
			<div class="field field--dark login__field">
				<input type="text" id="orderNumber" name="orderNumber" class="field__input" placeholder="ORDER #" required>
				<label for="orderNumber" id="order-label" placeholder="ORDER #"></label>
			</div>

			
		 
		  
		  <div class="field field--dark login__field">
			<input type="text" id="zipCode" name="zipCode" class="field__input" placeholder="ZIP Code" required>
			<label for="zipCode" id="zipcode-label" placeholder="ZIP Code"></label>
		  </div>
		  <div class="customer__buttons login__buttons">

		  <button type="submit" class="button button--primary button--arrow login__sign-in">Submit</button>
						

						
					</div>
		 
		<p class="help-text">Having trouble locating your order? No problem! Reach out to <a class="order-return__email" href="mailto:orders@xx-xyathletics.com">orders@xx-xyathletics.com</a> so we can help.</p>
	
		<p class="error-message" id="errorMessage"></p>
		<div class="loader" id="loader" style="display: none;">
                        Processing....
                    </div>
		</form>
		
		</div>
		</div>
		
		
	  </div>  

      {%  render 'account-portal-slider' %}

</div>
<script>

    document.getElementById('returnForm').addEventListener('submit', async function(event) {
    event.preventDefault();

    const orderNumber = document.getElementById('orderNumber').value;
    const zipCode = document.getElementById('zipCode').value;
    const errorMessage = document.getElementById('errorMessage');
    const loader = document.getElementById('loader');
    errorMessage.textContent = ''; 

    loader.style.display = 'block';

    const url = 'https://api.loopreturns.com/api/v1/order/link';
    const data = { name: orderNumber, zip: zipCode };
    
    const options = {
        method: 'POST',
        headers: {
            'Accept': 'application/json',
            'Content-Type': 'application/json',
            'X-Authorization': 'fa58fbbbf5dfe8a42c4ae2d3703c01ab8e2323ca'
        },
        body: JSON.stringify(data)
    };

    try {
        const response = await fetch(url, options);
        if (!response.ok) {
            throw new Error(`HTTP error! Status: ${response.status}`);
        }
        
        const result = await response.json();
        const returnUrl = result.url;

        window.location.href = returnUrl;

    } catch (error) {
        console.error('Error fetching or updating the return link:', error);
        errorMessage.textContent = 'An error occurred. Please check your order details and try again.';
    } finally {
        loader.style.display = 'none';
    }
});

  </script>
{% javascript %}
	const events = [
		'shopify:section:reorder',
		'shopify:section:deselect',
		'shopify:section:select',
		'shopify:section:unload',
		'shopify:section:load',
	];

	const account_header_overlay = () => {
		let headerOverlay = document.querySelector('.overlay');
		let colorScheme = document.querySelector('.header-color-light');

		if (headerOverlay) {
			if (colorScheme) {
				headerOverlay.classList.add('theme-dark');
				headerOverlay.classList.add('header-color-background-5');
			} else {
				headerOverlay.classList.remove('theme-dark');
				headerOverlay.classList.remove('header-color-background-5');
				headerOverlay.classList.add('color-background-1');
			}
		}
	};

	account_header_overlay();

	events.forEach(function (item) {
		document.addEventListener(item, function () {
			account_header_overlay();
		});
	});
{% endjavascript %}

