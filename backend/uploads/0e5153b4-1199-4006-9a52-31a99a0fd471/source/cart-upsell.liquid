

{{ 'section-main-product.css' | asset_url | stylesheet_tag }}
{{ 'quick-add.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="{{ 'component-deferred-media.css' | asset_url }}" media="all">

<script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

{% assign is_cart_empty = false %}
{% if cart.item_count == 0 %}
  {% assign is_cart_empty = true %}
{% endif %}

{% if is_cart_empty %}
  {% assign upsell_title = block.settings.empty_title | default: block.settings.title %}
  {% assign upsell_collection_handle = block.settings.empty_collection %}
  {% assign products_to_show = block.settings.empty_products_to_show %}
{% else %}
  {% assign upsell_title = block.settings.title %}
  {% assign upsell_collection_handle = block.settings.collection %}
  {% assign products_to_show = block.settings.products_to_show %}
{% endif %}

{%- assign upsell_collection = collections[upsell_collection_handle] -%}
{%- assign products_count = upsell_collection.products.size -%}

<div
  class="upsell-section"
  data-upsell-section
  data-section-id="{{ section.id }}"
  {{ block.shopify_attributes }}
>
  {% if upsell_title != blank %}
    <h4 class="upsell-section__title">{{ upsell_title }}</h4>
  {% endif %}

  <div class="upsell-slider-wrapper">
    {% if upsell_collection and products_count > 0 %}
      <div class="upsell-swiper">
        <div class="swiper-wrapper">
          {% for product in upsell_collection.products limit: products_to_show %}
            <div class="swiper-slide">
              <div class="upsell-card">
                <div class="upsell-card__image-wrapper">
                  <a href="{{ product.url }}" class="upsell-card__image-wrapper-link">
                    {% if product.featured_media %}
                      <img
                        class="upsell-card__image"
                        src="{{ product.featured_media | img_url: '400x' }}"
                        alt="{{ product.featured_media.alt | escape }}"
                        loading="lazy"
                        width="400"
                        height="400"
                      >
                    {% else %}
                      {{ 'product-1' | placeholder_svg_tag: 'upsell-card__image' }}
                    {% endif %}
                  </a>

                  {% assign product_form_id = 'upsell-quick-add-' | append: section.id | append: product.id %}

                  <modal-opener data-modal="#QuickAdd-upsell-{{ section.id }}-{{ product.id }}">
                    <button
                      id="{{ product_form_id }}-submit"
                      type="button"
                      class="upsell-card__add-btn"
                      aria-haspopup="dialog"
                      aria-label="Quick view {{ product.title | escape }}"
                      data-product-url="{{ product.url }}"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke-width="2"
                        stroke="currentColor"
                      >
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                      </svg>
                    </button>
                  </modal-opener>

                  <quick-add-modal id="QuickAdd-upsell-{{ section.id }}-{{ product.id }}" class="quick-add-modal">
                    <div
                      role="dialog"
                      aria-label="{{ 'products.product.choose_product_options' | t: product_name: product.title | escape }}"
                      aria-modal="true"
                      class="quick-add-modal__content global-settings-popup"
                      tabindex="-1"
                    >
                      <button
                        id="ModalClose-upsell-{{ section.id }}-{{ product.id }}"
                        type="button"
                        class="quick-add-modal__toggle modal-close-button"
                        aria-label="{{ 'accessibility.close' | t }}"
                      >
                        {% render 'icon-close' %}
                      </button>

                      <div class="quick-add-modal__content-wrapper">
                        <div
                          id="QuickAddInfo-upsell-{{ section.id }}-{{ product.id }}"
                          class="quick-add-modal__content-info"
                        ></div>
                      </div>
                    </div>
                  </quick-add-modal>
                </div>

                <div class="upsell-card__info">
                  <h3 class="upsell-card__title">
                    <a href="{{ product.url }}">{{ product.title }}</a>
                  </h3>
                  <span class="upsell-card__price">
                    {{ product.price | money }}
                  </span>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>

      {% if products_count > 5 %}
        <div class="upsell-nav-btn upsell-button-prev">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
          </svg>
        </div>
        <div class="upsell-nav-btn upsell-button-next">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
          </svg>
        </div>
      {% endif %}
    {% else %}
      <p>No products found in selected collection.</p>
    {% endif %}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof Swiper === 'undefined') return;

    const upsellSection = document.querySelector('.upsell-section[data-section-id="{{ section.id }}"]');

    if (!upsellSection || upsellSection.dataset.initialized) return;

    const swiperEl = upsellSection.querySelector('.upsell-swiper');
    if (!swiperEl) return;

    upsellSection.dataset.initialized = 'true';

    new Swiper(swiperEl, {
      slidesPerView: 2,
      spaceBetween: 15,
      slidesPerGroup: 2,
      loop: true,
      watchSlidesProgress: true,
      navigation: {
        nextEl: upsellSection.querySelector('.upsell-button-next'),
        prevEl: upsellSection.querySelector('.upsell-button-prev'),
      },
      breakpoints: {
        750: {
          slidesPerView: 3,
          slidesPerGroup: 3,
          spaceBetween: 20,
        },
        990: {
          slidesPerView: 4,
          slidesPerGroup: 4,
          spaceBetween: 20,
        },
        1200: {
          slidesPerView: 5,
          slidesPerGroup: 5,
          spaceBetween: 20,
        },
      },
    });
  });
</script>
