<script>
document.addEventListener('DOMContentLoaded', () => {
  const section = document.querySelector('#collection-tabs-{{ section.id }}');
  if (!section) return;

  const tabButtons = section.querySelectorAll('.tab-button');
  const tabsBar = section.querySelector('.tabs');
  const filtersBar = section.querySelector('.global-filters');

  tabButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = document.querySelector(btn.dataset.scrollTo);
      if (target) {
        const offset =
          (tabsBar?.offsetHeight || 0) +
          (filtersBar?.offsetHeight || 0) +
          20;

        const top =
          target.getBoundingClientRect().top +
          window.scrollY -
          offset;

        window.scrollTo({ top: top, behavior: 'smooth' });

        history.replaceState(null, '', `?bundle=${btn.dataset.bundle}`);
      }
    });
  });

  const params = new URLSearchParams(window.location.search);
  const bundleIndex = params.get('bundle');

  if (bundleIndex) {
    const targetBtn = section.querySelector(
      `.tab-button[data-bundle="${bundleIndex}"]`
    );

    if (targetBtn) {
      setTimeout(() => {
        targetBtn.click();
      }, 300);
    }
  }

  const allGrids = section.querySelectorAll('.product-grid');

  function sortAllProducts(sortBy) {
    allGrids.forEach((grid) => {
      const products = Array.from(grid.children);
      products.sort((a, b) => {
        const aTitle = (a.dataset.productTitle || '').toLowerCase();
        const bTitle = (b.dataset.productTitle || '').toLowerCase();
        const aPrice = Number(a.dataset.productPrice || 0);
        const bPrice = Number(b.dataset.productPrice || 0);
        const aDate = Number(a.dataset.productPublished || 0);
        const bDate = Number(b.dataset.productPublished || 0);

        switch (sortBy) {
          case 'title-asc': return aTitle.localeCompare(bTitle);
          case 'title-desc': return bTitle.localeCompare(aTitle);
          case 'price-asc': return aPrice - bPrice;
          case 'price-desc': return bPrice - aPrice;
          case 'date-asc': return aDate - bDate;
          case 'date-desc': return bDate - aDate;
          default: return 0;
        }
      });
      products.forEach((p) => grid.appendChild(p));
    });
  }

  function filterAllByGender(gender) {
    allGrids.forEach((grid) => {
      const cards = grid.querySelectorAll('.collection-product-card');
      cards.forEach((card) => {
        const tags = (card.dataset.productTags || '')
          .toLowerCase()
          .split(',')
          .map((t) => t.trim());

        card.style.display =
          gender === 'all' || tags.includes(gender) ? '' : 'none';
      });
    });
  }

  section.querySelectorAll('.bundle-filters .dropdown').forEach((dropdown) => {
    const btn = dropdown.querySelector('.dropdown-btn');
    const menu = dropdown.querySelector('.dropdown-menu');

    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      menu.classList.toggle('hidden');
    });

    menu.querySelectorAll('li').forEach((item) => {
      item.addEventListener('click', () => {
        btn.textContent = item.textContent;
        menu.classList.add('hidden');

        if (dropdown.classList.contains('sort-select')) {
          sortAllProducts(item.dataset.value);
        } else if (dropdown.classList.contains('gender-filter')) {
          filterAllByGender(item.dataset.value.toLowerCase());
        }
      });
    });
  });

  document.addEventListener('click', () => {
    section
      .querySelectorAll('.bundle-filters .dropdown .dropdown-menu')
      .forEach((menu) => menu.classList.add('hidden'));
  });

  section.querySelectorAll('.collection-block').forEach((block) => {
    const grid = block.querySelector('.product-grid');
    const loadMoreWrapper = block.querySelector('.load-more-wrapper');
    const btn = block.querySelector('.ctm-bundle-load-more');

    if (!grid || !btn) return;

    const products = Array.from(
      grid.querySelectorAll('.collection-product-card')
    );

    const INITIAL_VISIBLE = 8;

    if (products.length <= INITIAL_VISIBLE) {
      loadMoreWrapper.style.display = 'none';
      return;
    }

    products.forEach((product, index) => {
      if (index >= INITIAL_VISIBLE) {
        product.style.display = 'none';
      }
    });

    btn.addEventListener('click', (e) => {
      e.preventDefault();

      products.forEach((product) => {
        product.style.display = '';
      });

      loadMoreWrapper.style.display = 'none';
    });
  });

});
</script>


{% schema %}
{
  "name": "Bundle Tabs",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Section Description"
    },
    {
      "type": "range",
      "id": "bundle_heading_fontsize",
      "label": "Bundle Heading Font Size",
      "min": 10,
      "max": 50,
      "default": 36,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "bundle_subheading_fontsize",
      "label": "Bundle SubHeading Font Size",
      "min": 10,
      "max": 50,
      "default": 22,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "bundle_heading_mobile_fontsize",
      "label": "Bundle Heading Font Size - Mobile",
      "min": 10,
      "max": 50,
      "default": 30,
      "unit": "px"
