{%- liquid
  assign has_variant_mode = false
  for block in section.blocks
    if block.settings.show_variants_as_products
      assign has_variant_mode = true
      break
    endif
  endfor
-%}
{% if has_variant_mode %}
  <style>.card-title_info .wide-price{display:none}</style>
  <link rel="preload" href="{{ 'section-main-product.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <link rel="stylesheet" href="{{ 'component-deferred-media.css' | asset_url }}" media="all">
  <link rel="preload" href="{{ 'quick-add.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'copy.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-single.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'update-slider.js' | asset_url }}" defer="defer"></script>
{% endif %}

<section id="collection-tabs-{{ section.id }}" class="collection-tabs-section">
  <div class="">
    {% if section.settings.heading != blank %}
      <h2 class="section-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.description != blank %}
      <p class="section-description">{{ section.settings.description }}</p>
    {% endif %}

    {%- assign collections = section.blocks | map: 'settings' -%}
    {% if collections.size > 0 %}
      <div class="filter-tab-wrapper-above">
        <div class="fullscreen-container" style="padding-top: 0 !important;">
          <div class="filter-tab-wrapper">
            <div class="tabs">
              {% for block in section.blocks %}
                {% if block.settings.collection != blank %}
                  <h5 style="font-weight: 500; margin: 0;" class="tabs-heading-div">
                    <a
                        class="tab-button"
                        data-bundle="{{ forloop.index }}"
                        data-scroll-to="#collection-{{ section.id }}-{{ forloop.index }}"
                      >
                        {{ block.settings.tab_title | default: block.settings.collection.title }}
                      </a>
                    </h5>
                {% endif %}
              {% endfor %}
            </div>

            <div class="filter-grid-wrapper">
              <div class="bundle-filters global-filters">
                <div class="sort-select dropdown">
                  <button class="dropdown-btn">Sort By</button>
                  <ul class="dropdown-menu hidden">
                    <li data-value="title-asc">Alphabetical, A–Z</li>
                    <li data-value="title-desc">Alphabetical, Z–A</li>
                    <li data-value="price-asc">Price, low to high</li>
                    <li data-value="price-desc">Price, high to low</li>
                    <li data-value="date-desc">Date, new to old</li>
                    <li data-value="date-asc">Date, old to new</li>
                  </ul>
                </div>

                <div class="gender-filter dropdown">
                  <button class="dropdown-btn">Genders</button>
                  <ul class="dropdown-menu hidden">
                    <li data-value="all">All</li>
                    <li data-value="men">Men</li>
                    <li data-value="women">Women</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="fullscreen-container">
        <div class="collections-wrapper">
          {%- for block in section.blocks -%}
            {% if block.settings.collection != blank %}
              {% assign collection = block.settings.collection %}
              <div id="collection-{{ section.id }}-{{ forloop.index }}" class="collection-block">
                {% if block.settings.collection_title != blank %}
                  <h3 class="bundle-collection-title">{{ block.settings.collection_title }}</h3>
                {% endif %}
                {% if block.settings.collection_desc != blank %}
                  <p class="bundle-collection-subtitle">{{ block.settings.collection_desc }}</p>
                {% endif %}

                
                <div class="product-grid product-grid-builder-tabs-4" id="product-grid-{{ collection.handle }}">
                  {% if block.settings.show_variants_as_products %}
                    {%- comment -%} Show color variants as separate product cards {%- endcomment -%}
                    {% for product in collection.products %}
                      {% if product.has_only_default_variant %}
                        {%- comment -%} Product with single variant - show normally {%- endcomment -%}
                        <div
                          class="collection-product-card product-recommendations__product quickview{%- if settings.quickview_hover -%}--hover{% endif %}"
                          data-product-tags="{{ product.tags | join: ',' | downcase | escape }}"
                          data-product-title="{{ product.title | escape }}"
                          data-product-price="{{ product.price | default: 0 }}"
                          data-product-published="{{ product.published_at | date: '%s' }}"
                        >
                          {% render 'product-card',
                            product_card_product: product,
                            section_id: section.id,
                            media_size: 'portrait',
                            quickview_show: true,
                            media_fit: 'cover'
                          %}
                        </div>
                      {% else %}
                        {%- comment -%} Product with multiple variants - create a "virtual product" for each color {%- endcomment -%}
                        {%- liquid
                          assign color_trigger = settings.trigger_swatch | handle | strip
                          assign color_option_index = nil
                          
                          for option in product.options_with_values
                            assign option_name = option.name | handle | strip
                            if option_name == color_trigger
                              assign color_option_index = forloop.index0
                              break
                            endif
                          endfor
                        -%}
                        
                        {% if color_option_index != nil %}
                          {%- comment -%} Product has color variants - group by color {%- endcomment -%}
                          {%- assign colors_added = "" -%}
                          {% for variant in product.variants %}
                            {%- assign variant_color = variant.options[color_option_index] -%}
                            {%- unless colors_added contains variant_color -%}
                              {%- assign colors_added = colors_added | append: variant_color | append: "," -%}
                              <div
                                class="collection-product-card variant-as-product product-recommendations__product quickview{%- if settings.quickview_hover -%}--hover{% endif %}"
                                data-product-tags="{{ product.tags | join: ',' | downcase | escape }}"
                                data-product-title="{{ product.title | escape }} - {{ variant_color | escape }}"
                                data-product-price="{{ variant.price | default: 0 }}"
                                data-product-published="{{ product.published_at | date: '%s' }}"
                                data-color-variant="{{ variant_color }}"
                              >
                                {% render 'product-card-variant',
                                  product_card_product: product,
                                  variant_color: variant_color,
                                  color_option_index: color_option_index,
                                  section_id: section.id,
                                  media_size: 'portrait',
                                  quickview_show: true,
                                  media_fit: 'cover'
                                %}
                              </div>
                            {%- endunless -%}
                          {% endfor %}
                        {% else %}
                          {%- comment -%} No color option found - show normally {%- endcomment -%}
                          <div
                            class="collection-product-card product-recommendations__product quickview{%- if settings.quickview_hover -%}--hover{% endif %}"
                            data-product-tags="{{ product.tags | join: ',' | downcase | escape }}"
                            data-product-title="{{ product.title | escape }}"
                            data-product-price="{{ product.price | default: 0 }}"
                            data-product-published="{{ product.published_at | date: '%s' }}"
                          >
                            {% render 'product-card',
                              product_card_product: product,
                              section_id: section.id,
                              media_size: 'portrait',
                              quickview_show: true,
                              media_fit: 'cover'
                            %}
                          </div>
                        {% endif %}
                      {% endif %}
                    {% endfor %}
                  {% else %}
                    {%- comment -%} Normal display - show products as is {%- endcomment -%}
                    {% for product in collection.products %}
                      <div
                        class="collection-product-card product-recommendations__product quickview{%- if settings.quickview_hover -%}--hover{% endif %}"
                        data-product-tags="{{ product.tags | join: ',' | downcase | escape }}"
                        data-product-title="{{ product.title | escape }}"
                        data-product-price="{{ product.price | default: 0 }}"
                        data-product-published="{{ product.published_at | date: '%s' }}"
                      >
                        {% render 'product-card',
                          product_card_product: product,
                          section_id: section.id,
                          media_size: 'portrait',
                          quickview_show: true,
                          media_fit: 'cover'
                        %}
                      </div>
                    {% endfor %}
                  {% endif %}
                </div>

                {% if block.settings.show_variants_as_products %}
                  {%- assign total_items = 0 -%}
                  {% for product in collection.products %}
                    {% if product.has_only_default_variant %}
                      {%- assign total_items = total_items | plus: 1 -%}
                    {% else %}
                      {%- assign total_items = total_items | plus: product.variants.size -%}
                    {% endif %}
                  {% endfor %}
                  
                  {% if total_items > 8 %}
                    <div class="load-more-wrapper">
                      <a href="#" class="product-form__submit button--ctm_wb_global_button ctm-bundle-load-more">Load More</a>
                    </div>
                  {% endif %}
                {% else %}
                  {% if collection.products.size > 8 %}
                    <div class="load-more-wrapper">
                      <a href="#" class="product-form__submit button--ctm_wb_global_button ctm-bundle-load-more">Load More</a>
                    </div>
                  {% endif %}
                {% endif %}
              </div>
            {% endif %}
          {%- endfor -%}
        </div>
      </div>
    {% else %}
      <p class="no-collections">No collections selected yet.</p>
    {% endif %}
  </div>
</section>

