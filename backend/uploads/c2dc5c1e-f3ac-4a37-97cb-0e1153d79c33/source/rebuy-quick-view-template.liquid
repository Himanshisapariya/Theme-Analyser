<script>

  document.addEventListener('DOMContentLoaded', function () {
  const initRebuyFaqSwiper = () => {
    try {
      const el = document.querySelector('.rebuy-faq-swiper');

      if (el && !el.classList.contains('swiper-initialized') && typeof Swiper !== 'undefined') {
        new Swiper('.rebuy-faq-swiper', {
          slidesPerView: 1.2,
          spaceBetween: 16,
          grabCursor: true,
          scrollbar: {
            el: '.rebuy-faq-swiper .swiper-scrollbar',
            hide: false,
            draggable: true,
          },
          breakpoints: {
            640: { slidesPerView: 1.5, spaceBetween: 16 },
            900: { slidesPerView: 2, spaceBetween: 16 },
            1100: { slidesPerView: 2.3, spaceBetween: 16 },
          },
          on: {
            init: function() {
              console.log('Rebuy FAQ Swiper initialized successfully');
            }
          }
        });
      }
    } catch (error) {
      console.error('Error initializing Rebuy FAQ Swiper:', error);
    }
  };

  const initRebuyColorSwatchSwipers = () => {
    try {
      const swatchContainers = document.querySelectorAll('.rebuy-swatch-swiper');
      
      swatchContainers.forEach(container => {
        if (container && !container.classList.contains('swiper-initialized') && typeof Swiper !== 'undefined') {
          new Swiper(container, {
            slidesPerView: 'auto',
            spaceBetween: 2,
            nested: true,
            observeParents: true,
            on: {
              init: function() {
                console.log('Rebuy Color Swatch Swiper initialized successfully');
              }
            }
          });
        }
      });
    } catch (error) {
      console.error('Error initializing Rebuy Color Swatch Swipers:', error);
    }
  };

  // Initial initialization
  setTimeout(() => {
    initRebuyFaqSwiper();
    initRebuyColorSwatchSwipers();
  }, 500);

  // Watch for DOM changes
  const observer = new MutationObserver((mutations) => {
    let shouldReinit = false;
    
    mutations.forEach((mutation) => {
      if (mutation.addedNodes.length > 0) {
        mutation.addedNodes.forEach((node) => {
          if (node.nodeType === 1) { // Element node
            if (node.classList && node.classList.contains('rebuy-faq-swiper')) {
              shouldReinit = true;
            }
            if (node.querySelector && node.querySelector('.rebuy-faq-swiper, .rebuy-swatch-swiper')) {
              shouldReinit = true;
            }
          }
        });
      }
    });
    
    if (shouldReinit) {
      setTimeout(() => {
        initRebuyFaqSwiper();
        initRebuyColorSwatchSwipers();
      }, 100);
    }
  });

  observer.observe(document.body, { 
    childList: true, 
    subtree: true,
    attributes: false,
    characterData: false
  });

  // Also initialize when Rebuy quick view opens
  document.addEventListener('click', function(e) {
    if (e.target.closest('[data-rebuy-quick-view]') || e.target.closest('.rebuy-quick-view-trigger')) {
      setTimeout(() => {
        initRebuyFaqSwiper();
        initRebuyColorSwatchSwipers();
      }, 1000);
    }
  });
});

// Product image click function for color swatches
window.changeProductImageOnClick = function(event, variant) {
  if (!event || !variant) return;

  // Walk up from clicked label to find the closest product card
  const productCard = event.target.closest('[id^="rebuy-quick-view-product-id-"]');
  if (!productCard) return;

  const productImage = productCard.querySelector('img.rebuy-quick-view_image');
  if (!productImage) return;

  // Save current src only once per click session
  if (!productImage.dataset.originalSrc) {
    productImage.dataset.originalSrc = productImage.src;
    productImage.dataset.originalSrcset = productImage.srcset;
  }

  if (variant.images && variant.images[0]) {
    // Use the same image URL format as Vue.js - just the raw URL without extra parameters
    const newUrl = variant.images[0].url;
    productImage.src = newUrl;
    productImage.srcset = newUrl;
    console.log('Image changed to:', newUrl);
  }
};

// Product image hover functions for color swatches
window.changeProductImageOnHover = function(event, variant) {
  if (!event || !variant) return;

  // Walk up from hovered label to find the closest product card
  const productCard = event.target.closest('[id^="rebuy-quick-view-product-id-"]');
  if (!productCard) return;

  const productImage = productCard.querySelector('img.rebuy-quick-view_image');
  if (!productImage) return;

  // Save current src only once per hover session
  if (!productImage.dataset.originalSrc) {
    productImage.dataset.originalSrc = productImage.src;
    productImage.dataset.originalSrcset = productImage.srcset;
  }

  if (variant.images && variant.images[0]) {
    const newUrl = variant.images[0].url.split('?')[0] + '?width=600&height=600&crop=center';
    productImage.src = newUrl;
    productImage.setAttribute('src', newUrl);
