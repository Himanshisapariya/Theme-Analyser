window.restoreProductImageOnLeave = function(event) {
  if (!event) return;

  const productCard = event.target.closest('[id^="rebuy-quick-view-product-id-"]');
  if (!productCard) return;

  const productImage = productCard.querySelector('img.rebuy-quick-view_image');
  if (!productImage || !productImage.dataset.originalSrc) return;

  productImage.src = productImage.dataset.originalSrc;
  productImage.setAttribute('src', productImage.dataset.originalSrc);
  productImage.srcset = productImage.dataset.originalSrcset || productImage.dataset.originalSrc;

  delete productImage.dataset.originalSrc;
  delete productImage.dataset.originalSrcset;
};

// Helper functions for color variants
window.getColorVariants = function(product) {
  if (!product || !product.variants) return [];
  
  const colorVariants = [];
  const seenColors = new Set();
  
  product.variants.forEach(variant => {
    if (variant.options && variant.options.length > 0) {
      const colorValue = variant.options[0];
      const colorKey = colorValue.toLowerCase();
      
      if (!seenColors.has(colorKey)) {
        seenColors.add(colorKey);
        colorVariants.push(variant);
      }
    }
  });
  
  return colorVariants;
};

window.getColorValue = function(variant) {
  if (!variant || !variant.options || variant.options.length === 0) return '';
  return variant.options[0];
};

window.changeSearchResultImageOnClick = function(event, variant) {
  if (!event || !variant) return;

  const productCard = event.target.closest('[id^="rebuy-product-id-"]');
  if (!productCard) return;

  const productImage = productCard.querySelector('img.rebuy-smart-search-results-page__product-image');
  if (!productImage) return;

  if (!productImage.dataset.originalSrc) {
    productImage.dataset.originalSrc = productImage.src;
    productImage.dataset.originalSrcset = productImage.srcset;
  }

  if (variant.images && variant.images[0]) {
    const newUrl = variant.images[0].url;
    productImage.src = newUrl;
    productImage.srcset = newUrl;
  }
};

window.getColorSwatchUrl = function(variant) {
  // Try to get featured image first
  if (variant.featured_image && variant.featured_image.url) {
    return variant.featured_image.url;
  }
  
  // Fallback to product image
  if (variant.product && variant.product.featured_image) {
    return variant.product.featured_image;
  }
  
  // Return default swatch pattern or empty string
  return '';
};
