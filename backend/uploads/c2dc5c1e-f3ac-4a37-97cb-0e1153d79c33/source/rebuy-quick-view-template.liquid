                                                            <div class="rebuy-swatch-swiper swiper">
                                                                <fieldset class="rebuy-product-form__controls-group swiper-wrapper">
                                                                    <legend class="visually-hidden">Color Swatches</legend>
                                                                    <div 
                                                                        v-for="(variant, index) in (product.variants.filter((v, i, arr) => v && v.name && arr.findIndex(x => x && x.name && x.name.split(' / ')[0] === v.name.split(' / ')[0]) === i))"
                                                                        :key="variant.id"
                                                                        class="swiper-slide"
                                                                    >
                                                                        <input
                                                                            type="radio"
                                                                            :id="'rebuy-' + product.id + '-color-' + index"
                                                                            :name="'rebuy-color-' + product.id"
                                                                            :value="variant.id"
                                                                            v-model="product.selected_variant_id"
                                                                            v-on:change="selectVariant(product)"
                                                                            class="rebuy-color-swatch-input"
                                                                            :disabled="!variantAvailable(variant)"
                                                                        >
                                                                        <label
                                                                            :for="'rebuy-' + product.id + '-color-' + index"
