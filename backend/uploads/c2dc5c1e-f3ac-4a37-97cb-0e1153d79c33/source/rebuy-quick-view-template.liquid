{% comment %}Build a JS map of color-name handle → CDN swatch image URL from theme settings{% endcomment %}
<script>
  window.rebuyColorSwatchMap = {
    {% if settings.custom_colors != blank %}
      {% assign custom_colors_arr = settings.custom_colors | newline_to_br | split: '<br />' %}
      {% for line in custom_colors_arr %}
        {% assign line_strip = line | strip %}
        {% if line_strip != blank %}
          {% assign color_name_part = line_strip | split: ':' | first %}
          {% assign color_key = color_name_part | handle | strip %}
          {% assign color_url = line_strip | remove_first: color_name_part | remove_first: ':' | strip %}
          "{{ color_key }}": "{{ color_url }}",
        {% endif %}
      {% endfor %}
    {% endif %}
  };

  // Convert a color display name to its Shopify handle equivalent, then look up the swatch image URL.
  window.getRebuyColorSwatchUrl = function(colorName) {
    if (!colorName) return '';
    var handle = colorName
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '');
    return window.rebuyColorSwatchMap[handle] || '';
  };
</script>

{% raw %}

<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">

<style>

  .rebuy-quick-view__no-results p {
    color: rgb(var(--color-foreground));
    font-size: unset;
    font-weight: normal;
    font-style: normal;
}

.rebuy-quick-view-flyout__flyout {
  margin-top: 0;    
}

.rebuy-quick-view__search-term-section,
.rebuy-quick-view__no-results{
    padding: 1rem;
    margin-bottom: 0;
}

  /* ===== Rebuy FAQ Section — scoped styles ===== */

  .rebuy-faq-section *,
  .rebuy-faq-section *::before,
  .rebuy-faq-section *::after {
    box-sizing: border-box;
  }

  .rebuy-faq-section {
    padding: 1rem;
    margin: 0 auto;
  }

  .rebuy-quick-view__list-item {
    padding: 5px 15px;
    border: 1px solid #2f484c;
    border-radius: 30px;
    margin: 5px 0;
}

  /* Header */
  .rebuy-faq-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
  }

  .rebuy-faq-header h2 {
    letter-spacing: -0.3px;
    color: rgba(var(--color-foreground));
  }

  /* Show All button */
  .rebuy-faq-show-all-btn {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(var(--color-foreground));
    border: none;
    border-bottom: 1.5px solid rgba(var(--color-foreground));
    padding: 0 0 2px;
    cursor: pointer;
    background: none;
  }

  /* Swiper — scoped, no global .faq-swiper */
  .rebuy-faq-section .rebuy-faq-swiper {
    width: 100%;
    overflow: hidden;
  }

  .rebuy-faq-section .swiper-slide {
    height: auto;
  }

  /* Card */
  .rebuy-faq-card {
    border: 1px solid #d8d8d8;
    padding: 28px 24px 32px;
    height: 100%;
    display: flex;
    flex-direction: column;
    background: #fff;
    min-height: 190px;
    text-align: left;
  }

  .rebuy-faq-card h5 {
    line-height: 1.4;
    color: rgba(var(--color-foreground));
  }

  .rebuy-faq-card p {
    line-height: 1.65;
    color: rgba(var(--color-foreground), 0.75);
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Read more */
  .rebuy-faq-read-more {
    color: rgba(var(--color-foreground));
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    align-self: flex-start;
    margin-top: 4px;
    transition: opacity 0.2s ease;
  }

  .rebuy-faq-read-more:hover {
    opacity: 0.6;
  }

.rebuy-faq-section .swiper-scrollbar {
    display: block !important;
    position: relative;
    left: 50%;
    bottom: 0;
    margin: 30px 0;
    transform: translateX(-50%);
    background: #E8E8E9;
    border-radius: 3px;
    height: 3px;
    width: 250px;
}

.rebuy-faq-section .swiper-scrollbar-drag {
    cursor: pointer;
    background: #2f484c;
    border-radius: 3px;
}

@media (max-width: 749px) {
    .rebuy-faq-section .swiper-scrollbar {
        left: 40%;
    }
    .rebuy-faq-section .swiper-scrollbar {
        margin: 30px auto;
    }
}

/* Rebuy Color Swatches */

.rebuy-color-swatch {
    position: relative;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid transparent;
    cursor: pointer;
    padding: 0;
    background: transparent;
    transition: all 0.2s ease;
    overflow: hidden;
}

.rebuy-color-swatch:hover {
    border-color: transparent;
}

.rebuy-color-swatch.is-selected {
    border-color: #2f484c;
    box-shadow: 0 0 0 2px rgba(47, 72, 76, 0.2);
}

.rebuy-color-swatch.is-unavailable {
    opacity: 0.4;
    cursor: not-allowed;
}

.rebuy-color-swatch.is-unavailable:hover {
    transform: none;
    border-color: #e5e5e5;
}

/* Fallback for when no background image is available */
.rebuy-swatch-inner:not([style*="url"]) {
    background: var(--swatch-bg, #f0f0f0);
}

/* Color Swatches Styles for Rebuy Quick View */
.rebuy-color-swatches {
  max-width: 250px;
  overflow-x: auto;
  overflow-y: hidden;
  scrollbar-width: thin;
  scrollbar-color: #ddd transparent;
}

.rebuy-color-swatches::-webkit-scrollbar {
  height: 4px;
}

.rebuy-color-swatches::-webkit-scrollbar-track {
  background: transparent;
}

.rebuy-swatch-swiper {
  width: 100%;
  overflow: hidden;
}

.rebuy-product-form__controls-group {
  display: flex;
  flex-wrap: nowrap;
  gap: 2px;
  margin: 0;
  padding: 0;
  border: none;
}

.rebuy-color-swatch-input {
  position: absolute;
  opacity: 0;
  pointer-events: none;
}

.rebuy-color-swatch {
  display: inline-block;
  padding: 0;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  cursor: pointer;
  transition: 0.3s all ease-in-out;
  position: relative;
  background-color: #fff;
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  box-shadow: inset 0 0 0 1px rgba(0,0,0,0.1);
}

.rebuy-color-swatch:after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 26px;
  height: 26px;
  border-radius: 50%;
  transform: translate(-50%, -50%);
  background-image: var(--swatch-color);
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
}

.rebuy-color-swatch-input:checked + .rebuy-color-swatch {
  border-color: #28b473 !important;
}

.rebuy-color-swatch-input:disabled + .rebuy-color-swatch {
  opacity: 0.5;
  cursor: not-allowed;
}

.rebuy-color-swatch-input:disabled + .rebuy-color-swatch:hover {
  border-color: #DDDDDD !important;
}

@media (max-width: 425px) {
  .rebuy-color-swatch:after {
    width: 20px;
    height: 20px;
  }
  
  .rebuy-color-swatch {
    width: 26px;
    height: 26px;
  }
}

@media (max-width: 575px) {
  .rebuy-color-swatch:after {
    width: 24px;
    height: 24px;
  }
  
  .rebuy-color-swatch {
    width: 30px;
    height: 30px;
  }
  .rebuy-color-swatches {
    max-width: 150px;
  }
}

/* Hide add to cart buttons */
.rebuy-quick-view__product-cta {
  display: none !important;
}

.rebuy-smart-search-results-page__cta {
  display: none !important;
}

/* Disable all zoom on product images in search flyout */
.rebuy-smart-search__absolute-image--zoomed {
  transform: none !important;
  transition: none !important;
}

.rebuy-smart-search__absolute-image-container:hover .rebuy-smart-search__absolute-image--zoomed,
.rebuy-smart-search__absolute-image-container:focus .rebuy-smart-search__absolute-image--zoomed {
  transform: none !important;
  transition: none !important;
}


/* Search button styling */
.rebuy-quick-view__search-input {
    display: flex;
    align-items: center;
    position: relative;
}

.rebuy-quick-view__search-input input {
    flex: 1;
    padding-right: 40px;
}

.rebuy-quick-view__search-button {
    position: absolute;
    right: 5px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.rebuy-quick-view__search-button:hover {
    opacity: 0.7;
}

.rebuy-quick-view__search-button rebuy-icon {
    width: 20px;
    height: 20px;
}

.rebuy-quick-view__results {
    gap: 10px;
}
</style>

<script id="rebuy-quick-view-flyout-search-template" type="text/template">
    <div
        id="rebuy-quick-view-flyout-search"
        class="rebuy-quick-view-sidebar"
        :class="{ 'is-visible': isQuickViewOpen }"
        role="dialog"
        aria-modal="true"
        :aria-hidden="!isQuickViewOpen ? 'true' : 'false'"
    >
        <div class="rebuy-quick-view-flyout__flyout" :class="[{ 'is-visible': isQuickViewOpen }, flyoutModeSide]">
            <div class="rebuy-quick-view__container rebuy-quick-view-flyout__flyout-container">
                <div class="rebuy-quick-view__search-header rebuy-quick-view-flyout__search-header">
                    <button
                        type="button"
                        class="rebuy-quick-view__close-button"
                        @click.stop="closeQuickView"
                        aria-label="Close Cart"
                    >
                        <rebuy-icon name="x"></rebuy-icon>
                    </button>

                    <form
                        class="rebuy-quick-view__search-input rebuy-quick-view-flyout__search-input rebuy-input"
                        @submit.stop.prevent="goToSearchPage"
                        >
                        <label v-if="searchByCollectionsEnabled" for="search" class="sr-only">Search by Collections</label>
                        <select
                            v-if="searchByCollectionsEnabled"
                            name="search"
                            id="search"
                            v-model="searchByCollection"
                        >
                            <option :value="SEARCH_BY_COLLECTION_DEFAULT">All</option>
                            <option v-for="{ name, id } in searchByCollectionsCollections" :value="id">{{name}}</option>
                        </select>

                        <label for="searchInput" class="sr-only">Enter a Search Term</label>
                        <input
                            id="searchInput"
                            :class="(searchByCollectionsEnabled)"
                            type="text"
                            :placeholder="placeholderText()"
                            :value="searchTerm"
                            @input="($event) => searchTerm = $event.target.value"
                            ref="searchInput"
                            @keydown.escape.stop.prevent="closeQuickView"
                        />
                        <button type="submit" class="rebuy-quick-view__search-button" aria-label="Search">
                            <rebuy-icon name="search"></rebuy-icon>
                        </button>
                    </form>
                </div>

                <div class="rebuy-quick-view__body gts rebuy-quick-view-flyout__body">
                    <!-- Before User Types and No Results Suggestions -->
                    <div v-if="!showResults" class="rebuy-quick-view__suggestions-vertical">

                        <div
                            v-if="showNoResultsSuggestions"
                            class="rebuy-quick-view__no-results"
                        >
                            <p class="m-0" v-html="noResultsPageTitle"></p>
                        </div>

                        <div
                            v-if="suggestedCollectionsEnabled && suggestedCollections.length > 0"
                            class="rebuy-quick-view__collection-section"
                        >
                            <h6 class="rebuy-quick-view__subject-title">{{suggestedCollectionsTitle}}</h6>

                            <div class="rebuy-quick-view__collection-list">
                                <a
                                    v-for="collection in displayedSuggestedCollections"
                                    class="rebuy-quick-view__collection"
                                    :href="collectionHref(collection)"
                                >
                                    {{collection.name}}
                                </a>

                                <button
                                    v-if="shouldShowSeeMoreCollections"
                                    class="see-more"
                                    @click.stop.prevent="seeMore"
                                >
                                    See more &mldr;
                                </button>
                            </div>
                        </div>

                        <div
                            v-if="suggestedSearchTermsEnabled && suggestedTerms.length > 0"
                            class="rebuy-quick-view__search-term-section gts"
                        >
                            <h6 class="rebuy-quick-view__subject-title">{{suggestedSearchTermsTitle}}</h6>

                            <ul class="rebuy-quick-view__list-items">
                                <li
                                    class="rebuy-quick-view__list-item"
                                    v-for="term in suggestedTerms"
                                    @click.stop="search(term)"
                                >
                                    {{term}}
                                </li>
                            </ul>
                        </div>

                        <div
                            v-if="suggestedProductsEnabled && suggestedProducts.length > 0"
                            class="rebuy-quick-view__product-section"
                        >
                            <h6 class="rebuy-quick-view__subject-title">{{suggestedProductsTitle}}</h6>

                            <div
                                class="rebuy-quick-view__product-list rebuy-quick-view-flyout__product-list"
                                :class="productListColumnClass"
                            >
                                <div
                                    v-for="(product, index) in suggestedProducts"
                                    :class="[productDisplayType, 'rebuy-quick-view-product-id-' + product.productId]"
                                    :id="'rebuy-quick-view-product-id-' + product.productId"
                                >
                                    <a
                                        :href="learnMoreURL(product)"
                                        @click="learnMore(product, index)"
                                        class="rebuy-quick-view__image-link rebuy-smart-search__absolute-image-container"
                                        :class="shouldPositionAbsolute('container')"
                                        :style="productImageRatio()"
                                        rel="nofollow"
                                    >
                                        <img
                                            v-bind:src="productImage(product, product.selected_variant)"
                                            v-bind:srcset="generateImgSrcset(product)"
                                            v-bind:alt="'Image of ' + product.name"
                                            class="rebuy-quick-view_image rebuy-smart-search__absolute-image--zoomed rebuy-smart-search__absolute-image"
                                            :class="shouldPositionAbsolute('image')"
                                        />
                                    </a>

                                    <div class="rebuy-quick-view__product-detail">
                                        <div class="rebuy-product-info">
                                            <!-- Product Title -->
                                            <a
                                                class="rebuy-product-title"
                                                :class="productInfoClass"
                                                :href="learnMoreURL(product)"
                                                @click="learnMore(product, index)"
                                                rel="nofollow"
                                            >
                                                {{product.name}}
                                            </a>

                                            <!-- Product Review -->
                                            <div
                                                class="rebuy-product-review"
                                                :class="productInfoClass"
                                                v-if="shouldDisplayQuickViewProductRating(product)"
                                                aria-label="product star rating"
                                            >
                                                <span class="rebuy-star-rating" :style="{ width: starRatingSize.width + 'px', height: starRatingSize.height + 'px' }">
                                                    <span
                                                        v-if="product.reviews.star_rating"
                                                        class="rebuy-star-rating-value sr-only"
                                                        v-html="product.ratings.average + ' stars out of 5 stars'"
                                                    >
                                                    </span>

                                                    <!-- Default star rating (no custom colors) -->
                                                    <template v-if="!shouldDisplayStyledProductReviews">
                                                        <span class="rebuy-star-rating-background"></span>
                                                        <span class="rebuy-star-rating-foreground" v-bind:style="{ width: getProductReviewRatingPercentage(product) }"></span>
                                                    </template>

                                                    <!-- Styled star rating with custom colors -->
