{%- style -%}
  .shipping-bar-container {
    margin-block: 10px;
  }

  .js .shipping-bar-container.shipping-bar--hidden {
    display: none;
  }
  

  .shipping-bar {
    background: none;
    background-color: none;
    padding: 0;
    box-shadow: none;
    text-align: left;
  }

  .shipping-bar .h5 {
    font-weight: 500;
    margin: 0 0 6px;
    color: rgb(var(--color-foreground));
    font-family: 'Figtree';
    letter-spacing: 0;
  }

  .progress {
    width: 100%;
    height: 6px;
    background: rgba(var(--color-foreground), 0.15);
    border-radius: 999px;
    overflow: hidden;
  }

  .progress-bar {
    height: 100%;
    background: green;
    border-radius: 999px;
    transition: width 0.4s ease;
  }

  .shipping-bar--success .progress {
    opacity: 1;
  }

  .shipping-bar--success .progress-bar {
    width: 100% !important;
    background: green;
  }

  .shipping-bar--success .h5 {
    color: green;
  }

  .shipping-bar--success .h5 {
    color: green;
  }

{%- endstyle -%}

{%- liquid
  assign free_shipping_threshold = settings.threshold | times: 100
  assign current_cart_total = cart.total_price
-%}

{%- liquid
  assign free_shipping_threshold = settings.threshold | times: 100
  assign current_cart_total = cart.total_price
  assign remaining_amount = free_shipping_threshold | minus: current_cart_total
  assign progress_percentage = current_cart_total | times: 100 | divided_by: free_shipping_threshold
-%}

<div
  class="shipping-bar-container{% if cart.item_count == 0 %} shipping-bar--hidden{% endif %}"
  data-threshold="{{ free_shipping_threshold }}"
>
  {% if cart.item_count > 0 %}
    <div class="shipping-bar{% if current_cart_total >= free_shipping_threshold %} shipping-bar--success{% else %} shipping-bar--progress{% endif %}">
      <span class="" data-free-shipping-message>
        {% if current_cart_total >= free_shipping_threshold %}
          Your order qualifies for free shipping!
        {% else %}
          Add {{ remaining_amount | money }} more for free shipping
        {% endif %}
      </span>

      <div
        class="progress"
        role="progressbar"
        aria-label="Free shipping progress"
        aria-valuemin="0"
        aria-valuemax="100"
        aria-valuenow="{% if current_cart_total >= free_shipping_threshold %}100{% else %}{{ progress_percentage }}{% endif %}"
        aria-busy="false"
      >
        <div
          class="progress-bar"
          data-progress-bar
          style="width: {% if current_cart_total >= free_shipping_threshold %}100{% else %}{{ progress_percentage }}{% endif %}%"
        ></div>
      </div>
    </div>
  {% endif %}
</div>

<script>
  (function () {
    class ShippingBar {
      constructor() {
        this.container = document.querySelector('.shipping-bar-container');
        if (!this.container) return;

        this.threshold = parseInt(this.container.dataset.threshold, 10);

        this.bar = this.container.querySelector('.shipping-bar');
        this.message = this.container.querySelector('[data-free-shipping-message]');
        this.progressWrap = this.container.querySelector('.progress');
        this.progress = this.container.querySelector('.progress-bar');

        this.init();
      }

      init() {
        this.updateFromCart();
        this.hookFetch();
        this.setupCartRefreshListener();
      }

      hookFetch() {
        const originalFetch = window.fetch;
        if (window.__shippingBarFetchHooked) return;
        window.__shippingBarFetchHooked = true;

        window.fetch = async (...args) => {
          const response = await originalFetch(...args);
          const url = args[0]?.url || args[0];

          if (typeof url === 'string' && url.includes('/cart/')) {
            response
              .clone()
              .json()
              .then((cart) => {
                if (typeof cart.total_price === 'number') {
                  this.update(cart);
                } else {
                  this.updateFromCart();
                }
              });
          }

          return response;
        };
      }

      setupCartRefreshListener() {
        let _refreshTimer = null;
        document.addEventListener('cart:refresh', () => {
          clearTimeout(_refreshTimer);
          _refreshTimer = setTimeout(() => this.updateFromCart(), 350);
        });
        document.addEventListener('gwp:cart-updated', (e) => {
          if (e.detail?.cart) {
            clearTimeout(_refreshTimer);
            this.update(e.detail.cart);
          }
        });
      }

      async updateFromCart() {
        this.progressWrap.setAttribute('aria-busy', 'true');
        const res = await fetch('/cart.js');
        const cart = await res.json();
        this.update(cart);
      }

      update(cart) {
        if (!cart || cart.item_count === 0) {
          this.container.classList.add('shipping-bar--hidden');
          return;
        }

        this.container.classList.remove('shipping-bar--hidden');

        const cartTotal = typeof cart.total_price === 'number' && !isNaN(cart.total_price) ? cart.total_price : 0;
        
        if (cartTotal >= this.threshold) {
          this.bar.classList.add('shipping-bar--success');
          this.bar.classList.remove('shipping-bar--progress');

          this.message.textContent = 'Your order qualifies for free shipping!';

          this.progressWrap.style.display = 'block';
          this.progressWrap.setAttribute('aria-valuenow', '100');
          this.progressWrap.setAttribute('aria-busy', 'false');
          this.progress.style.width = '100%';

          return;
        }

        const remaining = this.threshold - cartTotal;
        const percent = Math.min((cartTotal / this.threshold) * 100, 100);

        this.bar.classList.remove('shipping-bar--success');
        this.bar.classList.add('shipping-bar--progress');

        this.message.textContent = `Add ${this.money(remaining)} more for free shipping`;
        this.progressWrap.style.display = 'block';
        this.progressWrap.setAttribute('aria-valuenow', Math.round(percent).toString());
        this.progressWrap.setAttribute('aria-busy', 'false');
        this.progress.style.width = `${percent}%`;
      }

      money(cents) {
        const validCents = typeof cents === 'number' && !isNaN(cents) ? cents : 0;
        return (validCents / 100).toLocaleString('en-AU', {
          style: 'currency',
          currency: 'AUD',
        });
      }
    }

    document.addEventListener('DOMContentLoaded', () => {
      new ShippingBar();
    });
  })();
</script>
