<script>
document.addEventListener("DOMContentLoaded", function () {
  const popup = document.querySelector(".size-chart-popup");
  const openBtn = document.querySelector(".size-chart-button");
  const closeBtn = document.querySelector(".close-popup");

  if (openBtn && popup && closeBtn) {
    openBtn.addEventListener("click", function () {
      popup.style.display = "block";
      document.body.classList.add("ctm-size-chart");
    });

    closeBtn.addEventListener("click", function () {
      popup.style.display = "none";
      document.body.classList.remove("ctm-size-chart");
    });

    window.addEventListener("click", function (event) {
      if (event.target === popup) {
        popup.style.display = "none";
        document.body.classList.remove("ctm-size-chart");
      }
    });
  }
});
</script>
<style>
.size-chart-popup {
  display: none;
  position: fixed;
  z-index: 9999;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  overflow: auto;
  background-color: rgba(0, 0, 0, 0.6);
}

.size-chart-popup-content {
  background: #fff;
  margin: 120px auto 5%; 
  padding: 20px;
  border-radius: 8px;
  width: 90%;
  max-width: 600px;
  box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
  position: relative;
  animation: popupFadeIn 0.3s ease;
  z-index: 10000; 
}

button.button.button--rebuy.button--link.size-chart-button {
    border: none;
    background-color: transparent;
}

.close-popup {
  position: absolute;
  top: 12px;
  right: 15px;
  font-size: 24px;
  font-weight: bold;
  color: #333;
  cursor: pointer;
  transition: color 0.2s ease;
}

.close-popup:hover {
  color: #000;
}

body.ctm-size-chart {
  overflow: hidden !important;
}

body.ctm-size-chart .shopify-section-header {
  z-index: 2;
}

.size-chart-popup-content h3 {
  margin:15px 0;
  text-align: center;
  -webkit-text-size-adjust: 100%;
}

@media (max-width: 1024px) {
  .size-chart-popup-content h3 {
      font-size: 28px;
  }
}

@media (max-width: 575px) {
    .size-chart-popup-content h3 {
        font-size: 26px;
    }
}


@keyframes popupFadeIn {
  from { opacity: 0; transform: translateY(-20px); }
  to { opacity: 1; transform: translateY(0); }
}

</style>