{{ 'section-image-with-text.css' | asset_url | stylesheet_tag }}
{{ 'spring-page-layout.css' | asset_url | stylesheet_tag }}

{% style %}
	{% render 'spaced-section' %}
{% endstyle %}

{%- style -%}
  .image-with-text.section-{{ section.id }} {
  	padding-top: {{ section.settings.top_padding_desktop }}px;
  	padding-bottom: {{ section.settings.bottom_padding_desktop }}px;
  }

  @media screen and (max-width: 990px) {
  	.image-with-text.section-{{ section.id }} {
  		padding-top: {{ section.settings.top_padding_mobile }}px;
  		padding-bottom: {{ section.settings.bottom_padding_mobile }}px;
  	}
  }
.image-with-text.section-{{ section.id }} {
  	margin-top: {{ section.settings.top_margin_desktop}}px;
  	margin-bottom: {{ section.settings.bottom_margin_desktop }}px;
  }

  @media screen and (max-width: 990px) {
  	.image-with-text.section-{{ section.id }} {
  		margin-top: {{ section.settings.top_margin_mobile }}px;
  		margin-bottom: {{ section.settings.bottom_margin_mobile }}px;
  	}
  }
{%- endstyle -%}

<div class="image-with-text section-{{ section.id }} {{ section.settings.image_size }} image-text-{{ section.settings.row-reverse }} {{ section.settings.lookbook_detail_class }}">
	{% liquid
	assign image_size = section.settings.image_size

	case image_size
		when 'adapt'
			assign section_size = 'adapt'
		when 'small'
			assign section_size = '30vh'
		when 'medium'
			assign section_size = '60vh'
		when 'large'
			assign section_size = 'calc(100vh - var(--header-height) - var(--announcement-height))'
		else
			assign section_size = 'calc(100vh - var(--header-height) - var(--announcement-height))'
	endcase
%}
	{% liquid
				assign image_height = section.settings.image.width | divided_by: section.settings.image.aspect_ratio
				assign adapt_height = 0.6 | divided_by: section.settings.image.aspect_ratio | times: 85.7 | append: '%'
				assign underline_color = section.settings.underline_color | default: '#000000'

				if image_size == 'adapt'
					assign section_size = adapt_height
				endif
			%}
			{% style %}
				.image-with-text {
					--slide-height : {{ section_size }};
				}
			{% endstyle %}
{% if section.settings.show_frame %}<div class="frame-true color-{{ section.settings.color_scheme }}">{% endif %}
		<div class="image-with-text__image color-{{ section.settings.color_scheme }} {% if section.settings.show_frame %} image-with-text__image--frame {% endif %}">
			
			{%- if section.settings.image != blank -%}
        				{{
					section.settings.image
					| image_url: width: auto
					| image_tag:
						loading: 'lazy',
						widths: auto,
						class: 'motion-reduce',
						width: auto,
						height: auto
				}}
				{% if section.settings.show_frame == false %}
          {%- if section.settings.frame-text != blank -%}

					<span
						class="frame-text-second">
						{{- section.settings['frame-text'] -}}
					</span>
          {% endif %}
          {%- if section.settings.frame-text-right != blank -%}
					<span
						class="frame-text-second"
					>
						{{- section.settings['frame-text-right'] -}}
					</span>
          {% endif %}
				{% endif %}
			{% else %}
			{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
		
			{%- endif -%}
      {% if section.settings.mobile_image != blank %}
        {{
					section.settings.mobile_image
					| image_url: width: auto
					| image_tag:
						loading: 'lazy',
						widths: auto,
						class: 'motion-reduce mobile-image',
						width: auto,
						height: auto,
            alt: section.settings.mobile_image.alt
				}}
      {% endif %}
		</div>
		{% if section.settings.show_frame %}
		<div class="frame-text-container">
			<span
				class="frame-text color-{{ section.settings.color_scheme }}"
			>
				{{- section.settings['frame-text'] -}}
			</span>
			<span
			class="frame-text color-{{ section.settings.color_scheme }}"
			>
				{{- section.settings['frame-text-right'] -}}
			</span>
		</div>
		{% endif %}
	{% if section.settings.show_frame %}</div>{% endif %}

	<div class="image-with-text__content image-with-text__content color-{{ section.settings.color_scheme_2 }}">
		{% if section.settings.subheading_left_top != blank or section.settings.subheading_right_top != blank %}
		<div class="image-with-text__content-top">
			<span>{{ section.settings.subheading_left_top }}</span>
			<span>{{ section.settings.subheading_right_top }}</span>
		</div>
	{% endif %}

		<div class="image-with-text__content-item">
			{{ section.settings.heading }}
        {% if section.settings.second_image != blank %}
          {% if section.settings.lookbook_detail_class == 'lookbook-detail-section' %}
              <img src="{{ section.settings.second_image | image_url: width: auto }}" />
          {% else %}
              <img src="{{ section.settings.second_image | image_url: width: 300 }}" />
          {% endif %}
        {% endif %}
        {% if section.settings.subheading != blank %}
			<div class="h6 ctm-img-subheading">{{ section.settings.subheading }}</div>
        {% endif %}
      {% if section.settings.desc != blank %}
			<div class="h6 ctm-img-desc">{{ section.settings.desc }}</div>
        {% endif %}
			{%- if section.settings.signatureimage != blank or section.settings.signatureimage_2 != blank -%}
        <div class="signature-image">
          {%- if section.settings.signatureimage_2 != blank -%}
            {{
              section.settings.signatureimage_2
              | image_url: width: 300
              | image_tag:
                loading: 'lazy',
                widths: '150, 300',
                class: 'motion-reduce image-with-text-img-dark',
                width: section.settings.signatureimage_2.width,
                height: image_height
            }}
          {% endif %}
          {%- if section.settings.signatureimage != blank -%}
              {{
                section.settings.signatureimage
                | image_url: width: 300
                | image_tag:
                  loading: 'lazy',
                  widths: '150, 300',
                  class: 'motion-reduce image-with-text-img-light',
                  width: section.settings.signatureimage.width,
                  height: image_height
              }}
          {% endif %}
        </div>
			{% endif %}

			{% if section.settings.button_text != blank %}
				<a
					{% if section.settings.button_link.url != blank %}
						href="{{ section.settings.button_link }}"
					{% endif %}
					type="button"
					{% if section.settings.button_link.url == blank %}
						aria-disabled="true"
					{% endif %}
					class="button {% if section.settings.button_style == 'link' %} button--rebuy {% else %} ctm_img_txtbtn {% endif %} button--{{ section.settings.button_style }}"
				>
					{{ section.settings.button_text }}
				</a>
		{% endif %}
		</div>
		{% if section.settings.subheading_left_bottom != blank or section.settings.subheading_right_bottom != blank %}
			<div class="image-with-text__content-bottom">
				<span>
					{{- section.settings.subheading_left_bottom -}}
				</span>
				<span>
					{{- section.settings.subheading_right_bottom -}}
				</span>
			</div>
		{% endif %}
	</div>
</div>
<div class="size-chart-popup" style="display: none;">
  <div class="size-chart-popup-content">
    <span class="close-popup">&times;</span>
    <h3>Size Chart</h3>
    {% render 'size-chart-w-bottoms' %}
  </div>
</div>
{%  style  %}  
.button.button--link.ctm_img_txtbtn {
	position: relative;
	color: inherit;
}
.button.button--link.ctm_img_txtbtn::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: -8px;
  height: 2px;
  width: 100%;
  background: {{ underline_color }};
  transition: width 0.3s ease;
}
.button.button--link.ctm_img_txtbtn:hover::after {
    width: 0;
}
{% endstyle %} 

