{{ 'section-featured-blog.css' | asset_url | stylesheet_tag }}
{{ 'component-article-card.css' | asset_url | stylesheet_tag }}
{% style %}
  {% render 'spaced-section' %}
{% endstyle %}

<style>
.blog-grid {
  padding: 30px;  
  display: grid;
  gap: 30px;
  grid-template-columns: repeat({{ section.settings.post_limit }}, 1fr);
}
.article {
  display: flex;
  flex-direction: column;
}

@media(max-width:575px){
  .blog-grid {
    gap: 30px !important;
    grid-template-columns: repeat(1, 1fr);
  }
  .blog-grid {
  padding: 5px;
}
}

@media(min-width:576px) and (max-width:1024px){
  .blog-grid {
    gap: 40px !important;
    grid-template-columns: repeat(2, 1fr);
  }
}

</style>

{% if template == 'article' %}
{% style %}
  .section-featured-blog{
    background-color: #f7f7f7;
  }
{% endstyle %}
{% endif %}

<section class="blog {% if section.settings.blog == blank %} empty-carousel {% endif %} featured-blog section-{{ section.id }}-padding ctm_featured_blog">

  <div class="blog__header {% if section.settings.blog != blank %}fullscreen-container {% else %} container {% endif %}">
    {% if section.settings.blog_title != blank %}
      <h2 class="blog__title h2 ctm_blog_title_feature">{{ section.settings.blog_title }}</h2>
    {% endif %}
  </div>

  <div class="blog__articles {% if section.settings.blog == blank %} container {% endif %} blog-grid gts">
    {% if section.settings.blog != blank and section.settings.blog.articles_count > 0 %}
      
      {% for article in section.settings.blog.articles limit: section.settings.post_limit %}
        <div class="article">
          {% render 'article-card',
            blog: section.settings.blog,
            article: article,
            show_image: section.settings.show_image,
            show_tags: section.settings.show_tags,
            show_date: section.settings.show_date,
            show_author: section.settings.show_author,
            show_excerpt: section.settings.show_excerpt,
            show_btn: section.settings.show_btn
          %}
        </div>
      {% endfor %}

    {% else %}
      {% for i in (1..3) %}
        <article class="article">
          <div class="article__item">
            <a class="article__img" href="javascript:;">
              {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
            </a>
            <div class="article__content">
              <h6 class="article__title">
                <a href="javascript:;" class="h6">
                  {{ 'sections.featured_blog.onboarding_title' | t }}
                </a>
              </h6>
              <p class="article__excerpt">
                {{ 'sections.featured_blog.onboarding_content' | t }}
              </p>
            </div>
          </div>
        </article>
      {% endfor %}
    {% endif %}
  </div>

  {%- comment -%} Only one Read More button below posts {%- endcomment -%}
  {% if section.settings.blog != blank and section.settings.blog.articles_count > section.settings.post_limit and section.settings.show_view_all %}
    <div class="ctm_feature_blog_btn">
      <a class="{{ section.settings.button_style }} button--with-underlines btn_blog_read_more" href="{{ section.settings.blog.url }}">
        <span>{{ 'sections.featured_blog.view_all' | t }}</span>
      </a>
    </div>
  {% endif %}

</section>


{% schema %}
{
  "name": "t:sections.featured-blog.name",
  "tag": "section",
  "class": "section-featured-blog spaced-section",
  "enabled_on": {
    "templates": [
      "*"
    ]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "blog_title",
      "default": "Some heading",
      "label": "t:sections.featured-blog.settings.blog_title.label"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "t:sections.featured-blog.settings.blog.label"
    },
    {
      "type": "range",
      "id": "post_limit",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "t:sections.featured-blog.settings.post_limit.label"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "default": true,
      "label": "t:sections.featured-blog.settings.show_image.label",
      "info": "t:sections.featured-blog.settings.show_image.info"
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "default": false,
      "label": "t:sections.featured-blog.settings.show_tags.label"
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "default": true,
      "label": "t:sections.featured-blog.settings.show_date.label"
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "default": false,
      "label": "t:sections.featured-blog.settings.show_author.label"
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "default": false,
      "label": "t:sections.featured-blog.settings.show_excerpt.label"
    },
    {
      "type": "checkbox",
      "id": "show_btn",
      "default": true,
      "label": "t:sections.featured-blog.settings.show_btn.label"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "t:sections.featured-blog.settings.show_view_all.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 110,
      "unit": "px",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 110,
      "unit": "px",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    },
    {
    "type": "select",
    "id": "button_style",
    "options": [
      {
        "value": "button--ctm_global_button",
        "label": "Global Button"
      },
      {
        "value": "button--ctm_wb_global_button",
        "label": "Global Button (White Background)"
      },
      {
        "value": "ctm-custom-button",
        "label": "Custom Button"
      },
      {
        "value": "ctm-custom-outline-button",
        "label": "Outline Button"
      },
      {
        "value": "button button--primary",
        "label": "t:sections.all.button.button_style.options__1.label"
      },
      {
        "value": "button button--secondary",
        "label": "t:sections.all.button.button_style.options__2.label"
      },
      {
        "value": "button button--tertiary",
        "label": "t:sections.all.button.button_style.options__3.label"
      }
    ],
    "default": "button button--primary",
    "label": "t:sections.all.button.button_style.label"
  }
  ],
  "presets": [
    {
      "name": "t:sections.featured-blog.presets.name"
    }
  ]
}
{% endschema %}
