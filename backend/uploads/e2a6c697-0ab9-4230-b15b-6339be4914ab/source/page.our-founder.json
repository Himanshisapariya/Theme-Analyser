      }
    },
    "image_with_text_D7GjPi": {
      "type": "image-with-text",
      "settings": {
        "row-reverse": "row-reverse",
        "image": "shopify://shop_images/XX-XY-hangtag-240123-back-free_0da88ec8-c523-41d9-96cb-88fdd70e821b.jpg",
        "image_size": "large",
        "show_frame": false,
        "color_scheme": "background-1",
        "frame-text": "",
        "frame-text-right": "",
        "color_scheme_2": "background-1",
        "heading": "",
        "subheading": "<p><strong>So I decided to make my own opportunity. What could be more American than that?<br><br></strong>And wouldn’t you know it? I teamed up with a rag tag group of cancelled, ousted and self-described misfits. And we created an athletic brand that would stand for the truth and America’s highest ideals: equality of opportunity, freedom of speech, open debate and dissent and striving for excellence.</p><p></p><p></p><p></p>",
        "desc": "",
        "subheading_left_top": "",
        "subheading_left_bottom": "",
        "subheading_right_top": "",
        "subheading_right_bottom": "",
        "button_text": "",
        "button_link": "",
        "button_style": "tertiary",
        "underline_color": "#000000",
        "margin_top": 30,
        "margin_bottom": 100,
        "lookbook_detail_class": "",
        "top_padding_desktop": 0,
        "bottom_padding_desktop": 0,
        "top_padding_mobile": 0,
        "bottom_padding_mobile": 0,
        "top_margin_desktop": 0,
        "bottom_margin_desktop": 0,
        "top_margin_mobile": 0,
        "bottom_margin_mobile": 0
      }
    },
    "image_with_text_jYPAFw": {
      "type": "image-with-text",
      "settings": {
        "row-reverse": "row",
        "image": "shopify://shop_images/PaulaBeigeFleece_129-Edit-sm.jpg",
        "image_size": "large",
        "show_frame": true,
        "color_scheme": "background-1",
        "frame-text": "",
        "frame-text-right": "",
        "color_scheme_2": "background-1",
        "heading": "",
        "subheading": "<p><strong>We’re not out to make so-so products for the “parallel economy.\"<br><br></strong>We are here to make clothes that are of the finest quality — the very best fits and fabrics and styles — that you’ll not only be proud to wear but love wearing.</p>",
        "desc": "",
        "subheading_left_top": "",
        "subheading_left_bottom": "",
        "subheading_right_top": "",
        "subheading_right_bottom": "",
        "button_text": "",
        "button_link": "",
        "button_style": "tertiary",
        "underline_color": "#000000",
        "margin_top": 30,
        "margin_bottom": 100,
        "lookbook_detail_class": "",
        "top_padding_desktop": 0,
        "bottom_padding_desktop": 0,
        "top_padding_mobile": 0,
        "bottom_padding_mobile": 0,
        "top_margin_desktop": 0,
        "bottom_margin_desktop": 0,
        "top_margin_mobile": 0,
        "bottom_margin_mobile": 0
      }
    },
    "image_with_text_9YBJJE": {
      "type": "image-with-text",
      "settings": {
        "row-reverse": "row-reverse",
        "image": "shopify://shop_images/XPTA03-501_MULTI.jpg",
        "image_size": "small",
        "show_frame": false,
        "color_scheme": "background-1",
        "frame-text": "",
        "frame-text-right": "",
        "color_scheme_2": "background-1",
        "heading": "",
        "subheading": "<p><strong>And we’re here to protect women’s sports and spaces.<br><br></strong>For women to be recognized as champions and to simply be afforded the chance to compete on an even playing field — and avail themselves of all the vast educational and developmental opportunities that competing in sports provides — girls' and women’s sports need to remain for girls and women only. We’ll be here defending them until that happens.<br><br><em><strong>I hope you’ll stand with us. Because as I’ve discovered, it’s a little less scary when we do it together. </strong></em><em><br><br></em>-Jennifer Sey</p>",
        "desc": "",
        "subheading_left_top": "",
        "subheading_left_bottom": "",
        "subheading_right_top": "",
        "subheading_right_bottom": "",
        "button_text": "",
        "button_link": "",
        "button_style": "tertiary",
        "underline_color": "#000000",
