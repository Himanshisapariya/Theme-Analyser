{{ 'section-rich-text.css' | asset_url | stylesheet_tag }}

{%- style -%}
	{% render 'spaced-section' %}
	{% render 'spaced-section-inner' %}

	.rich-text {
		text-align: center;
	}

	.section-{{ section.id }}-padding .rich-text__blocks {
		text-align: {{ section.settings.content_alignment_desktop }};
		align-items: {{ section.settings.content_alignment_desktop }};
	}

	@media screen and (max-width: 749px) {
		.section-{{ section.id }}-padding .rich-text__blocks {
			text-align: {{ section.settings.content_alignment_mobile }};
			align-items: {{ section.settings.content_alignment_mobile }};
		}
	}
{%- endstyle -%}

<div class="rich-text{% if section.settings.full_width %} rich-text--full-width{% endif %} color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding {{ section.settings.spring_shop_text }}">
	<div class="rich-text__blocks">
		{%- for block in section.blocks -%}
			{%- case block.type -%}
				{%- when 'subheading' -%}
					{% if block.settings.subheading != blank %}
					<div
						class="rich-text__subheading subtitle"
						{{ block.shopify_attributes }}
					>
						{{ block.settings.subheading | escape }}
					</div>
					{%  endif %}
				{%- when 'heading' -%}
					{%  if block.settings.heading != blank %}
					<h2	
						class="title--section {% if block.settings.heading_size == 'medium' %}h2{% else %}h1{% endif %}"
						style="padding-top: {{ block.settings.heading_padding_top }}px; padding-bottom: {{ block.settings.heading_padding_bottom }}px";
						{{ block.shopify_attributes }}
					>
						{{ block.settings.heading }}
					</h2>
					{%  endif %}
				{%- when 'text' -%}
					{% if block.settings.text != blank %}
					<div class="rich-text__text" {{ block.shopify_attributes }}>
						{{ block.settings.text }}
					</div>
				{%  endif %}
				{%- when 'button' -%}
					{%  if block.settings.button_label != blank %}
					<a
						{% if block.settings.button_link == blank %}
							aria-disabled="true"
						{% else %}
							href="{{ block.settings.button_link }}"
						{% endif %}
						class="{{ block.settings.button_style }}"
						{{ block.shopify_attributes }}
					>
							{{ block.settings.button_label | escape }}
					</a>
				{%  endif %}
				{%- when 'custom_liquid' -%}
						{% if block.settings.custom_liquid != blank %}
							<div class="rich-text__custom-liquid">
							{{ block.settings.custom_liquid }}
							</div>
						{% endif %}
			{%- endcase -%}
		{%- endfor -%}
	</div>
</div>

{% schema %}
{
	"name": "t:sections.rich-text.name",
	"tag": "section",
	"class": "spaced-section spaced-section--full-width",
	"enabled_on": {
		"templates": ["*"]
	},
	"settings": [
		{
			"type": "select",
			"id": "color_scheme",
			"options": [
				{
					"value": "background-1",
					"label": "t:sections.all.color_scheme.options__1.label"
				},
				{
					"value": "background-2",
					"label": "t:sections.all.color_scheme.options__2.label"
				},
				{
					"value": "background-3",
					"label": "t:sections.all.color_scheme.options__3.label"
				},
				{
					"value": "background-4",
					"label": "t:sections.all.color_scheme.options__4.label"
				}
			],
			"default": "background-1",
			"label": "t:sections.all.color_scheme.label"
		},
		{
			"type": "checkbox",
			"id": "full_width",
			"default": true,
			"label": "t:sections.rich-text.settings.full_width.label"
		},
		{
			"type": "header",
			"content": "Content Alignment"
		},
		{
			"type": "select",
			"id": "content_alignment_desktop",
			"label": "Desktop alignment",
			"options": [
				{
					"value": "left",
					"label": "Left"
				},
				{
					"value": "center",
					"label": "Center"
				},
				{
					"value": "right",
					"label": "Right"
				}
			],
			"default": "center"
		},
		{
			"type": "select",
			"id": "content_alignment_mobile",
			"label": "Mobile alignment",
			"options": [
				{
					"value": "left",
					"label": "Left"
				},
				{
					"value": "center",
					"label": "Center"
				},
				{
					"value": "right",
					"label": "Right"
				}
			],
			"default": "center"
		},
		{
			"type": "header",
			"content": "t:sections.all.section-padding.header.content"
		},
		{
			"type": "range",
			"id": "padding_top",
			"min": 0,
			"max": 200,
			"step": 10,
			"default": 0,
			"unit": "px",
			"label": "t:sections.all.section-padding.padding_top.label"
		},
		{
			"type": "range",
			"id": "padding_bottom",
			"min": 0,
			"max": 200,
			"step": 10,
			"default": 0,
			"unit": "px",
			"label": "t:sections.all.section-padding.padding_bottom.label"
		},
		{
			"type": "header",
			"content": "t:sections.all.section-margin.header.content"
		},
		{
			"type": "range",
			"id": "margin_top",
			"min": 0,
			"max": 200,
			"step": 10,
			"default": 20,
			"unit": "px",
			"label": "t:sections.all.section-margin.margin_top.label"
		},
		{
			"type": "range",
			"id": "margin_bottom",
			"min": 0,
			"max": 200,
			"step": 10,
			"default": 20,
			"unit": "px",
			"label": "t:sections.all.section-margin.margin_bottom.label"
		},
		{
			"type": "text",
			"id": "spring_shop_text",
			"label": "Spring Shop Class"
		}
	],
	"blocks": [
		{
			"type": "subheading",
			"name": "t:sections.rich-text.blocks.subheading.name",
			"limit": 1,
			"settings": [
				{
					"type": "text",
					"id": "subheading",
					"default": "Subheading",
					"label": "t:sections.rich-text.blocks.heading.settings.heading.label"
				}
			]
		},
		{
			"type": "custom_liquid",
			"name": "Custom Liquid",
			"settings": [
				{
				"type": "liquid",
				"label": "Custom Liquid",
				"id": "custom_liquid"
				}
			]
    },
		{
			"type": "heading",
			"name": "t:sections.rich-text.blocks.heading.name",
			"limit": 1,
			"settings": [
				{
					"type": "richtext",
					"id": "heading",
					"default": "<p>Heading for your section</p>",
					"label": "t:sections.rich-text.blocks.heading.settings.heading.label"
				},
				{
					"type": "select",
					"id": "heading_size",
					"options": [
						{
							"value": "medium",
							"label": "t:sections.rich-text.blocks.heading.settings.heading_size.options__1.label"
						},
						{
							"value": "large",
							"label": "t:sections.rich-text.blocks.heading.settings.heading_size.options__2.label"
						}
					],
					"default": "medium",
					"label": "t:sections.rich-text.blocks.heading.settings.heading_size.label"
				},
				{
					"type": "range",
					"id": "heading_padding_top",
					"min": 0,
					"max": 200,
					"step": 10,
					"default": 0,
					"unit": "px",
					"label": "Padding top"
				},
				{
					"type": "range",
					"id": "padding_bottom",
					"min": 0,
					"max": 200,
					"step": 10,
					"default": 0,
					"unit": "px",
					"label": "Padding Bottom"
				}
			]
		},
		{
			"type": "text",
			"name": "t:sections.rich-text.blocks.text.name",
			"limit": 1,
			"settings": [
				{
					"type": "richtext",
					"id": "text",
					"default": "<p>Description for your section.</p>",
					"label": "t:sections.rich-text.blocks.text.settings.text.label"
				}
			]
		},
		
		{
			"type": "button",
			"name": "t:sections.rich-text.blocks.button.name",
			"limit": 2,
			"settings": [
				{
					"type": "text",
					"id": "button_label",
					"default": "Button label",
					"label": "t:sections.all.button.button_text.label"
				},
				{
					"type": "url",
					"id": "button_link",
					"label": "t:sections.all.button.button_link.label"
				},
				{
					"type": "select",
					"id": "button_style",
					"options": [
						{
							"value": "button button--arrow primary",
							"label": "t:sections.all.button.button_style.options__1.label"
						},
						{
							"value": "button button--arrow secondary",
							"label": "t:sections.all.button.button_style.options__2.label"
						},
						{
							"value": "button button--arrow tertiary",
							"label": "t:sections.all.button.button_style.options__3.label"
						},
						{
							"value": "button--ctm_global_button",
							"label": "Global Button"
						},
						{
							"value": "button--ctm_wb_global_button",
							"label": "Global Button (White Background)"
						}
					],
					"default": "button--ctm_wb_global_button",
					"label": "t:sections.all.button.button_style.label"
				}
			]
		}
	],
	"presets": [
		{
			"name": "t:sections.rich-text.presets.name",
			"blocks": [
				{
					"type": "subheading"
				},
				{
					"type": "heading"
				},
				{
					"type": "text"
				},
				{
					"type": "button"
				}
			]
		}
	]
}
{% endschema %}
