        "color_scheme_2": "background-1",
        "heading": "",
        "subheading": "<p><strong>So I decided to make my own opportunity. What could be more American than that?<br><br></strong>And wouldn’t you know it? I teamed up with a rag tag group of cancelled, ousted and self-described misfits. And we created an athletic brand that would stand for the truth and America’s highest ideals: equality of opportunity, freedom of speech, open debate and dissent and striving for excellence.</p><p></p><p></p><p></p>",
        "desc": "",
        "subheading_left_top": "",
        "subheading_left_bottom": "",
        "subheading_right_top": "",
        "subheading_right_bottom": "",
        "button_text": "",
