      "type": "image-with-text",
      "settings": {
        "row-reverse": "row",
        "image": "shopify://shop_images/Athlete-A-Featured-8626.jpg",
        "image_size": "adapt",
        "show_frame": true,
        "color_scheme": "background-1",
        "frame-text": "",
        "frame-text-right": "",
        "color_scheme_2": "background-1",
        "heading": "",
        "subheading": "<p><strong>But by the time I produced “Athlete A” in 2020, many others began to speak out.<br><br></strong>And this taught me a valuable lesson: being brave and telling the truth helps other people find their voice too. I decided I would never stay silent again.</p>",
        "desc": "",
        "subheading_left_top": "",
        "subheading_left_bottom": "",
        "subheading_right_top": "",
        "subheading_right_bottom": "",
        "button_text": "",
        "button_link": "",
        "button_style": "tertiary",
        "underline_color": "#000000",
        "margin_top": 0,
