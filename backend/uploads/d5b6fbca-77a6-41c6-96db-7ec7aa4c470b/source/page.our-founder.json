    "image_with_text_M8xYeR": {
      "type": "image-with-text",
      "settings": {
        "row-reverse": "row",
        "image": "shopify://shop_images/FullSizeRender_2-8111_1b54a7bf-9841-40c4-b265-0043530a7337.jpg",
        "image_size": "adapt",
        "show_frame": true,
        "color_scheme": "background-1",
        "frame-text": "",
        "frame-text-right": "",
        "color_scheme_2": "background-1",
        "heading": "",
        "subheading": "<p><strong>After all, as a kid, I just wanted to fit in. <br><br></strong>In fact, in many ways I was the ultimate conformist. I was obedient to a fault. Even though the sport I loved, elite gymnastics, routinely abused girls like me — both emotionally and physically. Yet I stayed silent because that’s just what you were supposed to do — especially if you were vying for a spot on the National Team. Trouble makers didn’t get very far.  </p>",
        "desc": "",
        "subheading_left_top": "",
        "subheading_left_bottom": "",
        "subheading_right_top": "",
        "subheading_right_bottom": "",
        "button_text": "",
        "button_link": "",
        "button_style": "tertiary",
        "underline_color": "#000000",
        "margin_top": 0,
        "margin_bottom": 0,
        "lookbook_detail_class": "",
        "top_padding_desktop": 0,
        "bottom_padding_desktop": 0,
        "top_padding_mobile": 0,
        "bottom_padding_mobile": 0,
        "top_margin_desktop": 0,
        "bottom_margin_desktop": 0,
        "top_margin_mobile": 0,
        "bottom_margin_mobile": 0
      }
    },
    "image_with_text_dHd4dQ": {
      "type": "image-with-text",
      "settings": {
        "row-reverse": "row-reverse",
        "image": "shopify://shop_images/jen-8360.jpg",
        "image_size": "adapt",
        "show_frame": true,
        "color_scheme": "background-1",
        "frame-text": "",
        "frame-text-right": "",
        "color_scheme_2": "background-1",
        "heading": "",
        "subheading": "<p><strong>But 22 years after becoming a National Champion, I decided to break my silence.<br><br></strong>And when I blew the whistle on the rampant abuse in national gymnastics in my book <a href=\"https://www.amazon.com/Chalked-Up-Life-Elite-Gymnastics/dp/0061351474\">“Chalked Up,\"</a> I was vilified and ostracized by the very community I was speaking up for. </p>",
        "desc": "",
        "subheading_left_top": "",
        "subheading_left_bottom": "",
        "subheading_right_top": "",
        "subheading_right_bottom": "",
        "button_text": "",
        "button_link": "",
        "button_style": "tertiary",
        "underline_color": "#000000",
        "margin_top": 0,
        "margin_bottom": 0,
        "lookbook_detail_class": "",
        "top_padding_desktop": 0,
        "bottom_padding_desktop": 0,
        "top_padding_mobile": 0,
        "bottom_padding_mobile": 0,
        "top_margin_desktop": 0,
        "bottom_margin_desktop": 0,
        "top_margin_mobile": 0,
        "bottom_margin_mobile": 0
      }
    },
