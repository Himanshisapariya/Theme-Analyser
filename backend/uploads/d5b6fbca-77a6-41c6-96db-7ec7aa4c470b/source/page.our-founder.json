        "frame-text-right": "",
        "color_scheme_2": "background-1",
        "heading": "",
        "subheading": "<p><strong>But sports taught me an important lesson:<br><br></strong>You gotta get back up when you get knocked down.</p>",
        "desc": "",
        "subheading_left_top": "",
        "subheading_left_bottom": "",
        "subheading_right_top": "",
        "subheading_right_bottom": "",
        "button_text": "",
