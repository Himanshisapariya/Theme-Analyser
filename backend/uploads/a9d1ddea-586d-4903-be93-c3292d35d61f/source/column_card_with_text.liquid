{{ 'column-card-with-text.css' | asset_url | stylesheet_tag }}


<section class="column-card-with-text">
    <div class="grid-card-main">
      <div class="grid-card-inner">
        {% for block in section.blocks %}
          <div class="grid-card">
            {% if block.settings.image != blank %}
            <div class="grid-card-img">
              <img src="{{ block.settings.image | image_url }}" width="100%" height="100%" alt="">
            </div>
            {% endif %}
            <div class="grid-card-details">
            {% if block.settings.text != blank %}
                <div class="grid-card-text">
                    <p>{{ block.settings.text }}</p>
                </div>
            {% endif %}
            {% if  block.settings.button_text != blank %}
              <div class="grid-card-btn color-background-5 bg-transparent br-0">
                <a class="new-button-text {{ section.settings.button_style }}" href="{{ block.settings.button_link }}">{{ block.settings.button_text }}</a>
              </div>
            {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>
  
  {% schema %}
  {
    "name": "Column Card Text",
    "tag": "section",
    "class": "grid-card-main",
    "settings": [
      {
        "type": "inline_richtext",
        "label": "Heading",
        "id": "heading"
      },
      {
      "type": "select",
      "id": "button_style",
      "options": [
        {
          "value": "button--ctm_global_button",
          "label": "Global Button"
        },
        {
          "value": "button--ctm_wb_global_button",
          "label": "Global Button (White Background)"
        },
        {
          "value": "ctm-custom-button",
          "label": "Custom Button"
        },
        {
          "value": "ctm-custom-outline-button",
          "label": "Outline Button"
        },
        {
          "value": "button button--primary",
          "label": "t:sections.all.button.button_style.options__1.label"
        },
        {
          "value": "button button--secondary",
          "label": "t:sections.all.button.button_style.options__2.label"
        },
        {
          "value": "button button--tertiary",
          "label": "t:sections.all.button.button_style.options__3.label"
        }
      ],
      "default": "button button--primary",
      "label": "t:sections.all.button.button_style.label"
    }
    ],
    "blocks": [
      {
        "type": "blog_post",
        "name": "Blog Post",
        "settings": [
          {
            "type": "image_picker",
            "label": "Image",
            "id": "image"
          },
          {
            "type": "html",
            "label": "Text",
            "id": "text"
          },
          {
            "type": "text",
            "label": "Button Text",
            "id": "button_text"
          },
          {
            "type": "url",
            "label": "Button Link",
            "id": "button_link"
          },
          {
          "type": "select",
          "id": "button_style",
          "options": [
            {
              "value": "button--ctm_global_button",
              "label": "Global Button"
            },
            {
              "value": "button--ctm_wb_global_button",
              "label": "Global Button (White Background)"
            },
            {
              "value": "ctm-custom-button",
              "label": "Custom Button"
            },
            {
              "value": "ctm-custom-outline-button",
              "label": "Outline Button"
            },
            {
              "value": "button button--primary",
              "label": "t:sections.all.button.button_style.options__1.label"
            },
            {
              "value": "button button--secondary",
              "label": "t:sections.all.button.button_style.options__2.label"
            },
            {
              "value": "button button--tertiary",
              "label": "t:sections.all.button.button_style.options__3.label"
            }
          ],
          "default": "button button--primary",
          "label": "t:sections.all.button.button_style.label"
        },
        ]
      }
    ],
    "presets": [
      {
        "name": "Column Card Text"
      }
    ]
  }
  {% endschema %}  