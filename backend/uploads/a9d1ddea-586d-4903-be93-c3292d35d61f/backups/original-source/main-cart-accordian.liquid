<div class="cart-help-accordion" {{ block.shopify_attributes }}>
  <button class="cart-help-accordion__header" type="button" aria-expanded="false" aria-controls="cart-accordion-content-{{ block.id }}">
    {% if block.settings.icon != blank %}
      <img
        src="{{ block.settings.icon | image_url: width: 40 }}"
        class="cart-help-accordion__icon"
        height="auto"
        width="auto"
        alt=""
      >
    {% endif %}

    <span class="cart-help-accordion__question">
      {{ block.settings.question }}
    </span>

    <span class="cart-help-accordion__arrow">
      {% render 'icon-caret' %}
    </span>
  </button>

  <div class="cart-help-accordion__content" id="cart-accordion-content-{{ block.id }}">
    {{ block.settings.answer }}
  </div>
</div>

