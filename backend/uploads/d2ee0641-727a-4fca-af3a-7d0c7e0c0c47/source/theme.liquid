<script>
  document.addEventListener('DOMContentLoaded', function () {
    window.dataLayer = window.dataLayer || [];

    function attachUpsellTracking() {
      const buttons = document.querySelectorAll(
        '.upsell_click, [data-shopify-analytics-event-name="upsell_cart_click"]',
      );

      if (!buttons.length) return;

      buttons.forEach((btn) => {
        if (btn.dataset.trackingAttached === 'true') return;
        btn.dataset.trackingAttached = 'true';

        btn.addEventListener('click', function () {
          const itemId = btn.getAttribute('data-shopify-analytics-event-product_id')?.trim();
          const itemName = btn.getAttribute('data-shopify-analytics-event-product_name')?.trim() || '';
          const itemPrice = parseFloat(btn.getAttribute('data-shopify-analytics-event-price') || 0);
          const itemCategory = btn.getAttribute('data-shopify-analytics-event-upsell_type') || '';
          const eventName = btn.getAttribute('data-shopify-analytics-event-name');
          const itemBrand = 'Unknown';
          const itemVariant = '';

          if (!itemId) return;

          const eventToPush = eventName === 'upsell_cart_click' ? 'upsell_cart_click' : 'upsell_pdp_click';

          window.dataLayer.push({
            event: eventToPush,
            ecommerce: {
              items: [
                {
                  item_id: itemId,
                  item_name: itemName,
                  item_brand: itemBrand,
                  item_category: itemCategory,
                  price: itemPrice,
                  quantity: 1,
                  item_variant: itemVariant,
                },
              ],
            },
          });

          try {
            const key = 'upsellClicks_v1';
            const sourceKey = 'upsellSource_v1';
            let upsells = JSON.parse(localStorage.getItem(key) || '[]');
            upsells = upsells.filter((id) => id && id.trim() !== '');
            if (!upsells.includes(itemId)) upsells.push(itemId);
            localStorage.setItem(key, JSON.stringify(upsells));

            let sources = JSON.parse(localStorage.getItem(sourceKey) || '{}');
            sources[itemId] = eventToPush;
            localStorage.setItem(sourceKey, JSON.stringify(sources));
          } catch (err) {}
        });
      });
    }

    attachUpsellTracking();

    const observer = new MutationObserver(attachUpsellTracking);
    observer.observe(document.body, { childList: true, subtree: true });

    (function interceptEvents() {
      const originalPush = window.dataLayer.push;

      window.dataLayer.push = function () {
        const result = originalPush.apply(this, arguments);
        const data = arguments[0];

        if (data?.event === 'purchase') {
          handleUpsellPurchase(data);
        }

        return result;
      };

      function handleUpsellPurchase(purchaseData) {
        try {
          const key = 'upsellClicks_v1';
          const sourceKey = 'upsellSource_v1';
          const clickedUpsells = JSON.parse(localStorage.getItem(key) || '[]');
          const sources = JSON.parse(localStorage.getItem(sourceKey) || '{}');

          if (!clickedUpsells.length) return;

          const purchasedIds = purchaseData.ecommerce?.items?.map((i) => i.item_id || i.id) || [];
          const matched = purchasedIds.filter((id) => clickedUpsells.includes(id));

          if (!matched.length) return;

          matched.forEach((id) => {
            window.dataLayer.push({
              event: 'upsell_purchase_checkout',
              ecommerce: {
                items: [
                  {
                    item_id: id,
                  },
                ],
              },
            });
          });

          matched.forEach((id) => {
            const source = sources[id] || 'upsell_unknown_click';
            const purchaseEvent =
              source === 'upsell_cart_click' ? 'upsell_purchase_success_cart' : 'upsell_purchase_success_pdp';

            window.dataLayer.push({
              event: purchaseEvent,
              ecommerce: {
                items: [
                  {
                    item_id: id,
                  },
                ],
              },
            });
          });

          localStorage.removeItem(key);
          localStorage.removeItem(sourceKey);
        } catch (e) {}
      }
    })();
  });
</script>
