    <script>
      function addParamsToUrl(url) {
        if (url.includes('/checkout') || url.includes('checkout.shopify.com')) {
          return url;
        }
        var storedParams = sessionStorage.getItem('landingParams');
        if (!storedParams) return url;
        var params = JSON.parse(storedParams);
        var paramString = Object.keys(params)
          .map(function (key) {
            return key + '=' + encodeURIComponent(params[key]);
          })
          .join('&');
        if (paramString) {
          var separator = url.indexOf('?') === -1 ? '?' : '&';
          return url + separator + paramString;
        }
        return url;
      }
      document.addEventListener(
        'click',
        function (e) {
          var targetLink = e.target.closest('a');
          if (targetLink && targetLink.href && targetLink.hostname === window.location.hostname) {
            if (!targetLink.href.includes('/checkout')) {
              var newHref = addParamsToUrl(targetLink.href);
              if (newHref !== targetLink.href) {
                e.preventDefault();
                window.location.href = newHref;
              }
            }
          }
        },
        true,
      );
      function modifyCheckoutLinks() {
        var storedParams = sessionStorage.getItem('landingParams');
        if (!storedParams) return;
        var params = JSON.parse(storedParams);
        var paramString = Object.keys(params)
          .map(function (key) {
            return key + '=' + encodeURIComponent(params[key]);
          })
          .join('&');
        if (!paramString) return;

        var selectors = [
          'form[action*="/checkout"]',
          'form[action*="/cart"]',
          'a[href*="/checkout"]',
          'button[name="checkout"]',
          '[data-testid="checkout-button"]',
        ];

        selectors.forEach(function (selector) {
          var elements = document.querySelectorAll(selector);
          elements.forEach(function (element) {
            if (element.tagName === 'FORM' && element.action) {
              var separator = element.action.indexOf('?') === -1 ? '?' : '&';
              element.action = element.action + separator + paramString;
            }
            if (element.href) {
              var separator = element.href.indexOf('?') === -1 ? '?' : '&';
              element.href = element.href + separator + paramString;
            }
          });
        });
      }

      document.addEventListener('DOMContentLoaded', modifyCheckoutLinks);
      document.addEventListener('ajaxComplete', modifyCheckoutLinks);
      document.addEventListener('change', modifyCheckoutLinks);
      setInterval(modifyCheckoutLinks, 1000);
    </script>

