<style>
  .ctm_warranty_bg_img {
    background-image: url('{{ page.metafields.warranty-bg.acf }}');
    background-repeat: no-repeat;
    background-size: cover;
  }
  .faq_question.active .icon-shape.active svg path:last-child {
    display: none;
  }
  .faq_question.active .icon-shape.active svg path {
    stroke: #62673c;
  }
</style>

