              <g clip-path="url(#clip0_8216_10313)">
                 <path d="M13 13.75L19 19.75M8 15.75C4.13401 15.75 1 12.616 1 8.75C1 4.88401 4.13401 1.75 8 1.75C11.866 1.75 15 4.88401 15 8.75C15 12.616 11.866 15.75 8 15.75Z" stroke="#62673C" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </g>
              <defs>
                 <clipPath id="clip0_8216_10313">
                    <rect width="20" height="20" fill="white" transform="translate(0 0.75)"/>
                 </clipPath>
              </defs>
            </svg>
            <input class="focus-visible:outline-none" type="text" id="faqSearchInput" placeholder="Search...">
          </div>
        </div>
