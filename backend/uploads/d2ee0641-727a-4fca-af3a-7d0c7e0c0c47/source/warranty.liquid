<script>
  document.addEventListener('DOMContentLoaded', function () {
    // Get the ul element with id "faq-filter"
    var filterList = document.getElementById('faq-filter');

    // Get all li elements inside the ul with id "faq-filter"
    var filterItems = filterList.querySelectorAll('li');

    // Attach click event listener to each li element
    filterItems.forEach(function (item) {
      item.addEventListener('click', function () {
        // Remove active class from all li elements
        filterItems.forEach(function (item) {
          item.classList.remove('active');
        });

        // Add active class to the clicked li element
        this.classList.add('active');

        // Remove active class from the ul element
        filterList.classList.remove('active');
      });
    });
  });

  // Wait for the DOM content to load
  document.addEventListener('DOMContentLoaded', function () {
    // Get all main FAQ sections
    var mainFAQSections = document.querySelectorAll("[class^='ctm_faq_head_']");

    // Loop through each main FAQ section
    mainFAQSections.forEach(function (section) {
      // Find the first FAQ item in the current section
      var firstFAQItem = section.querySelector('.faq_container .answercont');

      // Open the first FAQ item if found
      if (firstFAQItem) {
        firstFAQItem.classList.remove('max-h-0');
      }
    });

    // Get all FAQ question containers
    var faqQuestions = document.querySelectorAll('.faq_question');

    // Loop through each FAQ question container
    faqQuestions.forEach(function (faqQuestion) {
      // Add click event listener to each FAQ question
      faqQuestion.addEventListener('click', function () {
        // Get the answer container corresponding to the clicked question
        var answerContainer = faqQuestion.nextElementSibling;

        // Close all other answer containers
        closeAllAnswers();

        // Toggle the visibility of the clicked question's answer container
        if (answerContainer) {
          answerContainer.classList.toggle('max-h-0');
        }
      });
    });

    // Function to close all answer containers
    function closeAllAnswers() {
      var allAnswerContainers = document.querySelectorAll('.answercont');
      allAnswerContainers.forEach(function (container) {
        container.classList.add('max-h-0');
      });
    }
  });

  document.addEventListener('DOMContentLoaded', function () {
    var label = document.querySelector('.filter-dropdown label');
    var ul = document.getElementById('faq-filter');

    label.addEventListener('click', function () {
      ul.classList.toggle('active');
    });
  });
</script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    // Get the ul element
    const categoryList = document.getElementById('faq-filter');

    // Function to update the filter label
    function updateFilterLabel(selectedListItem) {
      const filterLabel = document.querySelector('.filter-dropdown label');
      filterLabel.textContent = selectedListItem.textContent;
    }

    // Add event listener to handle click on list items
    categoryList.addEventListener('click', function (event) {
      // Get the clicked list item
      const selectedListItem = event.target.closest('li');

      // Check if a list item is clicked
      if (selectedListItem) {
        // Update the filter label
        updateFilterLabel(selectedListItem);

        // Remove the 'active' class from all list items
        const listItems = categoryList.querySelectorAll('li');
        listItems.forEach(function (item) {
          item.classList.remove('active');
        });

        // Add the 'active' class to the clicked list item
        selectedListItem.classList.add('active');

        // Get the data-category attribute value
        const selectedCategory = selectedListItem.getAttribute('data-category');

        // Hide all FAQ categories
        const faqCategories = document.querySelectorAll('.faq_main_container > div');
        faqCategories.forEach(function (category) {
          category.style.display = 'none';
        });

        // Show all FAQs if "All FAQs" is selected
        if (selectedCategory === 'all') {
          faqCategories.forEach(function (category) {
            category.style.display = 'block';
          });
        } else {
          // Show the selected FAQ category
          const selectedCategoryElement = document.querySelector(`.${selectedCategory}`);
          if (selectedCategoryElement) {
            selectedCategoryElement.style.display = 'block';
          }
        }
      }
    });
  });
</script>

{% schema %}
{
  "name": "Warranty",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "label": "Extra Class",
      "id": "extra_class"
    },
    {
      "type": "checkbox",
      "label": "First Accordion Open",
      "id": "first_accordion_open",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "search_bar_display",
      "label": "Want to hide search bar?",
      "default": false
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Warranty"
    }
  ]
}
{% endschema %}
