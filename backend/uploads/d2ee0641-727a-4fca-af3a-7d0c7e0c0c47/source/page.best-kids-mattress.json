    "video_with_text_YnJicQ": {
      "type": "video-with-text",
      "settings": {
        "extra_Class": "ctm_storyvideo_block",
        "upper_sub_head": "Made for",
        "main_head": "Our Children, And Yours",
        "lower_sub_head": "",
        "description": "Good sleep is one of the most important things that kids need for healthy growth and development. Unfortunately, most toddler mattresses on the market aren't designed to suit the unique needs of growing little bodies. The 5 Little Monkeys children's mattress is different: we designed the mattress from the ground up, creating a new kind of kid's mattress made with a science-backed design and organic materials for safe, sound sleep. So how did 5 Little Monkeys come into being? It all started from a desire to give our own children the very best kid's mattress.",
        "button_text": "Try Risk-Free Today!",
        "button_url": "shopify://collections/all",
        "video_title_mobile": "",
        "enable_embed_video": false,
        "play_btn_image": "shopify://shop_images/play-svgrepo-com.png",
        "video_poster": "shopify://shop_images/imag213e.png",
        "video": "https://cdn.shopify.com/videos/c/o/v/952380c166bb4f2ea9823fdce87ba544.mp4",
