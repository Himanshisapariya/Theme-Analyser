                {% if pillow-tick-txt[j] != blank %}
                  <div class="flex flex-col w-full">
                    <div class="ctm_tick_img_pdp flex gap-10 items-center">
                      <img
                        src="https://cdn.shopify.com/s/files/1/0792/4904/7864/files/check.png"
                        alt="img_logo"
                        loading="lazy"
                        width="36"
                        height="36"
                      >
                      <div class="ctm_tick_text_pdp">
                        <h6 class="font-normal text-dark_grey">{{ pillow-tick-txt[j] }}</h6>
                      </div>
                    </div>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </div>
        {% if pillow-image != blank %}
          <div class="ctm_pdp_zig_zag_img w-full mdscreen2:w-[calc(67%_-_55px)] desktop:w-[calc(67%_-_100px)] midlarge_desktop:w-[calc(50%_-_100px)] rounded-24 overflow-hidden ctm_pdpzigzag_{{ pillow-image-alignment }}">
            <img
              class="w-full h-full object-cover"
              src="{{ pillow-image }}"
              alt="pdp_zig_img"
              loading="lazy"
              width="780"
              height="446"
            >
          </div>
        {% endif %}
      </div>
    </div>
  </div>
{% endif %}
{% if mattress-sub-txt != blank %}
  <div class="ctm_mattress_img_txt_alignment {{ section.settings.extra_class }} pdpzigzag_{{ mattress-alignment }}">
    <div class="xl_container">
      <div class="pdp_zigzg_inner flex mdscreen1:flex-col gap-40 mdscreen2:gap-55 desktop:!gap-100 items-center">
        <div class="ctm_pdp_zig_zag_text_main w-full mdscreen2:w-1/2 desktop:w-[37%] midlarge_desktop:w-1/2 desktop:pl-[45px]">
          <div class="ctm_pdp_zz_txt pb-14 mdscreen1:text-center">
            <div class="ctm_pdp_caption pb-10">
