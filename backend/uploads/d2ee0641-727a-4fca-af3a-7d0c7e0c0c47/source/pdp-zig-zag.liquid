        {% endif %}
      </div>
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "PDP Zig Zag",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "label": "Extra Class",
      "id": "extra_class"
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "PDP Zig Zag"
    }
  ]
}
{% endschema %}
