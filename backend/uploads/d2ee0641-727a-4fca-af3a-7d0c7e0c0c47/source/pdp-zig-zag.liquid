            </div>
          </div>
          <div class="ctm_tick_txt_pdp">
            <div class="ctm_text_tick_main flex items-center flex-col gap-16">
              {% for j in (0..mattress-tick-txt.size) %}
                {% if mattress-tick-txt[j] != blank %}
                  <div class="flex flex-col w-full">
                    <div class="ctm_tick_img_pdp flex gap-10 items-center">
                      <img
                        src="https://cdn.shopify.com/s/files/1/0792/4904/7864/files/check.png"
                        alt="img_logo"
                        loading="lazy"
                        width="36"
                        height="36"
                      >
                      <div class="ctm_tick_text_pdp">
                        <h6 class="font-normal text-dark_grey">{{ mattress-tick-txt[j] }}</h6>
                      </div>
                    </div>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </div>
        {% if mattress-image != blank %}
          <div class="ctm_pdp_zig_zag_img w-full mdscreen2:w-[calc(67%_-_55px)] desktop:w-[calc(67%_-_100px)] midlarge_desktop:w-[calc(50%_-_100px)] rounded-24 overflow-hidden ctm_pdpzigzag_{{ kids-image-alignment }}">
            <img
              class="w-full h-full object-cover"
              src="{{ mattress-image }}"
