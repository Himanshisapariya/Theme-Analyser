{
  "devDependencies": {
    "@shopify/prettier-plugin-liquid": "^1.6.3",
    "autoprefixer": "^10.4.19",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "postcss": "^8.4.38",
    "postcss-import": "^16.1.0",
    "postcss-nesting": "^12.1.1",
    "postcss-preset-env": "^9.5.5",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.1",
    "vite": "^5.2.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css,md,liquid}": "prettier --write"
  },
  "scripts": {
    "dev": "run-p -sr shopify:dev build",
    "shopify:dev": "shopify theme dev --store=5-little-monkeys-dev.myshopify.com --theme-editor-sync",
    "build": "npx tailwindcss -i css/application.css -o assets/application.css.liquid -w -m",
    "watch": "vite build --watch",
    "format": "prettier --write snippets/ templates/ sections/ layout/ config/ assets/",
    "prepare": "husky"
  },
  "dependencies": {
    "esbuild": "^0.24.2",
    "npm-run-all": "^4.1.5",
    "tailwindcss-rem-to-px": "^0.1.0"
  }
}
