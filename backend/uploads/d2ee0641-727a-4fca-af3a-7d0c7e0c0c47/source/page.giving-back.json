    "image_with_text_hnGU7b": {
      "type": "image-with-text",
      "blocks": {
        "caption_gFYt99": {
          "type": "caption",
          "settings": {
            "caption": "Every Child",
            "text_style": "subtitle",
            "text_size": "medium"
          }
        },
        "heading_cBXg9e": {
          "type": "heading",
          "settings": {
            "heading": "Deserves to Sleep Well",
            "heading_size": "h3"
          }
        },
        "text_M6LFjx": {
          "type": "text",
          "settings": {
            "text": "<p>Imagine a future where every child enjoys a warm, healthy night's sleep in a toxin- free, hypoallergic sleep system designed to support their growing bodies.<\/p> <p>At 5 Little Monkeys, that's the future we hope to see. Because we believe that every child deserves the long-term benefits of getting a good night's rest. And that's why we make it a priority to provide new sleep systems to kids in need.<\/p>",
            "text_style": "body"
          }
        }
      },
      "block_order": ["caption_gFYt99", "heading_cBXg9e", "text_M6LFjx"],
