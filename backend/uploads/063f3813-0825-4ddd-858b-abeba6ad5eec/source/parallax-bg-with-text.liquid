  {{ 'section-banner-with-text.css' | asset_url | stylesheet_tag }}
  {{ 'spring-page-layout.css' | asset_url | stylesheet_tag }}

  {%- style -%}

  #shopify-section-{{ section.id }} .banner-with-text__content-box {
  text-align: {{ section.settings.text_alignment }};
}

#shopify-section-{{ section.id }} .banner-with-text {
  height: {{ section.settings.banner_height }}px;
}

/* Tablet to Small Desktop (1280px - 1600px) */
@media screen and (min-width: 1280px) and (max-width: 1600px) {
  #shopify-section-{{ section.id }} .banner-with-text {
    height: {{ section.settings.tablet_banner_height }}vh;
  }
}
  .banner-with-text {
  	padding-top: {{ section.settings.top_padding_desktop }}px;
  	padding-bottom: {{ section.settings.bottom_padding_desktop }}px;
  }

  @media screen and (max-width: 990px) {
  	.banner-with-text {
  		padding-top: {{ section.settings.top_padding_mobile }}px;
  		padding-bottom: {{ section.settings.bottom_padding_mobile }}px;
  	}
  }
 #shopify-section-{{ section.id }} {
  	margin-top: {{ section.settings.top_margin_desktop}}px;
  	margin-bottom: {{ section.settings.bottom_margin_desktop }}px;
  }

  @media screen and (max-width: 990px) {
  	 #shopify-section-{{ section.id }} {
  		margin-top: {{ section.settings.top_margin_mobile }}px;
  		margin-bottom: {{ section.settings.bottom_margin_mobile }}px;
  	}
  }

  @media screen and (max-width: 1650px) {
    .banner-with-text-link .text p br{
      display: none;
    }
  }
    #shopify-section-{{ section.id }} .banner-with-text {
    --slide-overlay: rgba(var(--color-overlay), {{ section.settings.overlay_opacity }}%);
  }

  /* Mobile override */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .banner-with-text {
      {% if section.settings.image_mobile != blank %}
        background-image: url('{{ section.settings.image_mobile | image_url}}') !important;
        background-size: cover;
        background-position: center;
        background-attachment: unset !important;
      {% endif %}
    }
    
    #shopify-section-{{ section.id }} .banner-with-text__content-box {
      text-align: {{ section.settings.mobile_text_alignment }};
    }
    
    @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .banner-with-text {
      height: {{ section.settings.mobile_banner_height }}vh;
    }
}
  }
{%- endstyle -%}

{%- style -%}

  #shopify-section-{{ section.id }} .banner-with-text__content-box .heading {
    font-family: {{ section.settings.heading_font_family }};
    font-size: {{ section.settings.heading_font_size_desktop }}px;
    font-weight: {{ section.settings.heading_font_weight }};
    line-height: {{ section.settings.heading_line_height }};
    letter-spacing: {{ section.settings.heading_letter_spacing }}px;
  }
  
  #shopify-section-{{ section.id }} .banner-with-text__content-box .text {
    font-family: {{ section.settings.subheading_font_family }};
    font-size: {{ section.settings.subheading_font_size_desktop }}px;
    font-weight: {{ section.settings.subheading_font_weight }};
    line-height: {{ section.settings.subheading_line_height }};
    margin-top: {{ section.settings.subheading_margin }}px !important; 
    margin-bottom: {{ section.settings.subheading_margin }}px !important; 
  }
  
  #shopify-section-{{ section.id }} .banner-with-text__content-box .caption {
    font-family: {{ section.settings.caption_font_family }};
    font-size: {{ section.settings.caption_font_size_desktop }}px;
    font-weight: {{ section.settings.caption_font_weight }};
    line-height: {{ section.settings.caption_line_height }};
  }

  
  /* =====================
    Tablet to Small Desktop Typography (769px - 1600px)
  ===================== */
  @media screen and (min-width: 1280px) and (max-width: 1600px) {
    #shopify-section-{{ section.id }} .banner-with-text__content-box .heading {
      font-size: {{ section.settings.heading_font_size_tablet }}px;
    }
  
    #shopify-section-{{ section.id }} .banner-with-text__content-box .text {
      font-size: {{ section.settings.subheading_font_size_tablet }}px;
      margin-top: {{ section.settings.subheading_margin_tablet }}px !important; 
      margin-bottom: {{ section.settings.subheading_margin_tablet }}px !important;
    }
  
    #shopify-section-{{ section.id }} .banner-with-text__content-box .caption {
      font-size: {{ section.settings.caption_font_size_tablet }}px;
    }
  }

  /* =====================
    Mobile Typography
  ===================== */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .banner-with-text__content-box .heading {
      font-size: {{ section.settings.heading_font_size_mobile }}px;
    }
  
    #shopify-section-{{ section.id }} .banner-with-text__content-box .text {
      font-size: {{ section.settings.subheading_font_size_mobile }}px;
    }
  
    #shopify-section-{{ section.id }} .banner-with-text__content-box .caption {
      font-size: {{ section.settings.caption_font_size_mobile }}px;
    }
  
    /* Mobile visibility */
    {% unless section.settings.show_heading_mobile %}
      #shopify-section-{{ section.id }} .banner-with-text__content-box .heading {
        display: none;
      }
    {% endunless %}
  
    {% unless section.settings.show_subheading_mobile %}
      #shopify-section-{{ section.id }} .banner-with-text__content-box .text {
        display: none;
      }
    {% endunless %}
  }
  

  
  {% if section.settings.enable_text_shadow %}
    #shopify-section-{{ section.id }} .heading.h2 {
    text-shadow:
      {{ section.settings.shadow_x }}px
      {{ section.settings.shadow_y | times: 1.5 }}px
      {{ section.settings.shadow_blur | times: 1.5 }}px
      {{ section.settings.shadow_color }};
  }
  
  #shopify-section-{{ section.id }} .text,
  #shopify-section-{{ section.id }} .text p {
    text-shadow:
      {{ section.settings.shadow_x }}px
      {{ section.settings.shadow_y }}px
      {{ section.settings.shadow_blur }}px
      {{ section.settings.shadow_color }};
  }
  {% endif %}

#shopify-section-{{ section.id }} .banner-with-text__content-wrapper {
  inset: 0;
  display: flex;
  width: 100%;
  height: 100%;
}

