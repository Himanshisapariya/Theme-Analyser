}

#shopify-section-{{ section.id }} 
.banner-with-text[data-desktop-position="center-left"] 
.banner-with-text__content-wrapper {
  align-items: flex-start;
  justify-content: center;
}

#shopify-section-{{ section.id }} 
.banner-with-text[data-desktop-position="center"] 
.banner-with-text__content-wrapper {
  align-items: center;
  justify-content: center;
}

#shopify-section-{{ section.id }} 
.banner-with-text[data-desktop-position="center-right"] 
.banner-with-text__content-wrapper {
  align-items: flex-end;
  justify-content: center;
}

/* BOTTOM */
