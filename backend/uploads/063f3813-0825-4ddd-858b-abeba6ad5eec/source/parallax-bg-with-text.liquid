.banner-with-text[data-desktop-position="bottom-left"] 
.banner-with-text__content-wrapper {
  align-items: flex-start;
  justify-content: flex-end;
}

#shopify-section-{{ section.id }} 
.banner-with-text[data-desktop-position="bottom-center"] 
.banner-with-text__content-wrapper {
  align-items: center;
  justify-content: flex-end;
}

#shopify-section-{{ section.id }} 
.banner-with-text[data-desktop-position="bottom-right"] 
.banner-with-text__content-wrapper {
  align-items: flex-end;
  justify-content: flex-end;
