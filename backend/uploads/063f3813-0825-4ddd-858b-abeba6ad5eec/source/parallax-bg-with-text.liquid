#shopify-section-{{ section.id }} .banner-with-text {
  position: relative;
}

#shopify-section-{{ section.id }} .banner-with-text::before {
  content: "";
  position: absolute;
  inset: 0;
  background: var(--slide-overlay);
  z-index: 1;
  pointer-events: none;
  opacity: {% if section.settings.overlay_enable %}1{% else %}0{% endif %};
}

/* Keep content above overlay */
#shopify-section-{{ section.id }} .banner-with-text__content-block,
#shopify-section-{{ section.id }} .banner-with-text__content-wrapper {
  position: relative;
  z-index: 2;
}

.banner-with-text__content-box .ctm-underline-button{
  padding: 0 !important;
  margin-right: 24px;
}
  {%- endstyle -%}
  

  {% liquid
    assign image_size = section.settings.image_size

    case image_size
      when 'adapt'
        assign section_size = 'adapt'
      when 'small'
        assign section_size = '30vh'
      when 'medium'
        assign section_size = '60vh'
      when 'large'
        assign section_size = 'calc(100vh - var(--announcement-height))'
    endcase
  %}
  {% style %}
    #shopify-section-{{ section.id }} .banner-with-text__video-block {
      --slide-overlay : rgba(var(--color-overlay), {{ section.settings.overlay_opacity }}%);
    }
    #shopify-section-{{ section.id }} .banner-with-text__image-block {
      --slide-overlay : rgba(var(--color-overlay), {{ section.settings.overlay_opacity }}%);
    }
  {% endstyle %}
<a class="banner-with-text-link">
  <div
    class="
      banner-with-text {{ section.settings.extra_class }}
      header-color-{{ section.settings.color_scheme }}
      {% if section.settings.color_scheme == 'dark' %} theme-light
      {% elsif section.settings.color_scheme == 'light' %} theme-dark color-background-5
      {% endif %}
      {{ section.settings.spring_banner_class }}
    "
     data-desktop-position="{{ section.settings.desktop_content_position }}"
  data-mobile-position="{{ section.settings.mobile_content_position }}"
    {% if section.settings.background_image != blank %}
      style="
        background-image: url('{{ section.settings.background_image | image_url: width: 2240 }}');
        background-size: cover;
        background-position: center center;
        background-attachment: fixed;
        width: 100%;
      "
    {% endif %}
  >

    <div class="banner-with-text__video-block {% if section.settings.overlay_enable %}have-overlay{% endif %}">
      {%- if section.settings.video != null -%}
        {% liquid
          assign adapt_height = 1 | divided_by: section.settings.video.aspect_ratio | times: 100 | append: '%'
          if image_size == 'adapt'
            assign section_size = adapt_height
          endif
        %}
        {% style %}
          #shopify-section-{{ section.id }} .banner-with-text{
            --slide-height : {{ section_size }};
          }
        {% endstyle %}
        {{
          section.settings.video
          | video_tag: image_size: '1100x', autoplay: true, loop: true, controls: false, muted: true
        }}
      {% endif %}
    </div>

    {% unless section.settings.background_image %}
      <div class="banner-with-text__image-block {% if section.settings.overlay_enable %}have-overlay{% endif %}">
        {% liquid
          assign image_height = section.settings.image.width | divided_by: section.settings.image.aspect_ratio
          assign adapt_height = 1 | divided_by: section.settings.image.aspect_ratio | times: 100 | append: '%'
          if image_size == 'adapt'
            assign section_size = adapt_height
          endif
        %}
        {% style %}
          #shopify-section-{{ section.id }} .banner-with-text{
            --slide-height : {{ section_size }};
          }
        {% endstyle %}

        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 2240
            | image_tag:
              loading: 'lazy',
              widths: '360,533,720,940,1066,1340,1560,1920,2240',
              class: 'motion-reduce',
              width: section.settings.image.width,
              height: image_height
          }}
        {% elsif section.settings.video == null %}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}

        {%- if section.settings.image_mobile != blank -%}
          {{
            section.settings.image_mobile
            | image_url: width: auto
            | image_tag: loading: 'lazy', class: 'spring-banner-mobile-img'
          }}
        {%- endif -%}
      </div>
    {% endunless %}

    <div class="banner-with-text__content-block fullscreen-container section-{{ section.id }}-padding">
      <div class="banner-with-text__content-wrapper">

        {% if section.settings.banner_logo_image != blank %}
          <div class="banner-image-logo">
            <img
              src="{{ section.settings.banner_logo_image | image_url }}"
              width="auto"
              height="auto"
              alt="{{ section.settings.banner_logo_image.alt | escape }}"
            >
          </div>
        {% endif %}

        <div class="banner-with-text__content-box content-width--{{ section.settings.content_width }}">
          {% if section.settings.caption_class != blank %}
            <span class="caption">{{ section.settings.caption_class }}</span>
          {% endif %}

          {% if section.settings.title != blank %}
            <h2 class="heading h2">
              {{ section.settings.title }}
            </h2>
          {% endif %}

          {% if section.settings.content_text != blank %}
            <div class="text">{{ section.settings.content_text }}</div>
          {% endif %}

          {% if section.settings.button_label != blank %}
            <a
              {% if section.settings.button_link.url != blank %}
                href="{{ section.settings.button_link }}"
              {% endif %}
              type="button"
              {% if section.settings.button_link.url == blank %}
                aria-disabled="true"
              {% endif %}
              class="{{ section.settings.button_style }}"
            >
              {{ section.settings.button_label }}
            </a>
          {% endif %}
           {% if section.settings.second_button_label != blank %}
            <a
              {% if section.settings.second_button_link.url != blank %}
                href="{{ section.settings.second_button_link }}"
              {% endif %}
              type="button"
              {% if section.settings.second_button_link.url == blank %}
                aria-disabled="true"
              {% endif %}
              class="{{ section.settings.button_style }}"
            >
              {{ section.settings.second_button_label }}
            </a>
          {% endif %}
        </div>

      </div>
    </div>

  </div>
</a>

  {% javascript %}
    const events = [
      'shopify:section:reorder',
      'shopify:section:deselect',
      'shopify:section:select',
      'shopify:section:unload',
      'shopify:section:load',
    ];

    const banner_with_text = () => {
      let headerOverlay = document.querySelector('.overlay');
      let pageAbout = document.querySelector('.page-about');
      let pageLookbook = document.querySelector('.page-lookbook');
      let breadCrumb = document.querySelector('.main-breadcrumb');
      let colorScheme = document.querySelector('.header-color-light');
      let colorSchemeDark = document.querySelector('.header-color-dark');
      let firstSection = document.querySelector('main section:first-of-type');

      if (headerOverlay && firstSection.classList.contains('section-banner-with-text')) {
        document.querySelector('main').classList.add('page-about');
        let pageAbout = document.querySelector('.page-about');
        let pageLookbook = document.querySelector('.page-lookbook');
        if (colorScheme) {
          headerOverlay.classList.add('theme-dark');
          headerOverlay.classList.add('header-color-background-5');
          if (pageAbout || pageLookbook) {
            breadCrumb && breadCrumb.classList.add('color-background-5');
          }
        }

        if (colorSchemeDark) {
          headerOverlay.classList.remove('theme-dark');
          headerOverlay.classList.remove('header-color-background-5');
          headerOverlay.classList.add('color-background-1');
          if (pageAbout || pageLookbook) {
            breadCrumb && breadCrumb.classList.remove('color-background-5');
          }
        }
      } else {
        if (colorScheme) {
          if (pageAbout || pageLookbook) {
            breadCrumb && breadCrumb.classList.add('color-background-5');
          }
        }

        if (colorSchemeDark) {
          if (pageAbout || pageLookbook) {
            breadCrumb && breadCrumb.classList.remove('color-background-5');
          }
        }
      }
    };

    banner_with_text();

    events.forEach(function (item) {
      document.addEventListener(item, function () {
        banner_with_text();
      });
    });
  {% endjavascript %}

