<link
  rel="stylesheet"
  href="{{ 'section-main-page.css' | asset_url }}"
  media="print"
  onload="this.media='all'">
<link
  rel="stylesheet"
  href="{{ 'component-rte.css' | asset_url }}"
  media="print"
  onload="this.media='all'">

<noscript>{{ 'section-main-page.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-rte.css' | asset_url | stylesheet_tag }}</noscript>

<div class="container  {{ section.settings.extra_class }}">
  <div class="page-header">
    <div class="page-header__inner">
      <h1 class="main-page-title page-title title--page">
        {{ page.title | escape }}
      </h1>
    </div>
  </div>
  <div class="rte">
    {{ page.content }}
  </div>
</div>

{%  style  %} 
@media only screen and (min-width: 750px) {
	.template-{{ template.name }} #MainContent{
		background-image: url('{{ section.settings.background_image | image_url: width:2000 }}');
		background-size: cover;
		background-position: center;
		background-repeat: no-repeat;
	}
}
{% endstyle %}

{% schema %}
  {
    "name": "t:sections.main-page.name",
    "tag": "section",
    "class": "page-section",
    "settings": [
      {
        "type": "image_picker",
        "label": "Background Image",
        "id": "background_image"
      },
      {
        "type": "text",
        "id": "extra_class",
        "label": "Extra Class"
		  },
    ]
  }
{% endschema %}